# 📋 Utkal Brahmin Samaj - Environment Variables Example
# Copy this to a file named .env and fill in your actual values.
# Do NOT commit your actual .env file to GitHub.

# 🌐 Server Settings
PORT=3000
NODE_ENV=production
SESSION_SECRET=a_very_long_random_string_here

# 🗄️ Database Settings (MongoDB Atlas)
# Example: mongodb+srv://username:password@cluster.mongodb.net/samaj_db
MONGODB_URI=

# ☁️ Cloudinary Settings (For Image Storage)
# Get these from your Cloudinary Dashboard
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# 🔐 Admin Credentials (Default credentials if DB is empty)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=password108

# 🤖 AI Chatbot (Optional - Gemini API)
GEMINI_API_KEY=

# 📧 SMTP Settings (Optional - for Password Reset)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@yourdomain.com
