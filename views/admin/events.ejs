<%- include('partials/admin-header') %>

<section class="py-12 bg-gray-50 flex-grow">
  <div class="container mx-auto px-4 max-w-6xl">
    
    <div class="flex justify-between items-center mb-6">
      <div>
        <h1 class="text-2xl font-bold text-gray-800"><a href="/admin" class="text-gray-400 hover:text-saffron-500 mr-2"><i class="fas fa-arrow-left text-lg"></i></a> Manage Events</h1>
      </div>
      <a href="/admin/events/add" class="bg-saffron-600 hover:bg-saffron-700 text-white px-4 py-2 rounded text-sm font-medium shadow-sm transition-colors inline-flex items-center">
        <i class="fas fa-calendar-plus mr-2"></i> Add Event
      </a>
    </div>

    <!-- Event List Placeholder -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-100 overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
          <thead>
            <tr class="bg-gray-50 text-gray-500 text-xs uppercase tracking-wider border-b border-gray-200">
              <th class="px-6 py-4 font-medium">Event Title</th>
              <th class="px-6 py-4 font-medium">Date</th>
              <th class="px-6 py-4 font-medium">Location</th>
              <th class="px-6 py-4 font-medium">Status</th>
              <th class="px-6 py-4 font-medium text-right">Actions</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100 text-sm">
            <% if (events && events.length > 0) { %>
              <% events.forEach(event => { %>
                <tr class="hover:bg-gray-50 text-gray-700">
                  <td class="px-6 py-4 font-medium text-gray-900 border-l-4 <%= new Date(event.date) >= new Date() ? 'border-l-green-500' : 'border-l-gray-400' %>">
                    <%= event.title %>
                  </td>
                  <td class="px-6 py-4"><%= event.date.toLocaleDateString() %>, <%= event.date.toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}) %></td>
                  <td class="px-6 py-4"><%= event.location %></td>
                  <td class="px-6 py-4">
                    <% if (new Date(event.date) >= new Date()) { %>
                      <span class="bg-green-100 text-green-700 px-2 py-1 rounded text-xs font-medium">Upcoming</span>
                    <% } else { %>
                      <span class="bg-gray-200 text-gray-700 px-2 py-1 rounded text-xs font-medium">Past</span>
                    <% } %>
                  </td>
                  <td class="px-6 py-4 text-right">
                    <form action="/admin/events/<%= event._id %>/delete" method="POST" class="inline" onsubmit="return confirm('Are you sure you want to delete this event?');">
                      <button type="submit" class="text-red-500 hover:text-red-700 mx-1" title="Delete"><i class="fas fa-trash-alt"></i></button>
                    </form>
                  </td>
                </tr>
              <% }) %>
            <% } else { %>
              <tr>
                <td colspan="5" class="px-6 py-8 text-center text-gray-500">No events found. Start by creating a new event.</td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>

  </div>
</section>

<%- include('partials/admin-footer') %>
