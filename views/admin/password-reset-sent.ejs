<%- include('partials/admin-header') %>
<section class="py-12 bg-gray-50">
  <div class="container mx-auto max-w-lg bg-white p-6 rounded shadow">
    <h1 class="text-2xl font-bold mb-4">Password Reset</h1>
    <% if (via === 'email') { %>
      <p class="mb-4">A password reset link has been sent to <strong><%= email %></strong> (if the address exists).</p>
    <% } else { %>
      <p class="mb-4">No SMTP configured. Use the token below to reset your password (valid 1 hour):</p>
      <pre class="bg-gray-100 p-3 rounded"><%= token %></pre>
      <p class="mt-3">Open: <a class="text-blue-600" href="/admin/password-reset/<%= token %>">/admin/password-reset/<%= token %></a></p>
    <% } %>
    <div class="mt-6">
      <a href="/admin/login" class="text-saffron-600">Back to login</a>
    </div>
  </div>
</section>
<%- include('partials/admin-footer') %>
