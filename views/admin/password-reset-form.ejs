<%- include('partials/admin-header') %>
<section class="py-12 bg-gray-50">
  <div class="container mx-auto max-w-lg bg-white p-6 rounded shadow">
    <h1 class="text-2xl font-bold mb-4">Set New Password</h1>
    <% if (error) { %>
      <div class="text-red-600 mb-3"><%= error %></div>
    <% } %>
    <form method="POST" action="/admin/password-reset/<%= token %>">
      <div class="mb-3">
        <label class="block text-sm font-medium">New Password</label>
        <input name="password" type="password" class="mt-1 block w-full border rounded px-3 py-2" required />
      </div>
      <div class="mb-3">
        <label class="block text-sm font-medium">Confirm Password</label>
        <input name="passwordConfirm" type="password" class="mt-1 block w-full border rounded px-3 py-2" required />
      </div>
      <div class="flex justify-end">
        <button class="bg-saffron-600 text-white px-4 py-2 rounded">Set Password</button>
      </div>
    </form>
  </div>
</section>
<%- include('partials/admin-footer') %>
