<%- include('partials/admin-header') %>

<section class="py-12 bg-gray-50 flex-grow">
  <div class="container mx-auto px-4 max-w-4xl">
    
    <div class="flex items-center mb-6">
      <a href="/admin/members" class="text-gray-400 hover:text-saffron-500 mr-4"><i class="fas fa-arrow-left text-xl"></i></a>
      <h1 class="text-2xl font-bold text-gray-800">Add New Member</h1>
    </div>

    <div class="bg-white rounded-lg shadow-sm border border-gray-100 p-6 md:p-8">
      <form action="/admin/members/add" method="POST">
        
        <h3 class="text-lg font-bold text-saffron-700 border-b pb-2 mb-6">Personal Details</h3>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Full Name *</label>
            <input type="text" name="name" required class="w-full px-4 py-2 border border-gray-300 rounded focus:ring-saffron-500 focus:border-saffron-500">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Gotra (गोत्र) *</label>
            <select id="gotraSelect" name="gotra" required class="w-full px-4 py-2 border border-gray-300 rounded focus:ring-saffron-500 focus:border-saffron-500 bg-white" onchange="toggleGotraInput(this)">
              <option value="">-- Select Gotra (गोत्र चुनें) --</option>
              <option value="Atri">Atri / Atreya (अत्रि / आत्रेय)</option>
              <option value="Upamanyu">Upamanyu (उपमन्यु)</option>
              <option value="Kapinjala">Kapinjala (कपिंजल)</option>
              <option value="Kashyapa">Kashyapa (कश्यप)</option>
              <option value="Kaundinya">Kaundinya (कौंडिन्य)</option>
              <option value="Kaushik">Kaushik (कौशिक)</option>
              <option value="Gargya">Gargya (गार्ग्य)</option>
              <option value="Gautama">Gautama (गौतम)</option>
              <option value="Jamadagnya">Jamadagnya (जामदग्न्य)</option>
              <option value="Parashara">Parashara (पराशर)</option>
              <option value="Bharadwaj">Bharadwaj (भरद्वाज)</option>
              <option value="Vatsa">Vatsa (वत्स)</option>
              <option value="Vashistha">Vashistha (वसिष्ठ)</option>
              <option value="Vishwamitra">Vishwamitra (विश्वामित्र)</option>
              <option value="Shandilya">Shandilya (शांडिल्य)</option>
              <option value="Harita">Harita (हरित)</option>
              <option value="Other">Other (अन्य)</option>
            </select>
            <div id="gotraCustomDiv" style="display:none;" class="mt-2">
              <input type="text" id="gotraCustomInput" placeholder="अपना गोत्र लिखें / Enter your Gotra" class="w-full px-4 py-2 border border-gray-300 rounded focus:ring-saffron-500 focus:border-saffron-500">
            </div>
          </div>
          <script>
            function toggleGotraInput(select) {
              const customDiv = document.getElementById('gotraCustomDiv');
              const customInput = document.getElementById('gotraCustomInput');
              if (select.value === 'Other') {
                customDiv.style.display = 'block';
                customInput.required = true;
                customInput.name = 'gotra';
                select.name = '_gotraSelect';
              } else {
                customDiv.style.display = 'none';
                customInput.required = false;
                customInput.name = '';
                select.name = 'gotra';
              }
            }
          </script>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Village (Mool) *</label>
            <input type="text" name="village" required class="w-full px-4 py-2 border border-gray-300 rounded focus:ring-saffron-500 focus:border-saffron-500">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Occupation</label>
            <input type="text" name="occupation" class="w-full px-4 py-2 border border-gray-300 rounded focus:ring-saffron-500 focus:border-saffron-500">
          </div>
        </div>

        <h3 class="text-lg font-bold text-saffron-700 border-b pb-2 mb-6">Contact Information</h3>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Contact Number *</label>
            <input type="tel" name="contactNumber" required class="w-full px-4 py-2 border border-gray-300 rounded focus:ring-saffron-500 focus:border-saffron-500">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Email Address</label>
            <input type="email" name="email" class="w-full px-4 py-2 border border-gray-300 rounded focus:ring-saffron-500 focus:border-saffron-500">
          </div>
          <div class="md:col-span-2">
            <label class="block text-sm font-medium text-gray-700 mb-1">Current Address</label>
            <textarea name="address" rows="3" class="w-full px-4 py-2 border border-gray-300 rounded focus:ring-saffron-500 focus:border-saffron-500"></textarea>
          </div>
        </div>

        <div class="flex items-center mb-8 bg-gray-50 p-4 rounded border border-gray-200">
          <input id="isCommitteeMember" name="isCommitteeMember" type="checkbox" class="h-5 w-5 text-saffron-600 focus:ring-saffron-500 border-gray-300 rounded">
          <label for="isCommitteeMember" class="ml-3 block text-gray-800 font-medium">Assign Committee Member Role (Admin/Special Tag)</label>
        </div>

        <div class="flex justify-end gap-4 border-t pt-6">
          <a href="/admin/members" class="px-6 py-2 border border-gray-300 rounded text-gray-700 font-medium hover:bg-gray-50 transition-colors">Cancel</a>
          <button type="submit" class="px-6 py-2 bg-saffron-600 hover:bg-saffron-700 text-white rounded font-medium shadow-sm transition-colors">
            <i class="fas fa-save mr-2"></i> Save Member
          </button>
        </div>

      </form>
    </div>
  </div>
</section>

<%- include('partials/admin-footer') %>
