<%- include('partials/admin-header') %>

  <section class="py-12 bg-gray-50 flex-grow">
    <div class="container mx-auto px-4 max-w-4xl">

      <div class="flex items-center justify-between mb-6">
        <div class="flex items-center">
          <a href="/admin/members" class="text-gray-400 hover:text-saffron-500 mr-4"><i
              class="fas fa-arrow-left text-xl"></i></a>
          <h1 class="text-2xl font-bold text-gray-800">
            <%= typeof member !=='undefined' ? 'Edit Member' : 'Add New Member' %>
          </h1>
        </div>
        <% if (typeof member !== 'undefined' && member.generationLevel !== null && member.generationLevel !== undefined) { %>
          <div class="flex items-center gap-2 bg-indigo-50 border border-indigo-200 px-4 py-2 rounded-xl">
            <span class="text-[10px] uppercase font-black tracking-widest text-indigo-400">Generation Level</span>
            <span class="text-xl font-black text-indigo-700">P<%= member.generationLevel %></span>
          </div>
        <% } %>
      </div>

      <div class="bg-white rounded-lg shadow-sm border border-gray-100 p-6 md:p-8">
        <form action="/admin/members/<%= typeof member !== 'undefined' ? member._id + '/edit' : 'add' %>" method="POST">

          <!-- Basic Information Section -->
          <h3 class="text-xl font-bold text-gray-800 mb-4 border-b pb-2"><i
              class="fas fa-user mr-2 text-saffron-500"></i> बुनियादी जानकारी (Basic Information)</h3>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
            <div>
              <label class="block text-sm font-bold text-gray-700 mb-2">पूर्ण नाम * (Full Name)</label>
              <div class="flex gap-2">
                <select name="honorific" id="honorific"
                  class="w-32 px-3 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-saffron-500"
                  onchange="syncHonorific(this.value)">
                  <option value="" <%=typeof member !=='undefined' && member.honorific==='' ? 'selected' : '' %>>-- Title --</option>
                  <option value="Shri" <%=typeof member !=='undefined' && member.honorific==='Shri' ? 'selected' : '' %>>Shri (श्री)</option>
                  <option value="Smt." <%=typeof member !=='undefined' && (member.honorific==='Smt.' || member.honorific==='Smt') ? 'selected' : '' %>>Smt. (श्रीमती)</option>
                  <option value="Ms." <%=typeof member !=='undefined' && member.honorific==='Ms.' ? 'selected' : '' %>>Ms. (कुमारी)</option>
                  <option value="Late" <%=typeof member !=='undefined' && member.honorific==='Late' ? 'selected' : '' %>>Late (स्वर्गीय)</option>
                  <option value="Dr." <%=typeof member !=='undefined' && member.honorific==='Dr.' ? 'selected' : '' %>>Dr. (डॉ.)</option>
                  <option value="Er." <%=typeof member !=='undefined' && member.honorific==='Er.' ? 'selected' : '' %>>Er. (अभि.)</option>
                  <option value="Prof." <%=typeof member !=='undefined' && member.honorific==='Prof.' ? 'selected' : '' %>>Prof. (प्रो.)</option>
                </select>
                <input type="text" name="name"
                  class="flex-grow px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-saffron-500"
                  value="<%= typeof member !== 'undefined' ? member.name : '' %>" required placeholder="Name">
              </div>
            </div>

            <div>
              <label class="block text-sm font-bold text-gray-700 mb-2">अंतिम नाम (Surname)</label>
              <% const currentSurname = typeof member !== 'undefined' ? member.surname : '';
                 const isOtherSurname = currentSurname && typeof surnames !== 'undefined' && !surnames.some(s => s.surname === currentSurname); %>
                <select name="surname_select" id="surname_select"
                  class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-saffron-500"
                  onchange="toggleOtherSurname(this)">
                  <option value="">-- Choose Surname --</option>
                  <% if (typeof surnames !== 'undefined') { %>
                    <% surnames.forEach(s => { %>
                      <option value="<%= s.surname %>" <%= currentSurname === s.surname ? 'selected' : '' %>><%= s.surname %></option>
                    <% }) %>
                  <% } %>
                  <option value="Others" <%= isOtherSurname ? 'selected' : '' %>>Others (अन्य)</option>
                </select>

                <div id="otherSurnameDiv" class="mt-3 <%= isOtherSurname ? '' : 'hidden' %>">
                  <label class="block text-xs font-bold text-saffron-600 mb-1 uppercase">कृपया उपनाम लिखें (Please type Surname)</label>
                  <input type="text" name="surname_other" id="surname_other"
                    class="w-full px-4 py-2 rounded-lg border border-saffron-300 focus:ring-2 focus:ring-saffron-500 bg-saffron-50"
                    value="<%= isOtherSurname ? currentSurname : '' %>" placeholder="Enter custom surname...">
                </div>
            </div>

            <script>
              function toggleOtherSurname(select) {
                const otherDiv = document.getElementById('otherSurnameDiv');
                const otherInput = document.getElementById('surname_other');
                if (select.value === 'Others') {
                  otherDiv.classList.remove('hidden');
                  otherInput.required = true;
                  otherInput.focus();
                } else {
                  otherDiv.classList.add('hidden');
                  otherInput.required = false;
                }
              }
            </script>

            <div>
              <label class="block text-sm font-bold text-gray-700 mb-2">गोत्र * (Gotra)</label>
              <% const standardGotras=['Kashyap', 'Bhardwaj' , 'Gautam' , 'Vashishtha' , 'Angiras' , 'Atri'
                , 'Vishwamitra' , 'Agastya' ]; const currentGotra=typeof member !=='undefined' ? member.gotra : '' ;
                const isOtherGotra=currentGotra && !standardGotras.includes(currentGotra); %>
                <select name="gotra_select" id="gotra_select"
                  class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-saffron-500"
                  onchange="toggleOtherGotra(this)" required>
                  <option value="">-- Choose Gotra --</option>
                  <% standardGotras.forEach(g=> { %>
                    <option value="<%= g %>" <%=currentGotra===g ? 'selected' : '' %>><%= g %>
                    </option>
                    <% }) %>
                      <option value="Others" <%=isOtherGotra ? 'selected' : '' %>>Others (अन्य)</option>
                </select>

                <div id="otherGotraDiv" class="mt-3 <%= isOtherGotra ? '' : 'hidden' %>">
                  <label class="block text-xs font-bold text-saffron-600 mb-1 uppercase">कृपया गोत्र लिखें (Please type
                    Gotra)</label>
                  <input type="text" name="gotra_other" id="gotra_other"
                    class="w-full px-4 py-2 rounded-lg border border-saffron-300 focus:ring-2 focus:ring-saffron-500 bg-saffron-50"
                    value="<%= isOtherGotra ? currentGotra : '' %>" placeholder="Enter custom gotra...">
                </div>
            </div>

            <div>
              <label class="block text-sm font-bold text-gray-700 mb-2">लिंग * (Gender)</label>
              <select name="gender" id="gender" class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-saffron-500" required
                onchange="syncGender(this.value)">
                <option value="Male" <%= typeof member !== 'undefined' && member.gender === 'Male' ? 'selected' : '' %>>Male (पुरुष)</option>
                <option value="Female" <%= typeof member !== 'undefined' && member.gender === 'Female' ? 'selected' : '' %>>Female (महिला)</option>
                <option value="Other" <%= typeof member !== 'undefined' && member.gender === 'Other' ? 'selected' : '' %>>Other (अन्य)</option>
              </select>
            </div>

            <div>
              <label class="block text-sm font-bold text-gray-700 mb-2">जन्म तिथि (Date of Birth)</label>
              <input type="date" name="dob"
                class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-saffron-500"
                value="<%= typeof member !== 'undefined' && member.matrimonialProfile && member.matrimonialProfile.dateOfBirth ? member.matrimonialProfile.dateOfBirth.toISOString().split('T')[0] : '' %>">
            </div>

            <div>
              <label class="block text-sm font-bold text-gray-700 mb-2">रक्त समूह (Blood Group)</label>
              <select name="bloodGroup" class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-saffron-500">
                <option value="">-- Choose --</option>
                <% ['A+', 'A-', 'B+', 'B-', 'O+', 'O-', 'AB+', 'AB-'].forEach(bg => { %>
                  <option value="<%= bg %>" <%= typeof member !== 'undefined' && member.bloodGroup === bg ? 'selected' : '' %>><%= bg %></option>
                <% }) %>
              </select>
            </div>

            <div>
              <label class="block text-sm font-bold text-gray-700 mb-2">शिक्षा (Qualification)</label>
              <input type="text" name="education"
                class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-saffron-500"
                value="<%= typeof member !== 'undefined' && member.matrimonialProfile ? (member.matrimonialProfile.education || '') : '' %>"
                placeholder="e.g. B.Tech, MA, 12th">
            </div>

            <script>
              function toggleOtherGotra(select) {
                const otherDiv = document.getElementById('otherGotraDiv');
                const otherInput = document.getElementById('gotra_other');
                if (select.value === 'Others') {
                  otherDiv.classList.remove('hidden');
                  otherInput.required = true;
                  otherInput.focus();
                } else {
                  otherDiv.classList.add('hidden');
                  otherInput.required = false;
                }
              }

              // Sync logic: Honorific → Gender + isDeceased
              function syncHonorific(val) {
                const genderSel = document.getElementById('gender');
                const deceasedCb = document.getElementById('isDeceased');
                const deathSection = document.getElementById('deathDateSection');

                if (val === 'Late') {
                  if (deceasedCb) { deceasedCb.checked = true; }
                  if (deathSection) { deathSection.classList.remove('hidden'); }
                } else {
                  if (deceasedCb) { deceasedCb.checked = false; }
                  if (deathSection) { deathSection.classList.add('hidden'); }
                }

                if (val === 'Shri') {
                  if (genderSel) genderSel.value = 'Male';
                } else if (val === 'Smt.' || val === 'Ms.') {
                  if (genderSel) genderSel.value = 'Female';
                }
              }

              // Sync logic: Gender → Honorific
              function syncGender(val) {
                const honorificSel = document.getElementById('honorific');
                if (!honorificSel) return;
                const cur = honorificSel.value;
                if (val === 'Male' && (cur === 'Smt.' || cur === 'Ms.')) {
                  honorificSel.value = 'Shri';
                } else if (val === 'Female' && cur === 'Shri') {
                  honorificSel.value = 'Smt.';
                }
              }

              function toggleDeathDate() {
                const deceasedCb = document.getElementById('isDeceased');
                const section = document.getElementById('deathDateSection');
                const honorificSel = document.getElementById('honorific');
                const isDeceased = deceasedCb && deceasedCb.checked;
                if (section) {
                  isDeceased ? section.classList.remove('hidden') : section.classList.add('hidden');
                }
                if (honorificSel && isDeceased && honorificSel.value !== 'Late') {
                  honorificSel.value = 'Late';
                }
              }

              // Auto-fill surname and gotra from father
              async function autoFillFromFather() {
                const fatherSelect = document.getElementById('father_select');
                const fatherId = fatherSelect.value;
                
                if (!fatherId) return; // No father selected

                try {
                  const response = await fetch(`/admin/api/member/${fatherId}/family-data`);
                  if (!response.ok) return;
                  
                  const data = await response.json();
                  
                  if (data.surname) {
                    // Set surname dropdown
                    const surnameSelect = document.getElementById('surname_select');
                    const surnameOther = document.getElementById('surname_other');
                    
                    const option = Array.from(surnameSelect.options).find(o => o.value === data.surname);
                    if (option) {
                      surnameSelect.value = data.surname;
                      surnameOther.value = '';
                      document.getElementById('otherSurnameDiv').classList.add('hidden');
                    } else {
                      // Custom surname
                      surnameSelect.value = 'Others';
                      surnameOther.value = data.surname;
                      document.getElementById('otherSurnameDiv').classList.remove('hidden');
                    }
                  }
                  
                  if (data.gotra) {
                    // Set gotra dropdown
                    const gotraSelect = document.getElementById('gotra_select');
                    const gotraOther = document.getElementById('gotra_other');
                    
                    const option = Array.from(gotraSelect.options).find(o => o.value === data.gotra);
                    if (option) {
                      gotraSelect.value = data.gotra;
                      gotraOther.value = '';
                      document.getElementById('otherGotraDiv').classList.add('hidden');
                    } else {
                      // Custom gotra
                      gotraSelect.value = 'Others';
                      gotraOther.value = data.gotra;
                      document.getElementById('otherGotraDiv').classList.remove('hidden');
                    }
                  }
                  
                  // Show a hint
                  showFamilyHint(`✅ Inherited from Father: ${data.surname} (${data.gotra})`);
                } catch (e) {
                  console.error('Error fetching father data:', e);
                }
              }

              function showFamilyHint(message) {
                // Remove existing hint if any
                const existing = document.querySelector('.family-hint');
                if (existing) existing.remove();
                
                const hint = document.createElement('div');
                hint.className = 'family-hint mt-2 p-2 bg-green-50 text-green-700 text-xs rounded border border-green-200';
                hint.innerHTML = message;
                
                const fatherSelect = document.getElementById('father_select');
                fatherSelect.parentNode.appendChild(hint);
                
                setTimeout(() => hint.remove(), 3000);
              }
            </script>

            <div>
              <label class="block text-sm font-bold text-gray-700 mb-2">मूल गांव * (Original Village/Mool)</label>
              <input type="text" name="village" list="villages"
                class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-saffron-500"
                value="<%= typeof member !== 'undefined' ? member.village : '' %>" required>
              <datalist id="villages">
                <option value="Pusaur">
                <option value="Raigarh">
                <option value="Ambikapur">
                <option value="Sambalpur">
              </datalist>
            </div>

            <div>
              <label class="block text-sm font-bold text-gray-700 mb-2">व्यवसाय (Occupation)</label>
              <input type="text" name="occupation"
                class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-saffron-500"
                value="<%= typeof member !== 'undefined' ? member.occupation : '' %>">
            </div>
          </div>

          <!-- Ancestor / Deceased Section -->
          <div class="mb-8 p-4 bg-gray-50 rounded-lg border border-gray-200">
            <div class="flex items-center">
              <input type="checkbox" name="isDeceased" id="isDeceased"
                class="w-5 h-5 text-saffron-600 rounded focus:ring-saffron-500" <%=typeof member !=='undefined' &&
                member.isDeceased ? 'checked' : '' %> onchange="toggleDeathDate()">
              <label for="isDeceased" class="ml-3 text-sm font-bold text-gray-700">क्या यह पूर्वज / स्वर्गीय हैं? (Is
                Ancestor / Deceased?)</label>
            </div>
            <div id="deathDateSection"
              class="mt-4 <%= typeof member !== 'undefined' && member.isDeceased ? '' : 'hidden' %>">
              <label class="block text-xs font-bold text-gray-500 mb-1 caps">स्वर्गवास तिथि (Death Date -
                Optional)</label>
              <input type="date" name="deathDate" class="w-full md:w-1/3 px-4 py-2 border rounded"
                value="<%= typeof member !== 'undefined' && member.deathDate ? member.deathDate.toISOString().split('T')[0] : '' %>">
            </div>
          </div>

          <!-- Family & Relationships Section -->
          <h3 class="text-xl font-bold text-gray-800 mb-4 border-b pb-2"><i
              class="fas fa-users mr-2 text-saffron-500"></i> पारिवारिक संबंध (Family & Relationships)</h3>

          <style>
            select option {
              padding: 6px 10px;
              line-height: 1.6;
            }
          </style>

          <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
            <div>
              <label class="block text-sm font-bold text-gray-700 mb-2">पिता (Father - Select)</label>
              <select name="father" id="father_select"
                class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-saffron-500 bg-white"
                onchange="autoFillFromFather()">
                <option value="">-- अज्ञात / कोई नहीं (None) --</option>
                <% if (typeof allMembers !=='undefined' ) { %>
                  <% allMembers.forEach(m=> { %>
                    <option value="<%= m._id %>" <%=typeof member !=='undefined' && member.father &&
                      member.father.toString()===m._id.toString() ? 'selected' : '' %>>
                      <%= m.name %> (<%= m.village %>) <%= m.isDeceased ? '†' : '' %>
                    </option>
                    <% }) %>
                      <% } %>
              </select>
              <div class="mt-3">
                <label class="block text-[10px] font-bold text-gray-500 uppercase">मैन्युअल नाम (Manual Name - Fallback if not in list)</label>
                <input type="text" name="fatherName" 
                  class="w-full px-3 py-1.5 text-sm rounded border border-gray-200 focus:ring-1 focus:ring-saffron-500 bg-gray-50 text-gray-700"
                  value="<%= typeof member !== 'undefined' ? (member.fatherName || '') : '' %>" 
                  placeholder="Enter father's name manually...">
              </div>
            </div>

            <div>
              <label class="block text-sm font-bold text-gray-700 mb-2">माता (Mother - Select)</label>
              <select name="mother"
                class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-saffron-500 bg-white">
                <option value="">-- अज्ञात / कोई नहीं (None) --</option>
                <% if (typeof allMembers !=='undefined' ) { %>
                  <% allMembers.forEach(m=> { %>
                    <option value="<%= m._id %>" <%=typeof member !=='undefined' && member.mother &&
                      member.mother.toString()===m._id.toString() ? 'selected' : '' %>>
                      <%= m.name %> (<%= m.village %>) <%= m.isDeceased ? '†' : '' %>
                    </option>
                    <% }) %>
                      <% } %>
              </select>
              <div class="mt-3">
                <label class="block text-[10px] font-bold text-gray-500 uppercase">मैन्युअल नाम (Manual Name - Fallback if not in list)</label>
                <input type="text" name="motherName" 
                  class="w-full px-3 py-1.5 text-sm rounded border border-gray-200 focus:ring-1 focus:ring-saffron-500 bg-gray-50 text-gray-700"
                  value="<%= typeof member !== 'undefined' ? (member.motherName || '') : '' %>" 
                  placeholder="Enter mother's name manually...">
              </div>
            </div>

            <div>
              <label class="block text-sm font-bold text-gray-700 mb-2">जीवनसाथी (Spouse - Select Member)</label>
              <select name="spouse"
                class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-saffron-500 bg-white">
                <option value="">-- लागू नहीं (N/A) --</option>
                <% if (typeof allMembers !=='undefined' ) { %>
                  <% allMembers.forEach(m=> { %>
                    <option value="<%= m._id %>" <%=typeof member !=='undefined' && member.spouse &&
                      member.spouse.toString()===m._id.toString() ? 'selected' : '' %>>
                      <%= m.name %> (<%= m.village %>) <%= m.isDeceased ? '†' : '' %>
                    </option>
                    <% }) %>
                      <% } %>
              </select>
              
              <div class="mt-4 pt-4 border-t border-gray-100">
                <label class="block text-xs font-bold text-saffron-600 mb-1 uppercase">मैन्युअल नाम (Manual Spouse Name - Fallback)</label>
                <input type="text" name="spouseName" 
                  class="w-full px-4 py-2 rounded-lg border border-saffron-300 focus:ring-2 focus:ring-saffron-500 bg-saffron-50 text-gray-700 font-medium"
                  value="<%= typeof member !== 'undefined' ? (member.spouseName || '') : '' %>" 
                  placeholder="Enter spouse name manually...">
                <p class="text-[10px] text-gray-400 mt-1 italic">उपयोग करें यदि जीवनसाथी सदस्य नहीं है (Use if spouse is not a registered member)</p>
              </div>
            </div>
          </div>

          <!-- Contact Information Section -->
          <h3 class="text-xl font-bold text-gray-800 mb-4 border-b pb-2"><i
              class="fas fa-address-card mr-2 text-saffron-500"></i> संपर्क जानकारी (Contact Information)</h3>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
            <div>
              <label class="block text-sm font-bold text-gray-700 mb-2">संपर्क नंबर * (Contact Number)</label>
              <input type="text" name="contactNumber"
                class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-saffron-500"
                value="<%= typeof member !== 'undefined' ? member.contactNumber : '' %>" required>
            </div>

            <div>
              <label class="block text-sm font-bold text-gray-700 mb-2">ईमेल पता (Email Address)</label>
              <input type="email" name="email"
                class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-saffron-500"
                value="<%= typeof member !== 'undefined' ? member.email : '' %>">
            </div>

            <div class="md:col-span-2">
              <label class="block text-sm font-bold text-gray-700 mb-2">वर्तमान पता (Current Address)</label>
              <textarea name="address" rows="3"
                class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-saffron-500"><%= typeof member !== 'undefined' ? member.address : '' %></textarea>
            </div>
          </div>

          <div class="mb-8 p-4 bg-gray-50 rounded-lg border border-gray-200">
            <div class="flex flex-col gap-4">
              <div class="flex items-center">
                <input type="checkbox" name="isCommitteeMember" id="isCommitteeMember"
                  class="w-5 h-5 text-saffron-600 rounded focus:ring-saffron-500" <%=typeof member !=='undefined' &&
                  member.isCommitteeMember ? 'checked' : '' %>>
                <label for="isCommitteeMember" class="ml-3 text-sm font-bold text-gray-700">समिति के सदस्य (Committee
                  Member Role)</label>
              </div>
              <div class="flex items-center">
                <input type="checkbox" name="isFamilyTreeOnly" id="isFamilyTreeOnly"
                  class="w-5 h-5 text-saffron-600 rounded focus:ring-saffron-500" <%=typeof member !=='undefined' &&
                  member.isFamilyTreeOnly ? 'checked' : '' %>>
                <label for="isFamilyTreeOnly" class="ml-3 text-sm font-bold text-gray-700">केवल पारिवारिक वृक्ष के लिए
                  (Is Family Tree Only? - Hide from main directory)</label>
              </div>
              </div>
            </div>
          </div>

          <div class="flex flex-col sm:flex-row gap-4 mt-8">
            <button type="submit"
              class="flex-grow bg-saffron-600 hover:bg-saffron-700 text-white font-bold py-4 px-8 rounded-xl shadow-lg transition-transform transform active:scale-95">
              <i class="fas fa-save mr-2"></i> सदस्य सहेजें (Save Member)
            </button>
            <% if (typeof member !== 'undefined') { %>
              <button type="button" onclick="applyToEntireTree('<%= member._id %>')"
                class="bg-blue-600 hover:bg-blue-700 text-white font-bold py-4 px-8 rounded-xl shadow-lg transition-transform transform active:scale-95">
                <i class="fas fa-sitemap mr-2"></i> पूरे Tree को लागू करें (Apply to Entire Tree)
              </button>
            <% } %>
          </div>

        </form>
      </div>
    </div>
  </section>

  <script>
    // Searchable Dropdowns Helper
    document.querySelectorAll('select[list]').forEach(select => {
      // This was for datalist, now we have proper selects
    });

    function addSearchToSelect(selectId) {
      const select = document.getElementsByName(selectId)[0];
      if (!select) return;

      const wrap = document.createElement('div');
      wrap.className = 'relative flex flex-col gap-1';
      select.parentNode.insertBefore(wrap, select);

      const input = document.createElement('input');
      input.type = 'text';
      input.placeholder = `खोजें (Search ${selectId})...`;
      input.className = 'w-full px-4 py-2 text-xs border border-gray-200 rounded-md focus:ring-1 focus:ring-saffron-300 mb-1';

      wrap.appendChild(input);
      wrap.appendChild(select);

      const originalOptions = Array.from(select.options);

      input.addEventListener('input', (e) => {
        const term = e.target.value.toLowerCase().trim();
        select.innerHTML = '';
        originalOptions.forEach(opt => {
          if (opt.text.toLowerCase().includes(term) || opt.value === "") {
            select.add(opt);
          }
        });
        if (select.options.length > 0 && term) {
          // select.selectedIndex = 0;
        }
      });
    }

    ['father', 'mother', 'spouse'].forEach(addSearchToSelect);

    // Apply surname and gotra to entire family tree (all descendants)
    async function applyToEntireTree(memberId) {
      const surnameSelect = document.getElementById('surname_select');
      const gotraSelect = document.getElementById('gotra_select');
      const surnameOther = document.getElementById('surname_other');
      const gotraOther = document.getElementById('gotra_other');
      
      const surname = surnameSelect.value === 'Others' ? surnameOther.value : surnameSelect.value;
      const gotra = gotraSelect.value === 'Others' ? gotraOther.value : gotraSelect.value;
      
      if (!surname || !gotra) {
        alert('कृपया पहले surname और gotra भरें\n(Please fill surname and gotra first)');
        return;
      }

      if (!confirm(`⚠️ पूरे family tree को update करना है?\n\nSurname: ${surname}\nGotra: ${gotra}\n\nयह सभी generations के लिए लागू होगा (सभी बच्चों, पोतियों, परपोतियों के लिए)।\n\n(Apply to ALL generations - children, grandchildren, great-grandchildren, etc.?)`)) {
        return;
      }

      try {
        const btn = event.target;
        btn.disabled = true;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i>Processing entire tree...';

        const response = await fetch(`/admin/api/member/${memberId}/apply-to-tree`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({ surname, gotra })
        });

        const data = await response.json();
        
        if (data.ok) {
          alert(`✅ Success!\n\n${data.message}`);
        } else {
          alert(`❌ Error: ${data.error || 'Failed to apply'}`);
        }
      } catch (err) {
        console.error('Error:', err);
        alert('❌ अनुरोध विफल हुआ\n(Request failed: ' + err.message + ')');
      } finally {
        const btn = event.target;
        btn.disabled = false;
        btn.innerHTML = '<i class="fas fa-sitemap mr-2"></i> पूरे Tree को लागू करें (Apply to Entire Tree)';
      }
    }

    // Apply surname and gotra to all children of a member
    async function applyToChildren(memberId) {
      const surnameSelect = document.getElementById('surname_select');
      const gotraSelect = document.getElementById('gotra_select');
      const surnameOther = document.getElementById('surname_other');
      const gotraOther = document.getElementById('gotra_other');
      
      const surname = surnameSelect.value === 'Others' ? surnameOther.value : surnameSelect.value;
      const gotra = gotraSelect.value === 'Others' ? gotraOther.value : gotraSelect.value;
      
      if (!surname || !gotra) {
        alert('कृपया पहले surname और gotra भरें\n(Please fill surname and gotra first)');
        return;
      }

      if (!confirm(`क्या आप निम्नलिखित को सभी बच्चों पर लागू करना चाहते हैं?\n\nSurname: ${surname}\nGotra: ${gotra}\n\n(Apply to all children?)`)) {
        return;
      }

      try {
        const btn = event.target;
        btn.disabled = true;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i>Processing...';

        const response = await fetch(`/admin/api/member/${memberId}/apply-to-children`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({ surname, gotra })
        });

        const data = await response.json();
        
        if (data.ok) {
          alert(`✅ Success!\n\n${data.message}`);
        } else {
          alert(`❌ Error: ${data.error || 'Failed to apply'}`);
        }
      } catch (err) {
        console.error('Error:', err);
        alert('❌ अनुरोध विफल हुआ\n(Request failed: ' + err.message + ')');
      } finally {
        const btn = event.target;
        btn.disabled = false;
        btn.innerHTML = '<i class="fas fa-share-alt mr-2"></i> सभी बच्चों को लागू करें (Apply to Children)';
      }
    }
  </script>


  <%- include('partials/admin-footer') %>
  <script>
    // Auto-prefill from ?parentId= when opened from the Family Tree
    (function prefillFromTree() {
      const params = new URLSearchParams(window.location.search);
      const parentId = params.get('parentId');
      const parentName = params.get('parentName');

      if (!parentId) return;

      const fatherSelect = document.getElementById('father_select');
      if (!fatherSelect) return;

      const option = Array.from(fatherSelect.options).find(o => o.value === parentId);
      if (option) {
        fatherSelect.value = parentId;
        // Trigger the existing auto-fill logic to inherit surname/gotra
        if (typeof autoFillFromFather === 'function') {
          autoFillFromFather();
        }

        // Show a confirmation banner
        const banner = document.createElement('div');
        banner.className = 'mb-6 p-4 bg-green-50 border border-green-300 rounded-xl flex items-start gap-3';
        banner.innerHTML = `
          <i class="fas fa-tree text-green-600 text-xl"></i>
          <div>
            <p class="font-bold text-green-800">Family Tree se Add Ho Raha Hai</p>
            <p class="text-green-600 text-sm">Parent: <strong>${decodeURIComponent(parentName || option.text)}</strong></p>
          </div>
        `;
        const h = document.querySelector('h1');
        if (h && h.parentNode) h.parentNode.insertBefore(banner, h.nextSibling);
      }
    })();
  </script>
