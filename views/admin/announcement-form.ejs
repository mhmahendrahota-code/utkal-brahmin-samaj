<%- include('partials/admin-header') %>
<%
  const isEdit = locals.announcement ? true : false;
  const msg = isEdit ? announcement.message : '';
  const icn = isEdit ? announcement.icon : 'fas fa-bullhorn';
  let exp = '';
  if (isEdit && announcement.expiryDate) {
    const d = new Date(announcement.expiryDate);
    exp = d.toISOString().split('T')[0];
  }
  const act = isEdit ? announcement.isActive : true;
%>

<section class="py-12 bg-gray-50 flex-grow">
  <div class="container mx-auto px-4 max-w-4xl">
    
    <div class="flex items-center mb-6">
      <a href="/admin/announcements" class="text-gray-400 hover:text-saffron-500 mr-4"><i class="fas fa-arrow-left text-xl"></i></a>
      <h1 class="text-2xl font-bold text-gray-800"><%= isEdit ? 'Edit Announcement' : 'Post New Announcement' %></h1>
    </div>

    <div class="bg-white rounded-lg shadow-sm border border-gray-100 p-6 md:p-8">
      <form action="<%= isEdit ? '/admin/announcements/' + announcement._id + '/edit' : '/admin/announcements/add' %>" method="POST">
        
        <div class="space-y-6 mb-8">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Message Content *</label>
            <input type="text" name="message" required placeholder="e.g., Happy Nuakhai to all Utkal Brahmins!" maxlength="150" class="w-full px-4 py-2 border border-gray-300 rounded focus:ring-saffron-500 focus:border-saffron-500" value="<%= msg %>">
            <p class="text-xs text-gray-500 mt-1">Keep it short! This will scroll across the top header of every page.</p>
          </div>
          
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Display Icon</label>
              <select name="icon" class="w-full px-4 py-2 border border-gray-300 rounded focus:ring-saffron-500 focus:border-saffron-500 bg-white">
                <option value="fas fa-dharmachakra" <%= icn === 'fas fa-dharmachakra' ? 'selected' : '' %>>Dharma Wheel (Default)</option>
                <option value="fas fa-bullhorn" <%= icn === 'fas fa-bullhorn' ? 'selected' : '' %>>Megaphone (Urgent)</option>
                <option value="fas fa-calendar-alt" <%= icn === 'fas fa-calendar-alt' ? 'selected' : '' %>>Calendar (Event)</option>
                <option value="fas fa-om" <%= icn === 'fas fa-om' ? 'selected' : '' %>>Om (Spiritual)</option>
                <option value="fas fa-exclamation-circle" <%= icn === 'fas fa-exclamation-circle' ? 'selected' : '' %>>Alert (Warning)</option>
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Auto-Remove Date (Optional)</label>
              <input type="date" name="expiryDate" class="w-full px-4 py-2 border border-gray-300 rounded focus:ring-saffron-500 focus:border-saffron-500 text-gray-700" value="<%= exp %>">
            </div>
          </div>
          
          <div class="flex items-center bg-gray-50 p-4 rounded border border-gray-200">
            <input id="isActive" name="isActive" type="checkbox" <%= act ? 'checked' : '' %> class="h-5 w-5 text-saffron-600 focus:ring-saffron-500 border-gray-300 rounded">
            <label for="isActive" class="ml-3 block text-gray-800 font-medium">Publish Immediately</label>
          </div>
        </div>

        <div class="flex justify-end gap-4 border-t pt-6">
          <a href="/admin/announcements" class="px-6 py-2 border border-gray-300 rounded text-gray-700 font-medium hover:bg-gray-50 transition-colors">Cancel</a>
          <button type="submit" class="px-6 py-2 bg-saffron-600 hover:bg-saffron-700 text-white rounded font-medium shadow-sm transition-colors">
            <i class="fas <%= isEdit ? 'fa-save' : 'fa-paper-plane' %> mr-2"></i> <%= isEdit ? 'Save Changes' : 'Post Announcement' %>
          </button>
        </div>

      </form>
    </div>
  </div>
</section>

<%- include('partials/admin-footer') %>
