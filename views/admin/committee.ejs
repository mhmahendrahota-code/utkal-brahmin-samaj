<%- include('partials/admin-header') %>

<div class="flex-grow max-w-7xl mx-auto w-full px-4 py-8">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-3xl font-bold text-gray-800"><i class="fas fa-users-cog text-saffron-500 mr-2"></i> Manage Committee</h1>
    <a href="/admin/committee/add" class="bg-saffron-600 hover:bg-saffron-700 text-white px-4 py-2 rounded text-sm font-medium shadow-sm transition-colors inline-flex items-center">
      <i class="fas fa-plus mr-2"></i> Add Member
    </a>
  </div>

  <div class="bg-white rounded-lg shadow-sm border border-gray-100 overflow-hidden">
    <% if (committee && committee.length > 0) { %>
      <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
          <thead>
            <tr class="bg-gray-50 border-b border-gray-200">
              <th class="p-4 font-semibold text-gray-600">Photo</th>
              <th class="p-4 font-semibold text-gray-600">Name</th>
              <th class="p-4 font-semibold text-gray-600">Role / Title</th>
              <th class="p-4 font-semibold text-gray-600">Hierarchy priority</th>
              <th class="p-4 font-semibold text-gray-600 text-right">Actions</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            <% committee.forEach(c => { %>
              <tr class="hover:bg-gray-50/50 transition-colors">
                <td class="p-4">
                  <img src="<%= c.photoUrl || '/images/default-avatar.png' %>" alt="<%= c.name %>" class="w-12 h-12 rounded-full object-cover border-2 border-saffron-200 shadow-sm">
                </td>
                <td class="p-4 font-medium text-gray-900"><%= c.name %></td>
                <td class="p-4 text-gray-700"><span class="bg-saffron-100 text-saffron-800 px-2 py-1 rounded text-xs font-bold"><%= c.role %></span></td>
                <td class="p-4 text-gray-500"><%= c.priority %></td>
                <td class="p-4 text-right">
                  <form action="/admin/committee/<%= c._id %>/delete" method="POST" class="inline" onsubmit="return confirm('Remove this committee member?');">
                    <button type="submit" class="text-red-500 hover:text-red-700 hover:bg-red-50 p-2 rounded transition-colors" title="Delete">
                      <i class="fas fa-trash-alt"></i>
                    </button>
                  </form>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } else { %>
      <div class="text-center py-16">
        <div class="w-16 h-16 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-4 text-gray-400">
          <i class="fas fa-user-times text-2xl"></i>
        </div>
        <h3 class="text-lg font-medium text-gray-900 mb-1">No Committee Members Found</h3>
        <p class="text-gray-500 text-sm mb-6">Add the managing committee to display them publicly on the website.</p>
        <a href="/admin/committee/add" class="bg-saffron-600 hover:bg-saffron-700 text-white px-4 py-2 rounded text-sm font-medium shadow-md transition-colors inline-block">
          Add First Member
        </a>
      </div>
    <% } %>
  </div>
</div>

<%- include('partials/admin-footer') %>
