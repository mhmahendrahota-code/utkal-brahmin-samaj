<%- include('partials/admin-header') %>

<div class="flex-grow max-w-4xl mx-auto w-full px-4 py-8">
  <div class="flex items-center mb-6">
    <a href="/admin/committee" class="text-gray-400 hover:text-saffron-500 mr-3 transition-colors">
      <i class="fas fa-arrow-left text-xl"></i>
    </a>
    <h1 class="text-3xl font-bold text-gray-800">Assign Committee Member</h1>
  </div>

  <div class="bg-white rounded-lg shadow-sm border border-gray-100 overflow-hidden">
    <div class="p-8">
      <form action="/admin/committee/add" method="POST" class="space-y-6">
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Full Name *</label>
            <input type="text" name="name" required placeholder="e.g. Ramesh Hota" class="w-full border-gray-300 rounded focus:ring-saffron-500 focus:border-saffron-500 px-3 py-2 border shadow-sm">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Designation / Role *</label>
            <input type="text" name="role" required placeholder="e.g. President (Adhyaksh)" class="w-full border-gray-300 rounded focus:ring-saffron-500 focus:border-saffron-500 px-3 py-2 border shadow-sm">
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Phone Number</label>
            <input type="text" name="phone" placeholder="+91 98765 43210" class="w-full border-gray-300 rounded focus:ring-saffron-500 focus:border-saffron-500 px-3 py-2 border shadow-sm">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Hierarchy Priority</label>
            <p class="text-xs text-gray-500 mb-1">1 = Highest (Appears first). Default is 5.</p>
            <input type="number" name="priority" value="5" min="1" class="w-full border-gray-300 rounded focus:ring-saffron-500 focus:border-saffron-500 px-3 py-2 border shadow-sm">
          </div>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Photo URL</label>
          <p class="text-xs text-gray-500 mb-1">Link to the member's photo avatar.</p>
          <input type="text" name="photoUrl" placeholder="https://example.com/avatar.jpg" class="w-full border-gray-300 rounded focus:ring-saffron-500 focus:border-saffron-500 px-3 py-2 border shadow-sm">
        </div>

        <div class="flex justify-end pt-4 border-t">
          <a href="/admin/committee" class="bg-white border border-gray-300 text-gray-700 hover:bg-gray-50 font-bold py-2 px-6 rounded mr-3 shadow-sm transition-colors">
            Cancel
          </a>
          <button type="submit" class="bg-saffron-600 hover:bg-saffron-700 text-white font-bold py-2 px-6 rounded shadow-sm transition-colors flex items-center">
            <i class="fas fa-save mr-2"></i> Save Member
          </button>
        </div>

      </form>
    </div>
  </div>
</div>

<%- include('partials/admin-footer') %>
