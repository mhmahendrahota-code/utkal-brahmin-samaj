<%- include('partials/admin-header') %>

<section class="py-12 bg-gray-50 flex-grow">
  <div class="container mx-auto px-4 max-w-4xl">
    
    <div class="flex items-center mb-6">
      <a href="/admin/matrimonial" class="text-gray-400 hover:text-saffron-500 mr-4"><i class="fas fa-arrow-left text-xl"></i></a>
      <h1 class="text-2xl font-bold text-gray-800">Edit Matrimonial Profile</h1>
    </div>

    <div class="bg-white rounded-lg shadow-sm border border-gray-100 p-6 md:p-8">
      <form action="/admin/matrimonial/<%= profile._id %>/edit" method="POST">
        
        <h3 class="text-lg font-bold text-saffron-700 border-b pb-2 mb-6">Personal Details</h3>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Full Name *</label>
            <input type="text" name="name" value="<%= profile.name %>" required class="w-full px-4 py-2 border border-gray-300 rounded focus:ring-saffron-500 focus:border-saffron-500">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Gotra *</label>
            <input type="text" name="gotra" value="<%= profile.gotra %>" required class="w-full px-4 py-2 border border-gray-300 rounded focus:ring-saffron-500 focus:border-saffron-500">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Date of Birth</label>
            <input type="date" name="dateOfBirth" value="<%= profile.matrimonialProfile && profile.matrimonialProfile.dateOfBirth ? new Date(profile.matrimonialProfile.dateOfBirth).toISOString().split('T')[0] : '' %>" class="w-full px-4 py-2 border border-gray-300 rounded focus:ring-saffron-500 focus:border-saffron-500">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Height (e.g. 5' 6")</label>
            <input type="text" name="height" value="<%= profile.matrimonialProfile && profile.matrimonialProfile.height ? profile.matrimonialProfile.height : '' %>" class="w-full px-4 py-2 border border-gray-300 rounded focus:ring-saffron-500 focus:border-saffron-500">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Village (Mool) *</label>
            <input type="text" name="village" value="<%= profile.village %>" required class="w-full px-4 py-2 border border-gray-300 rounded focus:ring-saffron-500 focus:border-saffron-500">
          </div>
        </div>

        <h3 class="text-lg font-bold text-saffron-700 border-b pb-2 mb-6">Career & Statistics</h3>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Education Level</label>
            <select name="educationLevel" class="w-full px-4 py-2 border border-gray-300 rounded focus:ring-saffron-500 focus:border-saffron-500">
              <option value="">-- Select --</option>
              <% ['Below 10th', '10th Pass', '12th Pass', 'Graduate', 'Post Graduate', 'PhD', 'Doctor', 'Engineer', 'Other'].forEach(lvl => { %>
                <option value="<%= lvl %>" <%= profile.matrimonialProfile && profile.matrimonialProfile.educationLevel === lvl ? 'selected' : '' %>><%= lvl %></option>
              <% }) %>
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Education Details</label>
            <input type="text" name="education" value="<%= profile.matrimonialProfile && profile.matrimonialProfile.education ? profile.matrimonialProfile.education : '' %>" class="w-full px-4 py-2 border border-gray-300 rounded focus:ring-saffron-500 focus:border-saffron-500" placeholder="e.g. B.Tech, MA">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Occupation</label>
            <input type="text" name="occupation" value="<%= profile.occupation %>" class="w-full px-4 py-2 border border-gray-300 rounded focus:ring-saffron-500 focus:border-saffron-500">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Annual Income</label>
            <input type="text" name="annualIncome" value="<%= profile.matrimonialProfile && profile.matrimonialProfile.annualIncome ? profile.matrimonialProfile.annualIncome : '' %>" class="w-full px-4 py-2 border border-gray-300 rounded focus:ring-saffron-500 focus:border-saffron-500">
          </div>
        </div>

        <h3 class="text-lg font-bold text-saffron-700 border-b pb-2 mb-6">Family & Expectations</h3>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Father's Occupation</label>
            <input type="text" name="fatherOccupation" value="<%= profile.matrimonialProfile && profile.matrimonialProfile.fatherOccupation ? profile.matrimonialProfile.fatherOccupation : '' %>" class="w-full px-4 py-2 border border-gray-300 rounded focus:ring-saffron-500 focus:border-saffron-500">
          </div>
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Brothers</label>
              <input type="number" name="brothers" value="<%= profile.matrimonialProfile && profile.matrimonialProfile.brothers ? profile.matrimonialProfile.brothers : 0 %>" class="w-full px-4 py-2 border border-gray-300 rounded focus:ring-saffron-500 focus:border-saffron-500">
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Sisters</label>
              <input type="number" name="sisters" value="<%= profile.matrimonialProfile && profile.matrimonialProfile.sisters ? profile.matrimonialProfile.sisters : 0 %>" class="w-full px-4 py-2 border border-gray-300 rounded focus:ring-saffron-500 focus:border-saffron-500">
            </div>
          </div>
          <div class="md:col-span-2">
            <label class="block text-sm font-medium text-gray-700 mb-1">Partner Expectations</label>
            <textarea name="expectations" rows="2" class="w-full px-4 py-2 border border-gray-300 rounded focus:ring-saffron-500 focus:border-saffron-500"><%= profile.matrimonialProfile && profile.matrimonialProfile.expectations ? profile.matrimonialProfile.expectations : '' %></textarea>
          </div>
          <div class="md:col-span-2">
            <label class="block text-sm font-medium text-gray-700 mb-1">Bio / About</label>
            <textarea name="bio" rows="3" class="w-full px-4 py-2 border border-gray-300 rounded focus:ring-saffron-500 focus:border-saffron-500"><%= profile.matrimonialProfile && profile.matrimonialProfile.bio ? profile.matrimonialProfile.bio : '' %></textarea>
          </div>
        </div>

        <h3 class="text-lg font-bold text-saffron-700 border-b pb-2 mb-6">Contact Information</h3>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Contact Number *</label>
            <input type="tel" name="contactNumber" value="<%= profile.contactNumber %>" required class="w-full px-4 py-2 border border-gray-300 rounded focus:ring-saffron-500 focus:border-saffron-500">
          </div>
          <div class="md:col-span-2">
            <label class="block text-sm font-medium text-gray-700 mb-1">Current Address</label>
            <textarea name="address" rows="3" class="w-full px-4 py-2 border border-gray-300 rounded focus:ring-saffron-500 focus:border-saffron-500"><%= profile.address %></textarea>
          </div>
        </div>

        <div class="flex justify-end gap-4 border-t pt-6">
          <a href="/admin/matrimonial" class="px-6 py-2 border border-gray-300 rounded text-gray-700 font-medium hover:bg-gray-50 transition-colors">Cancel</a>
          <button type="submit" class="px-6 py-2 bg-saffron-600 hover:bg-saffron-700 text-white rounded font-medium shadow-sm transition-colors">
            <i class="fas fa-save mr-2"></i> Save Changes
          </button>
        </div>

      </form>
    </div>
  </div>
</section>

<%- include('partials/admin-footer') %>
