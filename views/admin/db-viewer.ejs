<%- include('partials/admin-header') %>

<style>
  pre.doc-json { font-size: 11px; max-height: 240px; overflow-y: auto; background: #0f172a; color: #e2e8f0; border-radius: 8px; padding: 12px; line-height: 1.6; white-space: pre-wrap; word-break: break-all; }
  textarea.json-editor { font-family: 'Fira Mono', 'Cascadia Code', monospace; font-size: 12px; line-height: 1.7; border-radius: 8px; }
  .doc-row.selected { background: #eff6ff; border-left: 3px solid #3b82f6; }
  .doc-row.dirty { background: #fffcf0; }
  .inline-input { 
    width: 100%; height: 100%; background: transparent; border: 1px solid transparent; 
    padding: 4px 8px; border-radius: 4px; transition: all 0.2s; font-size: 12px; outline: none;
  }
  .inline-input:hover { border-color: #e2e8f0; background: rgba(255,255,255,0.5); }
  .inline-input:focus { background: white; border-color: #3b82f6; box-shadow: 0 0 0 1px #3b82f6; }
  .inline-input.changed { border-color: #f59e0b; background: #fffbeb; }
  .bulk-bar { transition: transform .25s, opacity .25s; }
  .bulk-bar.hidden { transform: translateY(120px); opacity: 0; pointer-events: none; }
</style>

<section class="py-10 bg-gray-50 flex-grow">
  <div class="w-full mx-auto px-2 sm:px-6">
    
    <div class="flex justify-between items-center mb-6">
      <div>
        <h1 class="text-2xl font-bold text-gray-800">
          <a href="/admin" class="text-gray-400 hover:text-saffron-500 mr-2"><i class="fas fa-arrow-left text-lg"></i></a>
          Database Explorer
        </h1>
        <p class="text-sm text-gray-500 mt-1">Browse, edit, bulk-edit/delete documents across all collections</p>
      </div>
      <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-green-100 text-green-700 text-xs font-semibold">
        <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse inline-block"></span> Connected
      </span>
    </div>

    <!-- Toast -->
    <div id="toast" class="fixed top-5 right-5 z-[100] hidden">
      <div class="px-5 py-3 rounded-xl shadow-lg text-white text-sm font-medium flex items-center gap-3" id="toast-inner">
        <div class="flex items-center gap-2"><i class="fas fa-check-circle"></i> <span id="toast-msg"></span></div>
        <button id="toast-undo-btn" class="hidden px-2 py-1 bg-white/20 hover:bg-white/30 rounded text-xs transition-colors"><i class="fas fa-undo mr-1"></i>Undo</button>
      </div>
    </div>

    <!-- Collection Tabs -->
    <div class="flex flex-wrap gap-2 mb-4">
      <% collections.forEach((col, idx) => { %>
        <button class="tab-btn px-4 py-2 rounded-lg text-sm font-medium transition-all border
                       <%= idx === 0 ? 'bg-saffron-600 text-white border-saffron-600 shadow' : 'bg-white text-gray-600 border-gray-200 hover:border-saffron-400 hover:text-saffron-600' %>"
                data-target="col-<%= col.name %>" onclick="switchTab(this, 'col-<%= col.name %>')">
          <i class="fas fa-table mr-1.5 opacity-60"></i> <%= col.label %>
          <span class="ml-1.5 px-1.5 py-0.5 rounded-full text-xs <%= idx === 0 ? 'bg-white/30 text-white' : 'bg-gray-100 text-gray-500' %>"><%= col.count %></span>
        </button>
      <% }) %>
    </div>

    <!-- Collection Panels -->
    <% collections.forEach((col, idx) => { %>
    <div id="col-<%= col.name %>" class="collection-panel <%= idx !== 0 ? 'hidden' : '' %>">
      <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
        <!-- Panel header with Select All & View Toggle -->
        <div class="flex flex-wrap justify-between items-center px-5 py-3 bg-gray-50 border-b border-gray-200 gap-4">
          <div class="flex items-center gap-4">
            <label class="flex items-center gap-2 cursor-pointer select-none">
              <input type="checkbox" class="select-all-cb w-4 h-4 rounded accent-saffron-600" data-col="<%= col.name %>" onchange="toggleSelectAll(this)">
              <span class="text-xs text-gray-500 font-medium">Select All</span>
            </label>
            <div class="h-4 w-px bg-gray-300"></div>
            <!-- View Mode Toggle -->
            <div class="flex bg-gray-200/50 p-1 rounded-lg">
              <button onclick="setViewMode('<%= col.name %>', 'list')" id="btn-list-<%= col.name %>"
                      class="px-2.5 py-1 rounded-md text-[10px] font-bold uppercase tracking-wider transition-all bg-white shadow-sm text-gray-800">
                <i class="fas fa-list mr-1"></i> List
              </button>
              <button onclick="setViewMode('<%= col.name %>', 'table')" id="btn-table-<%= col.name %>"
                      class="px-2.5 py-1 rounded-md text-[10px] font-bold uppercase tracking-wider transition-all text-gray-500 hover:text-gray-700">
                <i class="fas fa-table mr-1"></i> Table
              </button>
            </div>
            <span class="text-xs text-gray-400 font-mono hidden md:inline"><%= col.name %> · <%= col.count %> docs</span>
          </div>
          <div class="flex items-center gap-2">
            <% if (col.name === 'members') { %>
              <button onclick="filterType('matrimonial')" class="px-3 py-1.5 rounded-lg bg-red-50 text-red-600 hover:bg-red-100 text-[10px] font-bold uppercase tracking-wider transition-all flex items-center gap-1.5" title="Show only pending matrimonial requests">
                <i class="fas fa-heart"></i> Review Pending
              </button>
            <% } %>
            <a href="/admin/db/backup" class="px-3 py-1.5 rounded-lg bg-indigo-600 text-white hover:bg-indigo-700 text-[10px] font-bold uppercase tracking-wider transition-all flex items-center gap-1.5 shadow-sm" title="Download Full DB Backup (JSON)">
              <i class="fas fa-database"></i> Full Backup
            </a>
            <div class="h-6 w-px bg-gray-200 mx-1"></div>
            <button onclick="exportData('<%= col.name %>', 'csv')" class="px-2 py-1.5 rounded-lg bg-green-50 text-green-600 hover:bg-green-100 text-[10px] font-bold uppercase tracking-wider transition-all" title="Export Filtered CSV">
              <i class="fas fa-file-csv"></i> CSV
            </button>
            <button onclick="exportData('<%= col.name %>', 'json')" class="px-2 py-1.5 rounded-lg bg-amber-50 text-amber-600 hover:bg-amber-100 text-[10px] font-bold uppercase tracking-wider transition-all" title="Export Filtered JSON">
              <i class="fas fa-file-code"></i> JSON
            </button>
            <input type="text" placeholder="Search in collection..." 
                   class="w-48 md:w-64 px-3 py-1.5 border border-gray-200 rounded-lg text-xs focus:ring-1 focus:ring-saffron-400 focus:outline-none"
                   oninput="filterDocs(this, '<%= col.name %>')">
          </div>
        </div>

        <!-- List View -->
        <div class="divide-y divide-gray-100" id="list-view-<%= col.name %>">
          <% if (col.docs.length === 0) { %>
            <div class="px-6 py-8 text-center text-gray-400 text-sm">No documents in this collection.</div>
          <% } else { %>
            <% col.docs.forEach(doc => { %>
              <div class="doc-row px-5 py-3 group flex items-start gap-3"
                   id="row-<%= doc._id %>"
                   data-json='<%= JSON.stringify(doc).replace(/'/g, "&#39;") %>'
                   data-collection="<%= col.name %>">
                <!-- Checkbox -->
                <input type="checkbox" class="row-cb w-4 h-4 rounded accent-blue-600 mt-1 flex-shrink-0"
                       data-id="<%= doc._id %>" data-col="<%= col.name %>"
                       onchange="updateBulkBar()">
                <!-- Content -->
                <div class="flex-1 min-w-0">
                  <div class="flex justify-between items-start">
                    <div class="flex-1 cursor-pointer" onclick="toggleDoc(this.closest('.doc-row'))">
                      <div class="flex flex-wrap gap-2 items-center">
                        <% if (doc.name) { %><span class="font-semibold text-gray-800 text-sm"><%= doc.name %></span><% } %>
                        <% if (doc.title && !doc.name) { %><span class="font-semibold text-gray-800 text-sm"><%= doc.title %></span><% } %>
                        <% if (!doc.name && !doc.title) { %><span class="font-mono text-xs text-gray-400"><%= doc._id %></span><% } %>
                        <% if (doc.email) { %><span class="text-xs text-gray-500"><%= doc.email %></span><% } %>
                        <% if (doc.gotra) { %><span class="text-xs bg-saffron-50 text-saffron-600 px-2 py-0.5 rounded"><%= doc.gotra %></span><% } %>
                        <% if (doc.amount) { %><span class="text-xs bg-green-50 text-green-600 px-2 py-0.5 rounded">₹<%= doc.amount %></span><% } %>
                        <% if (doc.village) { %><span class="text-xs text-gray-400"><%= doc.village %></span><% } %>
                      </div>
                      <div class="text-xs text-gray-400 mt-0.5 font-mono"><%= doc._id %></div>
                    </div>
                    <!-- Row actions (shown on hover) -->
                    <div class="flex gap-1.5 ml-3 flex-shrink-0 opacity-0 group-hover:opacity-100 transition-opacity">
                      <button onclick="openEdit(this.closest('.doc-row'))"
                              class="text-xs px-2.5 py-1 rounded-lg bg-blue-50 text-blue-600 hover:bg-blue-100 font-medium">
                        <i class="fas fa-edit mr-1"></i>Edit
                      </button>
                      <button onclick="openDelete(this.closest('.doc-row'))"
                              class="text-xs px-2.5 py-1 rounded-lg bg-red-50 text-red-500 hover:bg-red-100 font-medium">
                        <i class="fas fa-trash mr-1"></i>Del
                      </button>
                    </div>
                  </div>
                  <pre class="doc-json mt-3 hidden"><%= JSON.stringify(doc, null, 2) %></pre>
                </div>
              </div>
            <% }) %>
          <% } %>
        </div>

        <!-- Table View -->
        <div id="table-view-<%= col.name %>" class="hidden overflow-x-auto">
          <table class="w-full text-left border-collapse min-w-[800px]">
            <thead class="bg-gray-50 text-[10px] uppercase tracking-wider text-gray-500 font-bold border-b border-gray-200" id="thead-<%= col.name %>">
              <!-- Dynamic headers -->
            </thead>
            <tbody id="tbody-<%= col.name %>" class="divide-y divide-gray-100 text-xs">
              <!-- Dynamic rows -->
            </tbody>
          </table>
        </div>
      </div>
    </div>
    <% }) %>

  </div>
</section>

<!-- ── Floating Bulk Action Bar ── -->
<div id="bulk-bar" class="bulk-bar hidden fixed bottom-6 left-1/2 -translate-x-1/2 z-50 bg-gray-900 text-white rounded-2xl shadow-2xl px-4 py-3 flex flex-wrap justify-center items-center gap-2 sm:gap-4 w-[calc(100vw-2rem)] md:w-max">
  <span class="text-sm font-semibold whitespace-nowrap"><span id="bulk-count">0</span> selected</span>
  <div class="hidden sm:block flex-1"></div>
  <button onclick="openBulkEdit()" class="px-4 py-1.5 rounded-lg bg-blue-500 hover:bg-blue-400 text-sm font-medium transition-colors">
    <i class="fas fa-pen mr-1"></i> Bulk Edit Field
  </button>
  <button onclick="openBulkDelete()" class="px-4 py-1.5 rounded-lg bg-red-500 hover:bg-red-400 text-sm font-medium transition-colors">
    <i class="fas fa-trash mr-1"></i> Bulk Delete
  </button>
  <button onclick="clearSelection()" class="text-gray-400 hover:text-white text-lg ml-1"><i class="fas fa-times"></i></button>
</div>

<!-- ── Edit Single Doc Modal ── -->
<div id="edit-modal" class="fixed inset-0 bg-black/60 backdrop-blur-sm z-50 flex items-center justify-center hidden">
  <div class="bg-white rounded-2xl shadow-2xl w-full max-w-2xl mx-4 flex flex-col max-h-[90vh]">
    <div class="bg-blue-50 border-b border-blue-100 px-6 py-4 flex items-center justify-between">
      <div>
        <h3 class="font-bold text-gray-900 text-lg"><i class="fas fa-edit text-blue-500 mr-2"></i>Edit Document</h3>
        <p class="text-xs text-gray-500 mt-0.5" id="edit-modal-id"></p>
      </div>
      <!-- Mode Switcher -->
      <div class="flex bg-gray-100 p-1 rounded-lg">
        <button id="btn-json-mode" onclick="setEditMode('json')" 
                class="px-3 py-1.5 rounded-md text-xs font-medium transition-all bg-white shadow-sm text-gray-800">JSON Mode</button>
        <button id="btn-form-mode" onclick="setEditMode('form')" 
                class="px-3 py-1.5 rounded-md text-xs font-medium transition-all text-gray-500 hover:text-gray-700">Simplified View</button>
      </div>
      <button onclick="closeModal('edit-modal')" class="text-gray-400 hover:text-gray-600 text-xl"><i class="fas fa-times"></i></button>
    </div>
    <div class="px-6 py-4 flex-1 overflow-y-auto">
      <p class="text-xs text-amber-600 bg-amber-50 border border-amber-200 rounded-lg px-3 py-2 mb-3">
        <i class="fas fa-info-circle mr-1"></i> <code>_id</code>, <code>__v</code>, <code>password</code> are protected and will be ignored.
      </p>
      <!-- JSON Editor -->
      <div id="json-editor-container">
        <textarea id="edit-json" class="json-editor w-full h-80 border border-gray-300 p-3 focus:ring-2 focus:ring-blue-400 focus:outline-none text-gray-800 bg-gray-50 resize-y"></textarea>
      </div>
      <!-- Form Editor -->
      <div id="form-editor-container" class="hidden space-y-4 py-2">
        <!-- Dynamic fields go here -->
      </div>
      <p id="edit-json-error" class="text-xs text-red-500 mt-1 hidden"><i class="fas fa-exclamation-circle mr-1"></i><span></span></p>
    </div>
    <div class="px-6 pb-5 flex gap-3 justify-between items-center border-t border-gray-100 pt-4">
      <button onclick="formatJson()" class="text-xs px-4 py-2 rounded-lg border border-gray-200 text-gray-600 hover:bg-gray-50"><i class="fas fa-magic mr-1"></i>Format</button>
      <div class="flex gap-3">
        <button onclick="closeModal('edit-modal')" class="px-5 py-2 rounded-lg border border-gray-300 text-gray-700 hover:bg-gray-50 font-medium">Cancel</button>
        <button onclick="saveEdit()" class="px-5 py-2 rounded-lg bg-blue-600 hover:bg-blue-700 text-white font-medium"><i class="fas fa-save mr-1"></i>Save</button>
      </div>
    </div>
  </div>
</div>

<!-- ── Bulk Edit Modal ── -->
<div id="bulk-edit-modal" class="fixed inset-0 bg-black/60 backdrop-blur-sm z-50 flex items-center justify-center hidden">
  <div class="bg-white rounded-2xl shadow-2xl w-full max-w-lg mx-4 overflow-hidden">
    <div class="bg-blue-50 border-b border-blue-100 px-6 py-4">
      <h3 class="font-bold text-gray-900 text-lg"><i class="fas fa-layer-group text-blue-500 mr-2"></i>Bulk Edit Field</h3>
      <p class="text-sm text-gray-500 mt-0.5">Set one field to a value on <strong id="bulk-edit-count"></strong> selected documents.</p>
    </div>
    <div class="px-6 py-5 space-y-4">
      <p class="text-xs text-amber-600 bg-amber-50 border border-amber-200 rounded-lg px-3 py-2">
        <i class="fas fa-exclamation-triangle mr-1"></i> This will <strong>overwrite</strong> the field values on all selected documents. Use with care.
      </p>
      
      <div id="bulk-fields-container" class="space-y-3">
        <!-- Field rows will be added here -->
        <div class="bulk-field-row flex gap-2 items-end">
          <div class="flex-1">
            <label class="block text-[10px] font-bold text-gray-400 uppercase mb-1">Field Name</label>
            <input type="text" placeholder="e.g. isApproved" class="bulk-field-name w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-400 focus:outline-none">
          </div>
          <div class="flex-1">
            <label class="block text-[10px] font-bold text-gray-400 uppercase mb-1">New Value (JSON)</label>
            <input type="text" placeholder='e.g. true' class="bulk-field-value w-full border border-gray-300 rounded-lg px-3 py-2 text-sm font-mono focus:ring-2 focus:ring-blue-400 focus:outline-none">
          </div>
          <button onclick="this.closest('.bulk-field-row').remove()" class="p-2.5 text-red-400 hover:text-red-600 transition-colors"><i class="fas fa-times"></i></button>
        </div>
      </div>

      <button onclick="addBulkFieldRow()" class="text-xs text-blue-600 hover:text-blue-800 font-bold flex items-center gap-1.5">
        <i class="fas fa-plus-circle"></i> ADD ANOTHER FIELD
      </button>

      <p id="bulk-edit-error" class="text-xs text-red-500 hidden"><i class="fas fa-exclamation-circle mr-1"></i><span></span></p>
    </div>
    <div class="px-6 pb-5 flex gap-3 justify-end border-t border-gray-100 pt-4">
      <button onclick="closeModal('bulk-edit-modal')" class="px-5 py-2 rounded-lg border border-gray-300 text-gray-700 hover:bg-gray-50 font-medium">Cancel</button>
      <button onclick="saveBulkEdit()" class="px-5 py-2 rounded-lg bg-blue-600 hover:bg-blue-700 text-white font-medium"><i class="fas fa-bolt mr-1"></i>Apply to All Selected</button>
    </div>
  </div>
</div>

<!-- ── Single Delete Confirm ── -->
<div id="del-modal" class="fixed inset-0 bg-black/60 backdrop-blur-sm z-50 flex items-center justify-center hidden">
  <div class="bg-white rounded-2xl shadow-2xl w-full max-w-md mx-4 overflow-hidden">
    <div class="bg-red-50 border-b border-red-100 px-6 py-4">
      <h3 class="font-bold text-gray-900 text-lg"><i class="fas fa-exclamation-triangle text-red-500 mr-2"></i>Delete Document?</h3>
      <p class="text-sm text-gray-500 mt-1" id="del-modal-desc"></p>
    </div>
    <div class="px-6 py-4 pb-5 flex gap-3 justify-end">
      <button onclick="closeModal('del-modal')" class="px-5 py-2 rounded-lg border border-gray-300 text-gray-700 hover:bg-gray-50 font-medium">Cancel</button>
      <button onclick="confirmDelete()" class="px-5 py-2 rounded-lg bg-red-600 hover:bg-red-700 text-white font-medium"><i class="fas fa-trash mr-1"></i>Delete</button>
    </div>
  </div>
</div>

<!-- ── Bulk Delete Confirm ── -->
<div id="bulk-del-modal" class="fixed inset-0 bg-black/60 backdrop-blur-sm z-50 flex items-center justify-center hidden">
  <div class="bg-white rounded-2xl shadow-2xl w-full max-w-md mx-4 overflow-hidden">
    <div class="bg-red-50 border-b border-red-100 px-6 py-4">
      <h3 class="font-bold text-gray-900 text-lg"><i class="fas fa-trash text-red-500 mr-2"></i>Bulk Delete?</h3>
      <p class="text-sm text-gray-500 mt-1" id="bulk-del-desc"></p>
    </div>
    <div class="px-6 py-4 pb-5 flex gap-3 justify-end">
      <button onclick="closeModal('bulk-del-modal')" class="px-5 py-2 rounded-lg border border-gray-300 text-gray-700 hover:bg-gray-50 font-medium">Cancel</button>
      <button onclick="confirmBulkDelete()" class="px-5 py-2 rounded-lg bg-red-600 hover:bg-red-700 text-white font-medium"><i class="fas fa-trash mr-1"></i>Delete All Selected</button>
    </div>
  </div>
</div>

<script>
  /* ── State ── */
  let _editId = null, _editCol = null;
  let _delId  = null, _delCol  = null, _delRow = null;

  /* ── Helpers ── */
  function closeModal(id) { document.getElementById(id).classList.add('hidden'); }
  let _toastTimer = null;
  function showToast(msg, color, undoCallback = null) {
    const inner = document.getElementById('toast-inner');
    document.getElementById('toast-msg').textContent = msg;
    inner.className = `px-5 py-3 rounded-xl shadow-lg text-white text-sm font-medium flex items-center justify-between gap-3 bg-${color}-600`;
    
    const undoBtn = document.getElementById('toast-undo-btn');
    if (undoCallback) {
      undoBtn.classList.remove('hidden');
      undoBtn.onclick = () => {
        undoCallback();
        document.getElementById('toast').classList.add('hidden');
      };
    } else {
      undoBtn.classList.add('hidden');
    }

    const toast = document.getElementById('toast');
    toast.classList.remove('hidden');
    if (_toastTimer) clearTimeout(_toastTimer);
    _toastTimer = setTimeout(() => toast.classList.add('hidden'), undoCallback ? 8000 : 3000);
  }

  function filterType(type) {
    const input = document.querySelector('input[oninput*="filterDocs"]');
    if (type === 'matrimonial') {
      // Filter for records with matrimonialProfile.isMatrimonialRequest = true AND isApproved = false
      const rows = document.querySelectorAll('.doc-row');
      rows.forEach(row => {
        try {
          const data = JSON.parse(row.dataset.json);
          const isRequest = data.matrimonialProfile?.isMatrimonialRequest === true;
          const isPending = data.matrimonialProfile?.isApproved === false;
          row.style.display = (isRequest && isPending) ? '' : 'none';
        } catch(e) {}
      });
      showToast('Filtering: Pending Matrimonial Requests', 'blue');
    }
  }

  /* ── Tab Switching ── */
  function switchTab(btn, target) {
    document.querySelectorAll('.tab-btn').forEach(b => {
      b.className = b.className.replace('bg-saffron-600 text-white border-saffron-600 shadow', 'bg-white text-gray-600 border-gray-200 hover:border-saffron-400 hover:text-saffron-600');
      const badge = b.querySelector('span:last-child');
      if (badge) { badge.classList.remove('bg-white/30', 'text-white'); badge.classList.add('bg-gray-100', 'text-gray-500'); }
    });
    btn.className = btn.className.replace('bg-white text-gray-600 border-gray-200 hover:border-saffron-400 hover:text-saffron-600', 'bg-saffron-600 text-white border-saffron-600 shadow');
    const badge = btn.querySelector('span:last-child');
    if (badge) { badge.classList.add('bg-white/30', 'text-white'); badge.classList.remove('bg-gray-100', 'text-gray-500'); }

    document.querySelectorAll('.collection-panel').forEach(p => p.classList.add('hidden'));
    document.getElementById(target).classList.remove('hidden');
    
    // Check view mode for this collection
    const colName = target.replace('col-', '');
    const currentMode = localStorage.getItem('db_view_mode_' + colName) || 'list';
    setViewMode(colName, currentMode, true); // true = don't toggle, just set
    clearSelection();
  }

  /* ── View Mode Switching (List vs Table) ── */
  function setViewMode(colName, mode, force = false) {
    const listContainer = document.getElementById('list-view-' + colName);
    const tableContainer = document.getElementById('table-view-' + colName);
    const btnList = document.getElementById('btn-list-' + colName);
    const btnTable = document.getElementById('btn-table-' + colName);
    
    if (!listContainer || !tableContainer) return;

    if (mode === 'table') {
      renderTable(colName);
      listContainer.classList.add('hidden');
      tableContainer.classList.remove('hidden');
      btnTable.classList.add('bg-white', 'shadow-sm', 'text-gray-800');
      btnTable.classList.remove('text-gray-500');
      btnList.classList.remove('bg-white', 'shadow-sm', 'text-gray-800');
      btnList.classList.add('text-gray-500');
    } else {
      listContainer.classList.remove('hidden');
      tableContainer.classList.add('hidden');
      btnList.classList.add('bg-white', 'shadow-sm', 'text-gray-800');
      btnList.classList.remove('text-gray-500');
      btnTable.classList.remove('bg-white', 'shadow-sm', 'text-gray-800');
      btnTable.classList.add('text-gray-500');
    }
    
    localStorage.setItem('db_view_mode_' + colName, mode);
  }

  function setNestedValue(obj, path, value) {
    const parts = path.split('.');
    let current = obj;
    for (let i = 0; i < parts.length - 1; i++) {
      if (current[parts[i]] === undefined || current[parts[i]] === null) current[parts[i]] = {};
      current = current[parts[i]];
    }
    current[parts[parts.length - 1]] = value;
  }

  function flattenObj(obj, prefix = '', res = {}) {
    for (let key in obj) {
      if (Object.prototype.hasOwnProperty.call(obj, key)) {
        const propName = prefix ? prefix + '.' + key : key;
        if (typeof obj[key] === 'object' && obj[key] !== null && !Array.isArray(obj[key]) && Object.keys(obj[key]).length > 0) {
          flattenObj(obj[key], propName, res);
        } else {
          res[propName] = obj[key];
        }
      }
    }
    return res;
  }

  function renderTable(colName) {
    const tbody = document.getElementById('tbody-' + colName);
    const thead = document.getElementById('thead-' + colName);
    const listRows = document.querySelectorAll('#list-view-' + colName + ' .doc-row');
    
    if (listRows.length === 0) return;
    
    // Get headers from all rows to be comprehensive, but limit to useful fields
    const allKeys = new Set(['_id']);
    const skipFields = ['__v', 'password', 'passwordHash', 'id'];

    // Prioritize keys requested by user for members collection
    const priorityKeys = colName === 'members' ? [
      '_id', 'name', 'surname', 'gotra', 'gender', 'honorific', 
      'isDeceased', 'isFamilyTreeOnly', 'isApproved', 'isCommitteeMember', 
      'children', 'profileImage', 
      'matrimonialProfile.isEligible', 'matrimonialProfile.isApproved', 
      'createdAt', 'updatedAt'
    ] : [];
    
    listRows.forEach(row => {
      try {
        const data = flattenObj(JSON.parse(row.dataset.json));
        Object.keys(data).forEach(k => {
          if (!skipFields.includes(k)) allKeys.add(k);
        });
      } catch (e) {
        console.warn("Invalid JSON in row", row.id, e);
      }
    });

    // Merge priority keys with all other detected keys
    const sortedKeys = [...new Set([...priorityKeys, ...Array.from(allKeys)])];
    const headers = sortedKeys.slice(0, 20); // Limit to 20 cols
    
    // Render Header
    thead.innerHTML = '';
    
    // Row 1: Titles
    const htr = document.createElement('tr');
    htr.innerHTML = `
      <th class="px-5 py-4 w-10"></th>
      <th class="px-4 py-4 w-10 text-center"><i class="fas fa-edit text-gray-400"></i></th>
    `;
    headers.forEach(h => {
      const th = document.createElement('th');
      th.className = 'px-5 py-4 whitespace-nowrap cursor-default text-xs';
      if (h === '_id') th.className += ' text-gray-400';
      th.textContent = h;
      htr.appendChild(th);
    });
    htr.innerHTML += `<th class="px-5 py-4 text-right whitespace-nowrap">Actions</th>`;
    thead.appendChild(htr);

    const btr = document.createElement('tr');
    btr.className = "bg-blue-50/50 border-b border-blue-100";
    btr.innerHTML = `
      <td class="px-5 py-3 text-center" title="Bulk Update Column Controls">
        <i class="fas fa-bolt text-blue-500 text-xs"></i>
      </td>
      <td></td>
    `;
    headers.forEach(h => {
      const isId = h === '_id';
      const cell = document.createElement('td');
      cell.className = "px-3 py-2";
      if (isId) {
        cell.innerHTML = `<span class="text-[10px] text-gray-400 italic px-2 whitespace-nowrap">READ ONLY</span>`;
      } else {
        cell.innerHTML = `
          <div class="flex items-center gap-1.5 w-40 min-w-full">
            <input type="text" id="bulk-input-${colName}-${h}" placeholder="Bulk value..." 
                   class="w-full text-xs px-2.5 py-1.5 rounded border border-blue-200 focus:border-blue-500 focus:ring-1 focus:ring-blue-500 outline-none">
            <button onclick="applyColumnBulk('${h}', '${colName}')" 
                    class="p-1.5 hover:bg-blue-200 text-blue-700 bg-blue-100 rounded transition-colors flex-shrink-0" title="Apply to all selected rows">
              <i class="fas fa-check-double text-[11px]"></i>
            </button>
          </div>
        `;
      }
      btr.appendChild(cell);
    });
    btr.innerHTML += `<td></td>`;
    thead.appendChild(btr);
    
    // Render Body
    tbody.innerHTML = '';
    listRows.forEach(lRow => {
      const originalData = JSON.parse(lRow.dataset.json);
      const flatData = flattenObj(originalData);
      const isSelected = lRow.querySelector('.row-cb').checked;
      
      const tr = document.createElement('tr');
      tr.className = 'hover:bg-blue-50/30 doc-row transition-colors group' + (isSelected ? ' selected bg-blue-50/50' : '');
      tr.id = 'table-row-' + originalData._id;
      tr.dataset.id = originalData._id;
      tr.dataset.json = lRow.dataset.json;
