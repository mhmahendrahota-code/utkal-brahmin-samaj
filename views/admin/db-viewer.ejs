      // Checkbox cell
      let html = `<td class="px-5 py-4" onclick="event.stopPropagation()">
        <input type="checkbox" class="row-cb w-4 h-4 rounded accent-blue-600" 
               ${isSelected ? 'checked' : ''} data-id="${originalData._id}" data-col="${colName}"
               onchange="syncRowSelect(this)">
      </td>`;

      // Inline Save status cell
      html += `<td class="px-2 py-4 text-center whitespace-nowrap">
        <button id="save-btn-${originalData._id}" onclick="saveInlineRow('${originalData._id}', '${colName}')" 
                class="save-row-btn hidden p-2 px-3 bg-green-500 hover:bg-green-600 text-white rounded shadow-sm transition-all text-xs font-bold" title="Save changes">
          <i class="fas fa-save mr-1"></i> Save
        </button>
        <i id="edit-icon-${originalData._id}" class="fas fa-pen-to-square text-blue-400 opacity-20 group-hover:opacity-100 transition-opacity"></i>
      </td>`;
      
      // Data cells
      headers.forEach(h => {
        const isId = h === '_id';
        let val = flatData[h] === undefined ? '' : flatData[h];
        if (typeof val === 'object' && val !== null) val = JSON.stringify(val);
        
        const type = typeof flatData[h];
        const isBoolean = type === 'boolean' || h.startsWith('is') || h.includes('.is');
        const isHonorific = h === 'honorific';
        const isGender = h === 'gender';
        
        html += `<td class="px-4 py-3 min-w-[200px]">`;
        if (isId) {
          html += `<input type="text" value="${val}" data-field="_id" disabled class="inline-input w-full text-gray-400 cursor-not-allowed italic font-mono px-3 py-1.5 bg-gray-50 rounded border border-transparent">`;
        } else if (isBoolean) {
          html += `<select class="inline-input w-full px-3 py-1.5 rounded border border-transparent hover:border-gray-300 focus:border-blue-500 cursor-pointer font-bold ${val === true ? 'text-green-600' : 'text-red-500'}" 
                           data-field="${h}" data-original="${val}" data-type="boolean" 
                           onchange="onCellInput(this, '${originalData._id}'); this.className= 'inline-input w-full px-3 py-1.5 rounded border border-transparent hover:border-gray-300 focus:border-blue-500 cursor-pointer font-bold ' + (this.value === 'true' ? 'text-green-600' : 'text-red-500');">
