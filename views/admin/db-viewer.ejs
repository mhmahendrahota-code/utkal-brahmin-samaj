        } else if (isHonorific) {
          const titles = ['Shri', 'Smt.', 'Ms.', 'Late', 'Dr.', 'Er.', 'Prof.'];
          const labels = { 'Shri': 'श्री (Shri)', 'Smt.': 'श्रीमती (Smt.)', 'Ms.': 'कुमारी (Ms.)', 'Late': 'स्वर्गीय (Late)', 'Dr.': 'डॉ. (Dr.)', 'Er.': 'अभि. (Er.)', 'Prof.': 'प्रो. (Prof.)' };
          html += `<select class="inline-input w-full px-3 py-1.5 rounded border border-transparent hover:border-gray-300 focus:border-blue-500 cursor-pointer" 
                           data-field="${h}" data-original="${val}" data-type="string" 
                           onchange="onCellInput(this, '${originalData._id}')">
                      <option value="">-- None --</option>
                      ${titles.map(t => `<option value="${t}" ${val === t ? 'selected' : ''}>${labels[t] || t}</option>`).join('')}
                   </select>`;
        } else if (isGender) {
          html += `<select class="inline-input w-full px-3 py-1.5 rounded border border-transparent hover:border-gray-300 focus:border-blue-500 cursor-pointer" 
                           data-field="${h}" data-original="${val}" data-type="string" 
                           onchange="onCellInput(this, '${originalData._id}')">
                      <option value="Male" ${val === 'Male' ? 'selected' : ''}>♂ Male (पुरुष)</option>
                      <option value="Female" ${val === 'Female' ? 'selected' : ''}>♀ Female (महिला)</option>
                      <option value="Other" ${val === 'Other' ? 'selected' : ''}>Other (अन्य)</option>
                   </select>`;
        } else {
          // Determine rows based on length of value
          const strVal = String(val);
          const lines = Math.min(Math.max(strVal.split('').length / 30, 1), 4);
          html += `<textarea 
                         rows="${Math.ceil(lines)}"
                         class="inline-input w-full px-3 py-2 rounded border border-transparent hover:border-gray-300 focus:border-blue-500 text-gray-800 resize-y min-h-[38px]"
                         style="field-sizing: content; min-width:150px; line-height: 1.4;"
                         data-field="${h}"
                         data-original="${strVal.replace(/"/g, '&quot;')}"
                         data-type="${type}"
                         oninput="onCellInput(this, '${originalData._id}'); this.style.height = 'auto'; this.style.height = (this.scrollHeight) + 'px';"
                         onkeydown="handleTableKey(event, this)">${strVal}</textarea>`;
        }
        html += `</td>`;
      });
      
      // Actions cell
      html += `<td class="px-5 py-3 text-right whitespace-nowrap" onclick="event.stopPropagation()">
        <button onclick="openEdit(document.getElementById('row-${originalData._id}'))" class="text-blue-600/40 hover:text-blue-600 font-medium mr-3" title="Open Deep Editor">
          <i class="fas fa-code"></i> JSON
        </button>
        <button onclick="openDelete(document.getElementById('row-${originalData._id}'))" class="text-red-400 hover:text-red-600 font-medium">
          <i class="fas fa-trash"></i>
        </button>
      </td>`;
      
      tr.innerHTML = html;
      tbody.appendChild(tr);
    });
  }

  /* ── Spreadsheet Actions ── */
  
  function onCellInput(input, docId) {
    const original = input.dataset.original;
    const current = input.value;
    const isChanged = original !== current;
    
    input.classList.toggle('changed', isChanged);
    
    // Sync related fields automatically
    syncRelatedCells(input, docId);
    
    // Check if ANY cell in the row is changed
    const row = input.closest('tr');
    const changedFields = row.querySelectorAll('.inline-input.changed');
    const saveBtn = document.getElementById('save-btn-' + docId);
    const editIcon = document.getElementById('edit-icon-' + docId);
    
    if (changedFields.length > 0) {
      row.classList.add('dirty');
      saveBtn.classList.remove('hidden');
      editIcon.classList.add('hidden');
    } else {
      row.classList.remove('dirty');
      saveBtn.classList.add('hidden');
      editIcon.classList.remove('hidden');
    }
  }

  // Smart sync: when honorific/gender/isDeceased changes, auto-update related fields
  function syncRelatedCells(changedInput, docId) {
    const field = changedInput.dataset.field;
    const val = changedInput.value;
    const row = document.getElementById('table-row-' + docId);
    if (!row) return;

    function getCell(fieldName) {
      return row.querySelector(`.inline-input[data-field="${fieldName}"]`);
    }
    function setCell(fieldName, newVal) {
      const el = getCell(fieldName);
      if (!el || el.value === newVal) return;
      el.value = newVal;
      const changed = el.dataset.original !== String(newVal);
      el.classList.toggle('changed', changed);
      // Update boolean color if needed
      if (el.tagName === 'SELECT' && el.dataset.type === 'boolean') {
        el.className = 'inline-input font-bold ' + (newVal === 'true' ? 'text-green-600' : 'text-red-500');
        el.classList.toggle('changed', changed);
      }
    }

    if (field === 'honorific') {
      // Late ↔ isDeceased
      if (val === 'Late') {
        setCell('isDeceased', 'true');
      } else {
        // Only clear isDeceased if it was set because of Late
        const deceasedEl = getCell('isDeceased');
        if (deceasedEl && deceasedEl.value === 'true') setCell('isDeceased', 'false');
      }
      // Honorific → Gender
      if (val === 'Shri') setCell('gender', 'Male');
      else if (val === 'Smt.' || val === 'Ms.') setCell('gender', 'Female');

    } else if (field === 'isDeceased') {
      // isDeceased → set honorific to Late
      if (val === 'true') {
        setCell('honorific', 'Late');
      } else {
        // If honorific is Late, clear it
        const hEl = getCell('honorific');
        if (hEl && hEl.value === 'Late') setCell('honorific', '');
      }

    } else if (field === 'gender') {
      // Gender → flip Shri/Smt only (not Dr/Er/Prof/Late)
      const hEl = getCell('honorific');
      if (!hEl) return;
      const cur = hEl.value;
      if (val === 'Male' && (cur === 'Smt.' || cur === 'Ms.')) {
        setCell('honorific', 'Shri');
      } else if (val === 'Female' && cur === 'Shri') {
        setCell('honorific', 'Smt.');
      }
    }
  }

  function handleTableKey(e, input) {
    if (e.key === 'Enter') {
      e.preventDefault();
      const tr = input.closest('tr');
      const docId = tr.dataset.id;
      const colName = tr.dataset.collection;
      saveInlineRow(docId, colName);
    }
  }

  async function saveInlineRow(docId, colName) {
    const row = document.getElementById('table-row-' + docId);
    if (!row) return;

    // Collect ONLY changed fields (Delta Update)
    const changedInputs = row.querySelectorAll('.inline-input.changed');
    if (changedInputs.length === 0) return;

    const delta = {};
    changedInputs.forEach(input => {
      const field = input.dataset.field;
      if (!field || field === '_id') return;

      const type = input.dataset.type;
      let val = input.value;

      // Type cast values
      if (type === 'number') val = Number(val);
      else if (type === 'boolean') val = (val.toLowerCase() === 'true');
      else if (type === 'object') {
        try { val = JSON.parse(val); } catch(e) { /* fallback to string */ }
      }
      
      delta[field] = val;
    });

    try {
      const res = await fetch('/admin/db/update', { 
        method:'POST', 
        headers:{'Content-Type':'application/json'}, 
        body: JSON.stringify({ collection: colName, id: docId, data: JSON.stringify(delta) }) 
      });
      
      const result = await res.json();
      if (result.ok) {
        // Update both Table row and List row data to maintain state
        const lRow = document.getElementById('row-' + docId);
        const originalData = JSON.parse(lRow.dataset.json);
        
        // Merge delta into the original data local state
        for (let path in delta) {
          setNestedValue(originalData, path, delta[path]);
        }
        
        const finalJson = JSON.stringify(originalData);
        lRow.dataset.json = finalJson;
        row.dataset.json = finalJson;
        lRow.querySelector('.doc-json').textContent = JSON.stringify(originalData, null, 2);
        
        // Reset the inputs
        changedInputs.forEach(input => {
          input.classList.remove('changed');
          input.dataset.original = input.value;
        });
        
        row.classList.remove('dirty');
        document.getElementById('save-btn-' + docId).classList.add('hidden');
        document.getElementById('edit-icon-' + docId).classList.remove('hidden');
        
        showToast('Saved successfully! (बदलाव सहेजे गए)', 'green');
      } else {
        alert('Save failed: ' + result.error);
      }
    } catch (err) {
      console.error('Save error:', err);
      alert('Network error while saving.');
    }
  }

  async function applyColumnBulk(fieldName, colName) {
    const ids = getSelectedCbs().filter(cb => cb.dataset.col === colName).map(cb => cb.dataset.id);
    if (ids.length === 0) return showToast('Select records first!', 'orange');
    
    const value = document.getElementById(`bulk-input-${colName}-${fieldName}`).value.trim();
    if (!value) return showToast('Enter a value to apply!', 'orange');

    const res = await fetch('/admin/db/bulk-update', { 
      method:'POST', 
      headers:{'Content-Type':'application/json'}, 
      body: JSON.stringify({ collection: colName, ids, field: fieldName, value: value }) 
    });
    
    const result = await res.json();
    if (result.ok) {
      showToast(`Updated ${result.modified} records in ${fieldName}!`, 'blue');
      // Reload to reflect changes (simplest way for bulk)
      setTimeout(() => location.reload(), 1000);
    } else {
      alert('Bulk update failed: ' + result.error);
    }
  }

  // Handle cross-view selection sync
  function syncRowSelect(cb) {
    const id = cb.dataset.id;
    const col = cb.dataset.col;
    const isChecked = cb.checked;
    
    // Update List view checkbox
    const listRow = document.getElementById('row-' + id);
    const listCb = listRow.querySelector('.row-cb');
    listCb.checked = isChecked;
    listRow.classList.toggle('selected', isChecked);
    
    // Toggle class on table row too
    const tableRow = cb.closest('tr');
    if (tableRow) tableRow.classList.toggle('selected', isChecked);
    
    updateBulkBar();
  }

  /* ── Toggle JSON ── */
  function toggleDoc(row) { row.querySelector('.doc-json').classList.toggle('hidden'); }

  /* ── Search ── */
  function filterDocs(input, colName) {
    const term = input.value.toLowerCase().trim();
    const selectors = [`#list-view-${colName} .doc-row`, `#tbody-${colName} .doc-row` ];
    
    selectors.forEach(selector => {
      document.querySelectorAll(selector).forEach(row => {
        const isMatch = !term || (row.dataset.json || '').toLowerCase().includes(term);
        row.style.display = isMatch ? '' : 'none';
      });
    });
  }

  /* ── Selection / Bulk Bar ── */
  function getSelectedCbs() {
    return [...document.querySelectorAll('.row-cb:checked')];
  }
  function updateBulkBar() {
    const cbs = getSelectedCbs();
    const bar = document.getElementById('bulk-bar');
    document.getElementById('bulk-count').textContent = cbs.length;
    // Highlight selected rows
    document.querySelectorAll('.row-cb').forEach(cb => {
      cb.closest('.doc-row').classList.toggle('selected', cb.checked);
    });
    if (cbs.length > 0) { bar.classList.remove('hidden'); }
    else { bar.classList.add('hidden'); }
  }
  function toggleSelectAll(masterCb) {
    const col = masterCb.dataset.col;
    document.querySelectorAll(`.row-cb[data-col="${col}"]`).forEach(cb => { cb.checked = masterCb.checked; });
    updateBulkBar();
  }
  function clearSelection() {
    document.querySelectorAll('.row-cb').forEach(cb => { cb.checked = false; });
    document.querySelectorAll('.select-all-cb').forEach(cb => { cb.checked = false; });
    document.querySelectorAll('.doc-row').forEach(r => r.classList.remove('selected'));
    document.getElementById('bulk-bar').classList.add('hidden');
  }

  /* ── Single Edit ── */
  let _editMode = 'json'; // 'json' or 'form'

  function openEdit(row) {
    _editId  = JSON.parse(row.dataset.json)._id;
    _editCol = row.dataset.collection;
    _editMode = 'json';
    updateEditModeUI();

    document.getElementById('edit-modal-id').textContent = `Collection: ${_editCol}  ·  ID: ${_editId}`;
    document.getElementById('edit-json').value = JSON.stringify(JSON.parse(row.dataset.json), null, 2);
    document.getElementById('edit-json-error').classList.add('hidden');
    document.getElementById('edit-modal').classList.remove('hidden');
  }

  function setEditMode(mode) {
    if (_editMode === mode) return;
    
    // Sync logic before switching
    if (mode === 'form') {
      try {
        const json = JSON.parse(document.getElementById('edit-json').value);
        renderForm(json);
        _editMode = 'form';
      } catch(e) {
        showEditError('Fix JSON syntax before switching to Form View: ' + e.message);
        return;
      }
    } else {
      syncFormToJson();
      _editMode = 'json';
    }
    updateEditModeUI();
  }

  function updateEditModeUI() {
    const isJson = _editMode === 'json';
    document.getElementById('json-editor-container').classList.toggle('hidden', !isJson);
    document.getElementById('form-editor-container').classList.toggle('hidden', isJson);
    
    const btnJson = document.getElementById('btn-json-mode');
    const btnForm = document.getElementById('btn-form-mode');
    
    [btnJson, btnForm].forEach(btn => {
      btn.classList.remove('bg-white', 'shadow-sm', 'text-gray-800');
      btn.classList.add('text-gray-500');
    });
    
    const activeBtn = isJson ? btnJson : btnForm;
    activeBtn.classList.add('bg-white', 'shadow-sm', 'text-gray-800');
    activeBtn.classList.remove('text-gray-500');
  }

  function renderForm(json) {
    const container = document.getElementById('form-editor-container');
    container.innerHTML = '';
    
    const protectedFields = ['_id', '__v', 'password'];
    
    Object.keys(json).forEach(key => {
      if (protectedFields.includes(key)) return;
      
      const val = json[key];
      const fieldDiv = document.createElement('div');
      fieldDiv.className = 'flex flex-col gap-1.5';
      
      const label = document.createElement('label');
      label.className = 'text-xs font-bold text-gray-600 uppercase tracking-wider';
      label.textContent = key;
      fieldDiv.appendChild(label);
      
      if (typeof val === 'boolean') {
        const cb = document.createElement('input');
        cb.type = 'checkbox';
        cb.checked = val;
        cb.className = 'w-5 h-5 rounded accent-blue-600 cursor-pointer form-field';
        cb.dataset.key = key;
        cb.dataset.type = 'boolean';
        fieldDiv.appendChild(cb);
      } else if (typeof val === 'number') {
        const input = document.createElement('input');
        input.type = 'number';
        input.value = val;
        input.className = 'w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-blue-400 focus:outline-none form-field';
        input.dataset.key = key;
        input.dataset.type = 'number';
        fieldDiv.appendChild(input);
      } else if (typeof val === 'object' && val !== null) {
        const area = document.createElement('textarea');
        area.value = JSON.stringify(val, null, 2);
        area.className = 'w-full px-3 py-2 border border-gray-300 rounded-lg font-mono text-[11px] focus:ring-2 focus:ring-blue-400 focus:outline-none form-field resize-y';
        area.rows = 4;
        area.dataset.key = key;
        area.dataset.type = 'object';
        fieldDiv.appendChild(area);
      } else {
        const input = document.createElement('input');
        input.type = 'text';
        input.value = val || '';
        input.className = 'w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-blue-400 focus:outline-none form-field';
        input.dataset.key = key;
        input.dataset.type = 'string';
        fieldDiv.appendChild(input);
      }
      
      container.appendChild(fieldDiv);
    });
  }

  function syncFormToJson() {
    const fields = document.querySelectorAll('.form-field');
    const json = JSON.parse(document.getElementById('edit-json').value);
    
    fields.forEach(field => {
      const key = field.dataset.key;
      const type = field.dataset.type;
      
      if (type === 'boolean') json[key] = field.checked;
      else if (type === 'number') json[key] = Number(field.value);
      else if (type === 'object') {
        try { json[key] = JSON.parse(field.value); } catch(e) { /* keep original on error or handle it */ }
      }
      else json[key] = field.value;
    });
    
    document.getElementById('edit-json').value = JSON.stringify(json, null, 2);
  }

  function formatJson() {
    try {
      if (_editMode === 'form') syncFormToJson();
      document.getElementById('edit-json').value = JSON.stringify(JSON.parse(document.getElementById('edit-json').value), null, 2);
      if (_editMode === 'form') renderForm(JSON.parse(document.getElementById('edit-json').value));
      document.getElementById('edit-json-error').classList.add('hidden');
    } catch(e) { showEditError(e.message); }
  }

  function showEditError(msg) {
    const el = document.getElementById('edit-json-error');
    el.querySelector('span').textContent = msg; el.classList.remove('hidden');
  }

  async function saveEdit() {
    if (_editMode === 'form') syncFormToJson();
    
    let parsed;
    try { parsed = JSON.parse(document.getElementById('edit-json').value); } catch(e) { showEditError('Invalid JSON structure: '+e.message); return; }
    
    const res = await fetch('/admin/db/update', { 
      method:'POST', 
      headers:{'Content-Type':'application/json'}, 
      body: JSON.stringify({ collection: _editCol, id: _editId, data: JSON.stringify(parsed) }) 
    });
    
    const result = await res.json();
    if (result.ok) {
      closeModal('edit-modal');
      const row = document.getElementById('row-'+_editId);
      if (row) { 
        row.dataset.json = JSON.stringify(parsed); 
        const pre = row.querySelector('.doc-json'); 
        if(pre) pre.textContent = JSON.stringify(parsed, null, 2); 
      }
      showToast('Successfully updated document!', 'blue');
    } else { showEditError('Failed to save: ' + result.error); }
  }

  /* ── Single Delete ── */
  function openDelete(row) {
    const doc = JSON.parse(row.dataset.json);
    _delId = doc._id; _delCol = row.dataset.collection; _delRow = row;
    document.getElementById('del-modal-desc').textContent = `"${doc.name||doc.title||_delId}" from ${_delCol}. Cannot be undone.`;
    document.getElementById('del-modal').classList.remove('hidden');
  }
  async function confirmDelete() {
    const docData = JSON.parse(_delRow.dataset.json);
    const res = await fetch('/admin/db/delete', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ collection: _delCol, id: _delId }) });
    const result = await res.json();
    if (result.ok) { 
      closeModal('del-modal'); 
      if(_delRow) _delRow.remove(); 
      
      const undoFn = async () => {
        const restoreRes = await fetch('/admin/db/restore', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ collection: _delCol, docs: [docData] }) });
        const restoreResult = await restoreRes.json();
        if (restoreResult.ok) window.location.reload();
        else alert('Restore failed: ' + restoreResult.error);
      };
      
      showToast('Deleted!', 'red', undoFn); 
      updateBulkBar(); 
    }
    else alert('Error: '+result.error);
  }

  /* ── Bulk Edit ── */
  function openBulkEdit() {
    const cbs = getSelectedCbs();
    if (!cbs.length) return;
    document.getElementById('bulk-edit-count').textContent = cbs.length + ' document' + (cbs.length>1?'s':'');
    
    // Reset container with one empty row
    const container = document.getElementById('bulk-fields-container');
    container.innerHTML = '';
    addBulkFieldRow();

    document.getElementById('bulk-edit-error').classList.add('hidden');
    document.getElementById('bulk-edit-modal').classList.remove('hidden');
  }

  function addBulkFieldRow() {
    const container = document.getElementById('bulk-fields-container');
    const div = document.createElement('div');
    div.className = 'bulk-field-row flex gap-2 items-end';
    div.innerHTML = `
      <div class="flex-1">
        <label class="block text-[10px] font-bold text-gray-400 uppercase mb-1">Field Name</label>
        <input type="text" placeholder="e.g. isApproved" class="bulk-field-name w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-400 focus:outline-none">
      </div>
      <div class="flex-1">
        <label class="block text-[10px] font-bold text-gray-400 uppercase mb-1">New Value (JSON)</label>
        <input type="text" placeholder='e.g. true' class="bulk-field-value w-full border border-gray-300 rounded-lg px-3 py-2 text-sm font-mono focus:ring-2 focus:ring-blue-400 focus:outline-none">
      </div>
      <button onclick="if(document.querySelectorAll('.bulk-field-row').length > 1) this.closest('.bulk-field-row').remove()" class="p-2.5 text-gray-300 hover:text-red-500 transition-colors"><i class="fas fa-times"></i></button>
    `;
    container.appendChild(div);
  }

  async function saveBulkEdit() {
    const cbs = getSelectedCbs();
    const ids = cbs.map(cb => cb.dataset.id);
    const col = cbs[0]?.dataset.col;
    const errorEl = document.getElementById('bulk-edit-error');
    
    // Gather updates
    const updates = {};
    const rows = document.querySelectorAll('.bulk-field-row');
    let hasError = false;

    rows.forEach(row => {
      const field = row.querySelector('.bulk-field-name').value.trim();
      const valueRaw = row.querySelector('.bulk-field-value').value.trim();
      
      if (!field) return; // Skip empty rows

      try {
        let parsedValue;
        try { parsedValue = JSON.parse(valueRaw); } catch { parsedValue = valueRaw; }
        updates[field] = parsedValue;
      } catch (e) {
        hasError = true;
        errorEl.querySelector('span').textContent = `Invalid value for field "${field}"`;
        errorEl.classList.remove('hidden');
      }
    });

    if (hasError) return;
    if (Object.keys(updates).length === 0) {
      errorEl.querySelector('span').textContent = 'Please specify at least one field to update';
      errorEl.classList.remove('hidden');
      return;
    }

    const res = await fetch('/admin/db/bulk-update', { 
      method:'POST', 
      headers:{'Content-Type':'application/json'}, 
      body: JSON.stringify({ collection: col, ids, updates }) 
    });
    
    const result = await res.json();
    if (result.ok) {
      closeModal('bulk-edit-modal');
      showToast(`Updated ${result.modified} document(s)!`, 'blue');
      // Update local storage/UI if needed, but a reload is safer for bulk
      setTimeout(() => location.reload(), 1000);
    } else {
      errorEl.querySelector('span').textContent = 'Server: ' + result.error;
      errorEl.classList.remove('hidden');
    }
  }

  /* ── Bulk Delete ── */
  function openBulkDelete() {
    const cbs = getSelectedCbs();
    if (!cbs.length) return;
    document.getElementById('bulk-del-desc').textContent = `${cbs.length} document${cbs.length>1?'s':''} will be permanently deleted. This cannot be undone.`;
    document.getElementById('bulk-del-modal').classList.remove('hidden');
  }
  async function confirmBulkDelete() {
    const cbs  = getSelectedCbs();
    const ids  = cbs.map(cb => cb.dataset.id);
    const col  = cbs[0]?.dataset.col;
    const rows = cbs.map(cb => cb.closest('.doc-row'));
    const docs = rows.map(r => JSON.parse(r.dataset.json));
    
    const res  = await fetch('/admin/db/bulk-delete', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ collection: col, ids }) });
    const result = await res.json();
    if (result.ok) {
      closeModal('bulk-del-modal');
      rows.forEach(r => r && r.remove());
      
      const undoFn = async () => {
        const restoreRes = await fetch('/admin/db/restore', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ collection: col, docs }) });
        const restoreResult = await restoreRes.json();
        if (restoreResult.ok) window.location.reload();
        else alert('Restore failed: ' + restoreResult.error);
      };

      showToast(`Deleted ${result.deleted} document(s)!`, 'red', undoFn);
      clearSelection();
    } else { alert('Error: '+result.error); }
  }

  /* ── Export Data ── */
  function exportData(colName, format) {
    const listContainer = document.getElementById('list-view-' + colName);
    const rows = listContainer.querySelectorAll('.doc-row');
    const data = [];
    
    rows.forEach(row => {
      // Only export rows that are visible (not filtered out)
      if (row.style.display !== 'none') {
        try {
          const doc = JSON.parse(row.dataset.json);
          data.push(doc);
        } catch(e) { console.error('Error parsing doc', e); }
      }
    });

    if (data.length === 0) {
      alert('No data to export.');
      return;
    }

    if (format === 'json') {
      const blob = new Blob([JSON.stringify(data, null, 2)], { type: 'application/json' });
      downloadBlob(blob, `${colName}_export.json`);
    } else if (format === 'csv') {
      // Collect all possible headers
      const headers = new Set();
      data.forEach(d => Object.keys(d).forEach(k => headers.add(k)));
      const headerRow = Array.from(headers);
      
      const csvRows = [headerRow.join(',')];
      data.forEach(row => {
        const values = headerRow.map(header => {
          let val = row[header];
          if (val === null || val === undefined) return '';
          if (typeof val === 'object') val = JSON.stringify(val);
          // Escape quotes
          const escaped = String(val).replace(/"/g, '""');
          return `"${escaped}"`;
        });
        csvRows.push(values.join(','));
      });
      
      const blob = new Blob([csvRows.join('\n')], { type: 'text/csv' });
      downloadBlob(blob, `${colName}_export.csv`);
    }
  }

  function downloadBlob(blob, filename) {
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = filename;
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
    URL.revokeObjectURL(url);
  }

  /* Close modals on backdrop click */
  ['edit-modal','bulk-edit-modal','del-modal','bulk-del-modal'].forEach(id => {
    document.getElementById(id).addEventListener('click', e => { if(e.target===e.currentTarget) closeModal(id); });
  });
</script>

