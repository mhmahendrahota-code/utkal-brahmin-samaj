<div id="delete-modal" class="fixed inset-0 bg-black/50 backdrop-blur-sm z-50 flex items-center justify-center hidden">
  <div class="bg-white rounded-2xl shadow-2xl w-full max-w-md mx-4 overflow-hidden">
    <div class="bg-red-50 border-b border-red-100 px-6 py-4 flex items-center gap-3">
      <div class="w-10 h-10 rounded-full bg-red-100 flex items-center justify-center flex-shrink-0">
        <i class="fas fa-exclamation-triangle text-red-600"></i>
      </div>
      <div>
        <h3 class="font-bold text-gray-900 text-lg">Delete Member?</h3>
        <p class="text-sm text-gray-500">This action cannot be undone.</p>
      </div>
    </div>
    <div class="px-6 py-5">
      <p class="text-gray-700">You are about to delete: <strong id="modal-member-name" class="text-gray-900"></strong></p>
      
      <div id="modal-impact" class="mt-4 hidden">
        <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
          <p class="text-sm font-semibold text-amber-800 mb-2"><i class="fas fa-sitemap mr-1"></i> Family Tree Impact:</p>
          <ul id="modal-impact-list" class="text-sm text-amber-700 space-y-1 list-disc list-inside"></ul>
        </div>
        <p class="text-xs text-gray-500 mt-3">All broken links will be automatically cleaned up. Children will appear as root-level ancestors in the family tree.</p>
      </div>
    </div>
    <div class="px-6 pb-5 flex gap-3 justify-end">
      <button type="button" id="modal-cancel" class="px-5 py-2 rounded-lg border border-gray-300 text-gray-700 hover:bg-gray-50 font-medium transition-colors">
        Cancel
      </button>
      <form id="delete-form" method="POST" action="">
        <button type="submit" class="px-5 py-2 rounded-lg bg-red-600 hover:bg-red-700 text-white font-medium transition-colors">
          <i class="fas fa-trash-alt mr-1"></i> Yes, Delete
        </button>
      </form>
    </div>
  </div>
</div>

<script>
  // Live Search
  const searchInput = document.getElementById('member-search');
  const rows = document.querySelectorAll('.member-row');
  const resultCount = document.getElementById('result-count');

  function updateSearch() {
    const term = searchInput.value.toLowerCase().trim();
    rows.forEach(row => {
      const match = !term || 
        row.dataset.name.includes(term) || 
        row.dataset.gotra.includes(term) || 
        row.dataset.village.includes(term);
      row.classList.toggle('hidden', !match);
    });
    
    // Update allRows to only include visible rows for pagination
    allRows = Array.from(document.querySelectorAll('.member-row:not(.hidden)'));
    currentPage = 1;
    updatePagination();
  }
  searchInput.addEventListener('input', updateSearch);

  // Delete Modal
  const modal = document.getElementById('delete-modal');
  const modalName = document.getElementById('modal-member-name');
  const modalImpact = document.getElementById('modal-impact');
  const modalImpactList = document.getElementById('modal-impact-list');
  const deleteForm = document.getElementById('delete-form');
  const cancelBtn = document.getElementById('modal-cancel');

  document.querySelectorAll('.delete-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const id = btn.dataset.id;
      const name = btn.dataset.name;
      const childCount = parseInt(btn.dataset.children) || 0;
      const hasFather = btn.dataset.hasFather === 'true';
      const hasMother = btn.dataset.hasMother === 'true';
      const hasSpouse = btn.dataset.hasSpouse === 'true';

      modalName.textContent = name;
      deleteForm.action = `/admin/members/${id}/delete`;

      // Build impact list
      const impacts = [];
      if (childCount > 0) impacts.push(`${childCount} child member${childCount > 1 ? 's' : ''} will lose their parent link`);
      if (hasFather) impacts.push(`Father's children list will be updated`);
      if (hasMother) impacts.push(`Mother's children list will be updated`);
      if (hasSpouse) impacts.push(`Spouse link will be removed`);

      if (impacts.length > 0) {
        modalImpactList.innerHTML = impacts.map(i => `<li>${i}</li>`).join('');
        modalImpact.classList.remove('hidden');
      } else {
        modalImpact.classList.add('hidden');
      }

      modal.classList.remove('hidden');
    });
  });

  cancelBtn.addEventListener('click', () => modal.classList.add('hidden'));
  modal.addEventListener('click', e => { if (e.target === modal) modal.classList.add('hidden'); });

  // Load Quick Stats
  async function loadStats() {
    try {
      const response = await fetch('/admin/api/member-stats');
      if (!response.ok) return;
      const stats = await response.json();
      
      document.getElementById('stat-total').textContent = stats.total;
      document.getElementById('stat-approved').textContent = stats.approved;
      document.getElementById('stat-pending').textContent = stats.pending;
      document.getElementById('stat-incomplete').textContent = stats.incomplete;
      document.getElementById('stat-matrimonial').textContent = stats.matrimonial;
      document.getElementById('stat-committee').textContent = stats.committee;
      document.getElementById('stat-deceased').textContent = stats.deceased;
      
      const familyCount = (stats.familyLinks.withFather + stats.familyLinks.withMother + 
                          stats.familyLinks.withSpouse + stats.familyLinks.withChildren);
      document.getElementById('stat-family').textContent = familyCount;
    } catch (e) {
      console.error('Error loading stats:', e);
    }
  }

  // Load stats on page load
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', loadStats);
  } else {
    loadStats();
  }

  // Toggle Advanced Filters
  function toggleAdvancedFilters() {
    const filterDiv = document.getElementById('advanced-filters');
    filterDiv.classList.toggle('hidden');
  }

  // Apply Filters
  function applyFilters() {
    const statusFilter = document.getElementById('filter-status').value;
    const familyFilter = document.getElementById('filter-family').value;
    const committeeFilter = document.getElementById('filter-committee').value;
    const qualityFilter = document.getElementById('filter-quality').value;
    
    const rows = document.querySelectorAll('.member-row');
    let visibleCount = 0;

    rows.forEach(row => {
      let show = true;

      // Status filter
      if (statusFilter === 'approved' && row.dataset.approved !== 'yes') show = false;
      if (statusFilter === 'pending' && row.dataset.approved !== 'no') show = false;

      // Family links filter
      if (familyFilter === 'has-father' && row.dataset.hasFather !== 'yes') show = false;
      if (familyFilter === 'has-mother' && row.dataset.hasMother !== 'yes') show = false;
      if (familyFilter === 'has-spouse' && row.dataset.hasSpouse !== 'yes') show = false;
      if (familyFilter === 'has-children' && row.dataset.hasChildren !== 'yes') show = false;
      if (familyFilter === 'no-links' && (row.dataset.hasFather === 'yes' || row.dataset.hasMother === 'yes' || row.dataset.hasSpouse === 'yes' || row.dataset.hasChildren === 'yes')) show = false;

      // Committee filter
      if (committeeFilter === 'member' && row.dataset.isCommittee !== 'yes') show = false;
      if (committeeFilter === 'non-committee' && row.dataset.isCommittee !== 'no') show = false;

      // Data quality filter
      if (qualityFilter === 'excellent') {
        const score = parseInt(row.dataset.qualityScore) || 0;
        if (score < 80) show = false;
      }
      if (qualityFilter === 'good') {
        const score = parseInt(row.dataset.qualityScore) || 0;
        if (score < 60 || score >= 80) show = false;
      }
      if (qualityFilter === 'incomplete') {
        const score = parseInt(row.dataset.qualityScore) || 0;
        if (score >= 60) show = false;
      }

      row.classList.toggle('hidden', !show);
      if (show) visibleCount++;
    });

    // Update allRows to only include non-hidden rows for pagination
    allRows = Array.from(document.querySelectorAll('.member-row:not(.hidden)'));
    currentPage = 1;
    updatePagination();
  }

  // Bulk Operations Functions
  function toggleSelectAll() {
    const selectAllCheckbox = document.getElementById('select-all');
    const checkboxes = document.querySelectorAll('.member-checkbox');
    const visibleRows = Array.from(document.querySelectorAll('.member-row')).filter(row => row.style.display !== 'none');
    
    checkboxes.forEach(checkbox => {
      const row = checkbox.closest('tr');
      if (row.style.display !== 'none') {
        checkbox.checked = selectAllCheckbox.checked;
      }
    });
    
    updateBulkActions();
  }

  function updateBulkActions() {
    const checkboxes = document.querySelectorAll('.member-checkbox:checked');
    const bulkBar = document.getElementById('bulk-actions-bar');
    const selectedCount = document.getElementById('selected-count');
    const selectAll = document.getElementById('select-all');
    
    const selected = checkboxes.length;
    if (selected > 0) {
      bulkBar.classList.remove('hidden');
      selectedCount.textContent = `${selected} selected`;
    } else {
      bulkBar.classList.add('hidden');
      selectAll.checked = false;
    }
  }

  function clearSelection() {
    document.querySelectorAll('.member-checkbox').forEach(cb => cb.checked = false);
    document.getElementById('select-all').checked = false;
    document.getElementById('bulk-actions-bar').classList.add('hidden');
  }

  function getSelectedIds() {
    return Array.from(document.querySelectorAll('.member-checkbox:checked')).map(cb => cb.dataset.id);
  }

  async function bulkUpdateStatus() {
    const selected = getSelectedIds();
    if (selected.length === 0) return alert('Please select members first');
    
    const confirmed = confirm(`Approve ${selected.length} member(s)?`);
    if (!confirmed) return;

    try {
      const response = await fetch('/admin/api/members/bulk-approve', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ memberIds: selected })
      });
      
      if (response.ok) {
        alert('Members approved successfully!');
        location.reload();
      } else {
        alert('Error approving members');
      }
    } catch (e) {
      alert('Error: ' + e.message);
    }
  }

  async function bulkRejectStatus() {
    const selected = getSelectedIds();
    if (selected.length === 0) return alert('Please select members first');
    
    const confirmed = confirm(`Reject ${selected.length} member(s)?`);
    if (!confirmed) return;

    try {
      const response = await fetch('/admin/api/members/bulk-reject', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ memberIds: selected })
      });
      
      if (response.ok) {
        alert('Members rejected successfully!');
        location.reload();
      } else {
        alert('Error rejecting members');
      }
    } catch (e) {
      alert('Error: ' + e.message);
    }
  }

  async function bulkDelete() {
    const selected = getSelectedIds();
    if (selected.length === 0) return alert('Please select members first');
    
    const confirmed = confirm(`⚠️ Delete ${selected.length} member(s)? This cannot be undone.`);
    if (!confirmed) return;

    try {
      const response = await fetch('/admin/api/members/bulk-delete', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ memberIds: selected })
      });
      
      if (response.ok) {
        alert('Members deleted successfully!');
        location.reload();
      } else {
        alert('Error deleting members');
      }
    } catch (e) {
      alert('Error: ' + e.message);
    }
  }

  // ========== SORTING & PAGINATION ==========
  let sortColumn = null;
  let sortOrder = 'asc'; // 'asc' or 'desc'
  let currentPage = 1;
  let rowsPerPage = 25;
  let allRows = [];

  function initPagination() {
    // Get all member rows (not visible/hidden state, just collect them all)
    allRows = Array.from(document.querySelectorAll('.member-row'));
    updatePagination();
  }

  function sortTable(column) {
    // Toggle sort order if clicking the same column
    if (sortColumn === column) {
      sortOrder = sortOrder === 'asc' ? 'desc' : 'asc';
    } else {
      sortColumn = column;
      sortOrder = 'asc';
    }

    // Clear all sort indicators
    document.getElementById('sort-name').textContent = '';
    document.getElementById('sort-gotra').textContent = '';
    document.getElementById('sort-village').textContent = '';
    document.getElementById('sort-contact').textContent = '';

    // Add sort indicator to current column
    const sortIndicator = sortOrder === 'asc' ? '↑' : '↓';
    document.getElementById(`sort-${column}`).textContent = sortIndicator;

    // Sort the rows
    const getColumnValue = (row) => {
      switch(column) {
        case 'name': return row.dataset.name || '';
        case 'gotra': return row.dataset.gotra || '';
        case 'village': return row.dataset.village || '';
        case 'contact': return row.querySelector('td:nth-child(5)')?.textContent?.trim() || '';
        default: return '';
      }
    };

    allRows.sort((a, b) => {
      const aVal = getColumnValue(a).toLowerCase();
      const bVal = getColumnValue(b).toLowerCase();
      const comparison = aVal.localeCompare(bVal);
      return sortOrder === 'asc' ? comparison : -comparison;
    });

    // Reset to first page after sort
    currentPage = 1;
    updatePagination();
  }

  function changeRowsPerPage() {
    rowsPerPage = parseInt(document.getElementById('rows-per-page').value);
    currentPage = 1; // Reset to first page
    updatePagination();
  }

  function prevPage() {
    if (currentPage > 1) {
      currentPage--;
      updatePagination();
    }
  }

  function nextPage() {
    const totalPages = Math.ceil(allRows.length / rowsPerPage);
    if (currentPage < totalPages) {
      currentPage++;
      updatePagination();
    }
  }

  function goToPage(pageNum) {
    currentPage = pageNum;
    updatePagination();
  }

  function updatePagination() {
    const totalRows = allRows.length;
    const totalPages = Math.ceil(totalRows / rowsPerPage);
    const startIdx = (currentPage - 1) * rowsPerPage;
    const endIdx = Math.min(startIdx + rowsPerPage, totalRows);

    // Hide all rows, then show only current page rows
    allRows.forEach(row => row.style.display = 'none');
    for (let i = startIdx; i < endIdx; i++) {
      if (allRows[i]) allRows[i].style.display = '';
    }

    // Update showing X-Y of Z
    document.getElementById('showing-start').textContent = totalRows > 0 ? startIdx + 1 : 0;
    document.getElementById('showing-end').textContent = endIdx;
    document.getElementById('total-rows').textContent = totalRows;

    // Update Previous/Next buttons
    document.getElementById('prev-btn').disabled = currentPage === 1;
    document.getElementById('next-btn').disabled = currentPage === totalPages;

    // Update page numbers
    const pageNumbersDiv = document.getElementById('page-numbers');
    pageNumbersDiv.innerHTML = '';

    const maxPageButtons = 5;
    let startPage = Math.max(1, currentPage - Math.floor(maxPageButtons / 2));
    let endPage = Math.min(totalPages, startPage + maxPageButtons - 1);
    if (endPage - startPage + 1 < maxPageButtons) {
      startPage = Math.max(1, endPage - maxPageButtons + 1);
    }

    if (startPage > 1) {
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.textContent = '1';
      btn.className = 'px-2 py-1 rounded text-sm font-medium border border-gray-300 hover:bg-gray-100 transition-colors';
      btn.onclick = () => goToPage(1);
      pageNumbersDiv.appendChild(btn);

      if (startPage > 2) {
        const ellipsis = document.createElement('span');
        ellipsis.textContent = '...';
        ellipsis.className = 'px-1 text-gray-500';
        pageNumbersDiv.appendChild(ellipsis);
      }
    }

    for (let i = startPage; i <= endPage; i++) {
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.textContent = i;
      btn.className = i === currentPage
        ? 'px-2 py-1 rounded text-sm font-medium bg-saffron-600 text-white'
        : 'px-2 py-1 rounded text-sm font-medium border border-gray-300 hover:bg-gray-100 transition-colors';
      btn.onclick = () => goToPage(i);
      pageNumbersDiv.appendChild(btn);
    }

    if (endPage < totalPages) {
      if (endPage < totalPages - 1) {
        const ellipsis = document.createElement('span');
        ellipsis.textContent = '...';
        ellipsis.className = 'px-1 text-gray-500';
        pageNumbersDiv.appendChild(ellipsis);
      }

      const btn = document.createElement('button');
      btn.type = 'button';
      btn.textContent = totalPages;
      btn.className = 'px-2 py-1 rounded text-sm font-medium border border-gray-300 hover:bg-gray-100 transition-colors';
      btn.onclick = () => goToPage(totalPages);
      pageNumbersDiv.appendChild(btn);
    }
  }

  // Initialize pagination on page load
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => {
      loadStats();
      initPagination();
    });
  } else {
    loadStats();
    initPagination();
  }

  // ========== DUPLICATE DETECTION ==========
  async function checkDuplicates() {
    const modal = document.getElementById('duplicates-modal');
    const loading = document.getElementById('duplicates-loading');
    const content = document.getElementById('duplicates-content');
    const errorDiv = document.getElementById('duplicates-error');
    
    modal.classList.remove('hidden');
    loading.classList.remove('hidden');
    content.classList.add('hidden');
    errorDiv.classList.add('hidden');

    try {
      const response = await fetch('/admin/api/members/duplicates');
      if (!response.ok) throw new Error('Failed to fetch duplicates');
      
      const data = await response.json();
      loading.classList.add('hidden');

      if (data.totalDuplicatePairs === 0) {
        content.classList.remove('hidden');
        document.getElementById('duplicates-list').innerHTML = `
          <div class="text-center py-8">
            <i class="fas fa-check-circle text-green-600 text-3xl"></i>
            <p class="text-gray-600 mt-2">Great! No duplicate members detected.</p>
          </div>
        `;
        return;
      }

      // Display duplicates
      let html = `<p class="text-sm text-gray-600 mb-4">Found <strong>${data.totalDuplicatePairs}</strong> potential duplicate pair(s):</p>`;
      
      data.duplicates.forEach((pair, idx) => {
        const [m1, m2] = pair.pair;
        html += `
          <div class="border border-orange-200 rounded-lg p-4 bg-orange-50">
            <div class="flex items-center justify-between mb-3">
              <div class="flex items-center gap-2">
                <span class="inline-block bg-orange-500 text-white px-2 py-1 rounded text-xs font-bold">${pair.score}% Match</span>
                <span class="text-xs text-gray-600">${pair.reasons.join(' • ')}</span>
              </div>
            </div>
            
            <div class="grid grid-cols-2 gap-4 mb-3">
              <!-- Member 1 -->
              <div class="bg-white p-3 rounded border border-gray-200">
                <div class="font-medium text-gray-900">${m1.name}</div>
                <div class="text-xs text-gray-600 space-y-1 mt-2">
                  <div><span class="font-medium">Surname:</span> ${m1.surname || '—'}</div>
                  <div><span class="font-medium">Gotra:</span> ${m1.gotra || '—'}</div>
                  <div><span class="font-medium">Village:</span> ${m1.village || '—'}</div>
                  <div><span class="font-medium">Contact:</span> ${m1.contactNumber || '—'}</div>
                  <div><span class="font-medium">Status:</span> ${m1.isApproved ? '✓ Approved' : '⏳ Pending'}</div>
                </div>
              </div>
              
              <!-- Member 2 -->
              <div class="bg-white p-3 rounded border border-gray-200">
                <div class="font-medium text-gray-900">${m2.name}</div>
                <div class="text-xs text-gray-600 space-y-1 mt-2">
                  <div><span class="font-medium">Surname:</span> ${m2.surname || '—'}</div>
                  <div><span class="font-medium">Gotra:</span> ${m2.gotra || '—'}</div>
                  <div><span class="font-medium">Village:</span> ${m2.village || '—'}</div>
                  <div><span class="font-medium">Contact:</span> ${m2.contactNumber || '—'}</div>
                  <div><span class="font-medium">Status:</span> ${m2.isApproved ? '✓ Approved' : '⏳ Pending'}</div>
                </div>
              </div>
            </div>
            
            <div class="flex gap-2">
              <a href="/admin/members/${m1._id}/edit" target="_blank" class="flex-1 text-center px-3 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded text-sm font-medium transition-colors">
                <i class="fas fa-edit mr-1"></i> Edit First
              </a>
              <a href="/admin/members/${m2._id}/edit" target="_blank" class="flex-1 text-center px-3 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded text-sm font-medium transition-colors">
                <i class="fas fa-edit mr-1"></i> Edit Second
              </a>
              <button type="button" onclick="deleteMember('${m2._id}')" class="flex-1 px-3 py-2 bg-red-600 hover:bg-red-700 text-white rounded text-sm font-medium transition-colors">
                <i class="fas fa-trash-alt mr-1"></i> Delete Duplicate
              </button>
            </div>
          </div>
        `;
      });
      
      document.getElementById('duplicates-list').innerHTML = html;
      content.classList.remove('hidden');
    } catch (err) {
      loading.classList.add('hidden');
      errorDiv.classList.remove('hidden');
      document.getElementById('duplicates-error-text').textContent = err.message;
    }
  }

  function closeDuplicatesModal() {
    document.getElementById('duplicates-modal').classList.add('hidden');
  }

  function deleteMember(memberId) {
    if (confirm('Are you sure you want to delete this duplicate member?')) {
      fetch(`/admin/members/${memberId}/delete`, { method: 'POST' })
        .then(() => {
          alert('Duplicate deleted! Reloading...');
          location.reload();
        })
        .catch(err => alert('Error: ' + err.message));
    }
  }

  // ========== RELATIONSHIP MANAGER ==========
  let currentRelMemberId = null;

  async function openRelationshipManager(memberId, memberName) {
    currentRelMemberId = memberId;
    const modal = document.getElementById('relationship-modal');
    document.getElementById('rel-member-title').textContent = memberName;
    modal.classList.remove('hidden');

    try {
      // Get all members from the table
      const otherMembers = Array.from(document.querySelectorAll('.member-row'))
        .filter(row => row.dataset.id !== memberId)
        .map(row => ({
          id: row.dataset.id,
          name: row.dataset.name.split(/\s+/)[0] || row.dataset.name  // First word for display
        }));

      // Populate dropdowns
      ['father', 'mother', 'spouse', 'child'].forEach(rel => {
        const select = document.getElementById(`select-${rel}`);
        if (select) {
          const currentValue = select.value;
          select.innerHTML = '<option value="">Select a member...</option>';
          otherMembers.forEach(m => {
            const opt = document.createElement('option');
            opt.value = m.id;
            opt.textContent = m.name;
            select.appendChild(opt);
          });
          select.value = currentValue;
        }
      });

      // Load current relationships from the row data
      const row = document.querySelector(`.member-row[data-id="${memberId}"]`);
      
      document.getElementById('father-display').textContent = row?.dataset.hasFather === 'yes' ? '✓ Father linked' : 'Not linked';
      document.getElementById('mother-display').textContent = row?.dataset.hasMother === 'yes' ? '✓ Mother linked' : 'Not linked';
      document.getElementById('spouse-display').textContent = row?.dataset.hasSpouse === 'yes' ? '✓ Spouse linked' : 'Not linked';
      document.getElementById('children-count').textContent = row?.dataset.hasChildren === 'yes' ? row.dataset.children : '0';

      document.getElementById('btn-unlink-father').classList.toggle('hidden', row?.dataset.hasFather !== 'yes');
      document.getElementById('btn-unlink-mother').classList.toggle('hidden', row?.dataset.hasMother !== 'yes');
      document.getElementById('btn-unlink-spouse').classList.toggle('hidden', row?.dataset.hasSpouse !== 'yes');
    } catch (err) {
      console.error('Error loading relationship data:', err);
    }
  }

  function closeRelationshipManager() {
    document.getElementById('relationship-modal').classList.add('hidden');
  }

  async function linkRelation(relationType) {
    const selectId = `select-${relationType}`;
    const select = document.getElementById(selectId);
    const relatedMemberId = select.value;

    if (!relatedMemberId) return;

    try {
      // Create the relationship (this will trigger page reload on success)
      const url = `/admin/members/${currentRelMemberId}/edit`;
      const data = {};
      data[relationType] = relatedMemberId;

      const response = await fetch(url, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
      });

      if (response.ok) {
        alert(`${relationType.charAt(0).toUpperCase() + relationType.slice(1)} linked successfully!`);
        location.reload();
      } else {
        alert('Error linking relationship');
      }
    } catch (err) {
      alert('Error: ' + err.message);
    }
  }

  async function unlinkRelation(relationType) {
    if (!confirm(`Unlink this ${relationType}?`)) return;

    try {
      const response = await fetch(`/admin/members/${currentRelMemberId}/edit`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ [relationType]: '' })
      });

      if (response.ok) {
        alert(`${relationType.charAt(0).toUpperCase() + relationType.slice(1)} unlinked!`);
        location.reload();
      }
    } catch (err) {
      alert('Error: ' + err.message);
    }
  }

  function addChild() {
    const select = document.getElementById('select-child');
    const childId = select.value;
    if (!childId) return;

    if (confirm('Add this member as a child?')) {
      fetch(`/admin/members/${childId}/edit`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ 
          father: currentRelMemberId,
          mother: ''
        })
      }).then(r => {
        if (r.ok) {
          alert('Child added!');
          location.reload();
        }
      });
    }
  }

  // ========== MEMBER BULK IMPORT ==========
  let pendingImportData = [];

  function openMemberImport() {
    document.getElementById('member-import-modal').classList.remove('hidden');
    document.getElementById('csv-file').value = '';
    document.getElementById('csv-paste').value = '';
    document.getElementById('import-preview').classList.add('hidden');
    document.getElementById('import-btn').disabled = true;
    pendingImportData = [];
  }

  function closeMemberImport() {
    document.getElementById('member-import-modal').classList.add('hidden');
  }

  function previewMemberCSV() {
    const fileInput = document.getElementById('csv-file');
    const textArea = document.getElementById('csv-paste');
    let csvText = '';

    // Read from file or textarea
    if (fileInput.files.length > 0) {
      const reader = new FileReader();
      reader.onload = (e) => {
        csvText = e.target.result;
        processMemberCSV(csvText);
      };
      reader.readAsText(fileInput.files[0]);
    } else if (textArea.value) {
      csvText = textArea.value;
      processMemberCSV(csvText);
    }
  }

  function processMemberCSV(csvText) {
    const lines = csvText.split('\n').filter(line => line.trim());
    if (lines.length === 0) {
      alert('No data in CSV');
      return;
    }

    // Skip header if it looks like a header
    let startIdx = 0;
    const firstLine = lines[0].toLowerCase();
    if (firstLine.includes('name') || firstLine.includes('member')) {
      startIdx = 1;
    }

    pendingImportData = [];
    for (let i = startIdx; i < lines.length; i++) {
      const parts = lines[i].split(',').map(p => p.trim());
      if (parts.length < 2 || !parts[0]) continue;

      const member = {
        name: parts[0] || '',
        surname: parts[1] || '',
        gotra: parts[2] || '',
        village: parts[3] || '',
        contactNumber: parts[4] || '',
        honorific: parts[5] || '',
        isFamilyTreeOnly: (parts[6] && (parts[6].toLowerCase() === 'yes' || parts[6].toLowerCase() === 'true' || parts[6] === '1')),
        spouseName: parts[7] || '',
        fatherName: parts[8] || '',
        motherName: parts[9] || ''
      };

      // Validate required fields
      if (member.name && member.gotra) {
        pendingImportData.push(member);
      }
    }

    if (pendingImportData.length === 0) {
      alert('No valid members found (require: name, gotra)');
      return;
    }

    // Display preview
    document.getElementById('preview-count').textContent = pendingImportData.length;
    const previewRows = document.getElementById('preview-rows');
    previewRows.innerHTML = pendingImportData.slice(0, 10).map(m => `
      <tr>
        <td class="border border-gray-300 px-2 py-1">${m.name}</td>
        <td class="border border-gray-300 px-2 py-1">${m.gotra}</td>
        <td class="border border-gray-300 px-2 py-1">${m.village}</td>
        <td class="border border-gray-300 px-2 py-1">
          ${m.isFamilyTreeOnly ? '<span class="text-xs bg-yellow-100 text-yellow-700 px-1 rounded">Tree Only</span>' : '<span class="text-xs bg-green-100 text-green-700 px-1 rounded">Samaj Member</span>'}
        </td>
        <td class="border border-gray-300 px-2 py-1">${m.spouseName || '—'}</td>
        <td class="border border-gray-300 px-2 py-1">F: ${m.fatherName || '—'}, M: ${m.motherName || '—'}</td>
      </tr>
    `).join('');

    if (pendingImportData.length > 10) {
      previewRows.innerHTML += `<tr><td colspan="4" class="border border-gray-300 px-2 py-1 text-center text-gray-600">+${pendingImportData.length - 10} more</td></tr>`;
    }

    document.getElementById('import-preview').classList.remove('hidden');
    document.getElementById('import-btn').disabled = false;
  }

  async function importMembers() {
    if (pendingImportData.length === 0) {
      alert('No data to import');
      return;
    }

    if (!confirm(`Import ${pendingImportData.length} members?`)) return;

    const btn = document.getElementById('import-btn');
    btn.disabled = true;
    btn.textContent = '⏳ Importing...';

    try {
      const response = await fetch('/admin/api/members/bulk-import', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ members: pendingImportData })
      });

      if (response.ok) {
        const result = await response.json();
        alert(`✅ Imported ${result.created} new members!\n${result.duplicates} duplicates skipped.`);
        closeMemberImport();
        location.reload();
      } else {
        const error = await response.json();
        alert('Import failed: ' + (error.error || 'Unknown error'));
      }
    } catch (err) {
      alert('Error: ' + err.message);
    } finally {
      btn.disabled = false;
      btn.textContent = '<i class="fas fa-check mr-1"></i> Import';
    }
  }

  // ========== DATA HEALTH DASHBOARD ==========
  async function checkDataHealth() {
    // We can reuse the duplicates modal markup for simplicity, or create a custom one!
    // Since we are adding it directly here:
    let modal = document.getElementById('data-health-modal');
    if (!modal) {
       document.body.insertAdjacentHTML('beforeend', `
       <div id="data-health-modal" class="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50">
          <div class="bg-white rounded-xl shadow-xl w-full max-w-4xl max-h-[90vh] overflow-hidden flex flex-col">
             <div class="px-6 py-4 border-b border-gray-200 flex justify-between items-center bg-teal-50">
                <h3 class="text-xl font-bold text-gray-800"><i class="fas fa-notes-medical text-teal-600 mr-2"></i> Data Health Dashboard</h3>
                <button onclick="document.getElementById('data-health-modal').classList.add('hidden')" class="text-gray-400 hover:text-gray-600 focus:outline-none">
                   <i class="fas fa-times text-xl"></i>
                </button>
             </div>
             <div class="p-6 overflow-y-auto" id="data-health-content">
                <p class="text-center text-gray-500 py-8"><i class="fas fa-spinner fa-spin mr-2"></i> Scanning database health...</p>
             </div>
          </div>
       </div>`);
       modal = document.getElementById('data-health-modal');
    }
    modal.classList.remove('hidden');

    try {
       const res = await fetch('/admin/api/data-health');
       const data = await res.json();
       
       if (!data.success) throw new Error(data.error);

       let html = '<div class="grid grid-cols-1 md:grid-cols-2 gap-6">';
       
       // Orphan Block
       html += `<div class="bg-red-50 rounded-lg p-4 border border-red-100">
           <h4 class="font-bold text-red-800 mb-2 border-b border-red-200 pb-2"><i class="fas fa-unlink mr-2"></i> Unlinked Members (Orphans) <span class="bg-red-200 text-red-800 text-xs px-2 py-0.5 rounded-full ml-2">${data.orphans.length}</span></h4>
           <p class="text-xs text-red-600 mb-3 block">These members have no family ties assigned.</p>
           <ul class="space-y-2 max-h-60 overflow-y-auto pr-2">
               ${data.orphans.map(o => `
                   <li class="flex justify-between items-center bg-white p-2 rounded text-sm shadow-sm border border-red-100">
                       <span class="font-medium text-gray-800">${o.name} <span class="text-xs text-gray-500">(${o.gotra})</span></span>
                       <a href="/admin/members/${o.id}/edit" target="_blank" class="text-blue-600 hover:text-blue-800 text-xs font-bold">Fix</a>
                   </li>`).join('') || '<p class="text-sm text-green-600"><i class="fas fa-check-circle"></i> No orphan members found.</p>'}
           </ul>
       </div>`;

       // Identical Names Block
       const dupes = data.identicalNames.filter(arr => arr.length > 1);
       html += `<div class="bg-orange-50 rounded-lg p-4 border border-orange-100">
           <h4 class="font-bold text-orange-800 mb-2 border-b border-orange-200 pb-2"><i class="fas fa-user-friends mr-2"></i> Identical Names <span class="bg-orange-200 text-orange-800 text-xs px-2 py-0.5 rounded-full ml-2">${dupes.length} groups</span></h4>
           <p class="text-xs text-orange-600 mb-3 block">Multiple members share the exact same Name + Gotra.</p>
           <ul class="space-y-4 max-h-60 overflow-y-auto pr-2">
               ${dupes.map(group => `
                   <li class="bg-white p-3 rounded text-sm shadow-sm border border-orange-100 flex flex-col gap-2">
                       ${group.map(o => `
                           <div class="flex justify-between items-center bg-gray-50 border border-gray-100 p-1.5 rounded">
                               <span class="font-medium text-gray-800">${o.name} <span class="text-xs text-gray-500">(${o.gotra})</span> <span class="text-[10px] text-gray-400 block">${o.id}</span></span>
                               <a href="/admin/members/${o.id}/edit" target="_blank" class="text-blue-600 hover:text-blue-800 text-xs font-bold bg-white px-2 py-1 rounded shadow-sm border border-gray-200">Edit</a>
                           </div>
                       `).join('')}
                   </li>`).join('') || '<p class="text-sm text-green-600"><i class="fas fa-check-circle"></i> No identical names found.</p>'}
           </ul>
       </div>`;

       html += '</div>';

       if (data.orphans.length === 0 && dupes.length === 0) {
           html = `<div class="text-center p-8 bg-green-50 rounded-xl border border-green-200">
             <i class="fas fa-check-circle text-5xl text-green-500 mb-4"></i>
             <h3 class="text-2xl font-bold text-green-800">Perfect Health!</h3>
             <p class="text-green-600 mt-2">No structural errors or duplicate names detected in the database.</p>
           </div>`;
       }

       document.getElementById('data-health-content').innerHTML = html;
    } catch(e) {
       document.getElementById('data-health-content').innerHTML = `<p class="text-red-500 text-center py-4">Error: ${e.message}</p>`;
    }
  }

  async function recalculateGenerations() {
    if (!confirm('\u0915्या आप सभी सदस्यों की पीढ़ी (generationLevel) पुनः गणना करना चाहते हैं?\n(Recalculate generations for all members from scratch?)')) return;
    
    const btn = document.querySelector('[onclick="recalculateGenerations()"]');
    const origText = btn.innerHTML;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i> Processing...';
    btn.disabled = true;
    
    try {
      const res = await fetch('/admin/api/members/recalculate-generations', { method: 'POST' });
      const ct = res.headers.get('content-type') || '';
      if (!ct.includes('application/json')) {
        alert('Session expired! Kripya dobara login karein.\n(Session expired, please re-login.)');
        window.location.href = '/admin/login';
        return;
      }
      const data = await res.json();
      if (data.ok) {
        alert(data.message);
      } else {
        alert('Error: ' + (data.error || 'Failed'));
      }
    } catch(e) {
      alert('Request failed: ' + e.message);
    } finally {
      btn.innerHTML = origText;
      btn.disabled = false;
    }
  }

</script>

