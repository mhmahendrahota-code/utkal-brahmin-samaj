<%- include('partials/admin-header') %>

<section class="py-12 bg-gray-50 flex-grow">
  <div class="container mx-auto px-4 max-w-6xl">
    
    <div class="flex justify-between items-center mb-6">
      <div>
        <h1 class="text-2xl font-bold text-gray-800"><a href="/admin" class="text-gray-400 hover:text-saffron-500 mr-2"><i class="fas fa-arrow-left text-lg"></i></a> Manage Members</h1>
        <p class="text-sm text-gray-500 mt-1">Total: <strong><%= members.length %></strong> members</p>
      </div>
      <div class="flex gap-2">
        <a href="/admin/members/export" class="bg-gray-600 hover:bg-gray-700 text-white px-4 py-2 rounded text-sm font-medium shadow-sm transition-colors inline-flex items-center">
          <i class="fas fa-file-csv mr-2"></i> Export CSV
        </a>
        <a href="/admin/members/add" class="bg-saffron-600 hover:bg-saffron-700 text-white px-4 py-2 rounded text-sm font-medium shadow-sm transition-colors inline-flex items-center">
          <i class="fas fa-user-plus mr-2"></i> Add Member
        </a>
      </div>
    </div>

    <div class="bg-white rounded-lg shadow-sm border border-gray-100 overflow-hidden">
      <div class="p-4 border-b border-gray-200 flex justify-between items-center bg-gray-50">
        <div class="relative w-80">
          <input type="text" id="member-search" placeholder="Search by name, gotra, village..." 
                 class="w-full pl-10 pr-4 py-2 rounded border border-gray-300 text-sm focus:ring-saffron-500 focus:border-saffron-500">
          <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
            <i class="fas fa-search text-gray-400"></i>
          </div>
        </div>
        <div class="text-sm text-gray-500" id="result-count"></div>
      </div>
      
      <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse" id="members-table">
          <thead>
            <tr class="bg-gray-50 text-gray-500 text-xs uppercase tracking-wider border-b border-gray-200">
              <th class="px-6 py-4 font-medium">Name</th>
              <th class="px-6 py-4 font-medium">Gotra</th>
              <th class="px-6 py-4 font-medium">Village</th>
              <th class="px-6 py-4 font-medium">Contact</th>
              <th class="px-6 py-4 font-medium">Family Links</th>
              <th class="px-6 py-4 font-medium">Status</th>
              <th class="px-6 py-4 font-medium text-right">Actions</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100 text-sm" id="members-tbody">
            <% if (members && members.length > 0) { %>
              <% members.forEach(member => { %>
                <tr class="hover:bg-gray-50 text-gray-700 member-row"
                    data-name="<%= member.name.toLowerCase() %>"
                    data-gotra="<%= (member.gotra || '').toLowerCase() %>"
                    data-village="<%= (member.village || '').toLowerCase() %>">
                  <td class="px-6 py-4 font-medium text-gray-900">
                    <div class="flex items-center">
                      <div class="w-8 h-8 rounded-full bg-saffron-100 text-saffron-600 flex items-center justify-center mr-3 font-bold flex-shrink-0"><%= member.name.charAt(0) %></div>
                      <div>
                        <div><%= member.name %></div>
                        <% if (member.honorific) { %><div class="text-xs text-gray-400"><%= member.honorific %></div><% } %>
                      </div>
                    </div>
                  </td>
                  <td class="px-6 py-4"><%= member.gotra || '—' %></td>
                  <td class="px-6 py-4"><%= member.village || '—' %></td>
                  <td class="px-6 py-4"><%= member.contactNumber || '—' %></td>
                  <td class="px-6 py-4">
                    <div class="flex flex-wrap gap-1">
                      <% if (member.father) { %><span class="text-xs bg-blue-50 text-blue-600 px-1.5 py-0.5 rounded">Has Father</span><% } %>
                      <% if (member.mother) { %><span class="text-xs bg-purple-50 text-purple-600 px-1.5 py-0.5 rounded">Has Mother</span><% } %>
                      <% if (member.spouse) { %><span class="text-xs bg-pink-50 text-pink-600 px-1.5 py-0.5 rounded">Married</span><% } %>
                      <% if (member.children && member.children.length > 0) { %><span class="text-xs bg-green-50 text-green-600 px-1.5 py-0.5 rounded font-medium"><%= member.children.length %> Child<%= member.children.length > 1 ? 'ren' : '' %></span><% } %>
                      <% if (!member.father && !member.mother && !member.spouse && (!member.children || member.children.length === 0)) { %><span class="text-xs text-gray-400">—</span><% } %>
                    </div>
                  </td>
                  <td class="px-6 py-4">
                    <div class="flex flex-wrap gap-1">
                      <% if(member.isDeceased) { %><span class="bg-gray-100 text-gray-600 px-2 py-1 rounded text-xs font-medium">स्वर्गीय</span><% } %>
                      <% if(member.isCommitteeMember) { %><span class="bg-saffron-100 text-saffron-700 px-2 py-1 rounded text-xs font-medium">Committee</span><% } %>
                      <% if(member.isFamilyTreeOnly) { %><span class="bg-yellow-100 text-yellow-700 px-2 py-1 rounded text-xs font-medium">Tree Only</span><% } %>
                      <% if(!member.isDeceased && !member.isCommitteeMember && !member.isFamilyTreeOnly) { %><span class="bg-green-100 text-green-700 px-2 py-1 rounded text-xs font-medium">Active</span><% } %>
                    </div>
                  </td>
                  <td class="px-6 py-4 text-right whitespace-nowrap">
                    <a href="/members/<%= member._id %>" target="_blank" class="text-gray-400 hover:text-gray-600 mx-1" title="View Profile"><i class="fas fa-eye"></i></a>
                    <a href="/admin/members/<%= member._id %>/edit" class="text-blue-500 hover:text-blue-700 mx-1" title="Edit"><i class="fas fa-edit"></i></a>
                    <!-- Delete button triggers modal -->
                    <button type="button" 
                            class="text-red-400 hover:text-red-600 mx-1 delete-btn" 
                            title="Delete"
                            data-id="<%= member._id %>"
                            data-name="<%= member.name %>"
                            data-children='<%= JSON.stringify((member.children || []).length) %>'
                            data-has-father="<%= !!member.father %>"
                            data-has-mother="<%= !!member.mother %>"
                            data-has-spouse="<%= !!member.spouse %>">
                      <i class="fas fa-trash-alt"></i>
                    </button>
                  </td>
                </tr>
              <% }) %>
            <% } else { %>
              <tr>
                <td colspan="7" class="px-6 py-8 text-center text-gray-500">No members found. <a href="/admin/members/add" class="text-saffron-600 font-medium">Add one now →</a></td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</section>

<!-- Delete Confirmation Modal -->
<div id="delete-modal" class="fixed inset-0 bg-black/50 backdrop-blur-sm z-50 flex items-center justify-center hidden">
  <div class="bg-white rounded-2xl shadow-2xl w-full max-w-md mx-4 overflow-hidden">
    <div class="bg-red-50 border-b border-red-100 px-6 py-4 flex items-center gap-3">
      <div class="w-10 h-10 rounded-full bg-red-100 flex items-center justify-center flex-shrink-0">
        <i class="fas fa-exclamation-triangle text-red-600"></i>
      </div>
      <div>
        <h3 class="font-bold text-gray-900 text-lg">Delete Member?</h3>
        <p class="text-sm text-gray-500">This action cannot be undone.</p>
      </div>
    </div>
    <div class="px-6 py-5">
      <p class="text-gray-700">You are about to delete: <strong id="modal-member-name" class="text-gray-900"></strong></p>
      
      <div id="modal-impact" class="mt-4 hidden">
        <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
          <p class="text-sm font-semibold text-amber-800 mb-2"><i class="fas fa-sitemap mr-1"></i> Family Tree Impact:</p>
          <ul id="modal-impact-list" class="text-sm text-amber-700 space-y-1 list-disc list-inside"></ul>
        </div>
        <p class="text-xs text-gray-500 mt-3">All broken links will be automatically cleaned up. Children will appear as root-level ancestors in the family tree.</p>
      </div>
    </div>
    <div class="px-6 pb-5 flex gap-3 justify-end">
      <button type="button" id="modal-cancel" class="px-5 py-2 rounded-lg border border-gray-300 text-gray-700 hover:bg-gray-50 font-medium transition-colors">
        Cancel
      </button>
      <form id="delete-form" method="POST" action="">
        <button type="submit" class="px-5 py-2 rounded-lg bg-red-600 hover:bg-red-700 text-white font-medium transition-colors">
          <i class="fas fa-trash-alt mr-1"></i> Yes, Delete
        </button>
      </form>
    </div>
  </div>
</div>

<script>
  // Live Search
  const searchInput = document.getElementById('member-search');
  const rows = document.querySelectorAll('.member-row');
  const resultCount = document.getElementById('result-count');

  function updateSearch() {
    const term = searchInput.value.toLowerCase().trim();
    let visible = 0;
    rows.forEach(row => {
      const match = !term || 
        row.dataset.name.includes(term) || 
        row.dataset.gotra.includes(term) || 
        row.dataset.village.includes(term);
      row.style.display = match ? '' : 'none';
      if (match) visible++;
    });
    resultCount.textContent = term ? `${visible} of ${rows.length} shown` : '';
  }
  searchInput.addEventListener('input', updateSearch);

  // Delete Modal
  const modal = document.getElementById('delete-modal');
  const modalName = document.getElementById('modal-member-name');
  const modalImpact = document.getElementById('modal-impact');
  const modalImpactList = document.getElementById('modal-impact-list');
  const deleteForm = document.getElementById('delete-form');
  const cancelBtn = document.getElementById('modal-cancel');

  document.querySelectorAll('.delete-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const id = btn.dataset.id;
      const name = btn.dataset.name;
      const childCount = parseInt(btn.dataset.children) || 0;
      const hasFather = btn.dataset.hasFather === 'true';
      const hasMother = btn.dataset.hasMother === 'true';
      const hasSpouse = btn.dataset.hasSpouse === 'true';

      modalName.textContent = name;
      deleteForm.action = `/admin/members/${id}/delete`;

      // Build impact list
      const impacts = [];
      if (childCount > 0) impacts.push(`${childCount} child member${childCount > 1 ? 's' : ''} will lose their parent link`);
      if (hasFather) impacts.push(`Father's children list will be updated`);
      if (hasMother) impacts.push(`Mother's children list will be updated`);
      if (hasSpouse) impacts.push(`Spouse link will be removed`);

      if (impacts.length > 0) {
        modalImpactList.innerHTML = impacts.map(i => `<li>${i}</li>`).join('');
        modalImpact.classList.remove('hidden');
      } else {
        modalImpact.classList.add('hidden');
      }

      modal.classList.remove('hidden');
    });
  });

  cancelBtn.addEventListener('click', () => modal.classList.add('hidden'));
  modal.addEventListener('click', e => { if (e.target === modal) modal.classList.add('hidden'); });
</script>

<%- include('partials/admin-footer') %>
