<%- include('partials/admin-header') %>

<style>
  /* Data Quality Highlighting */
  .member-row[data-quality-score="100"],
  .member-row[data-quality-score="90"],
  .member-row[data-quality-score="80"] {
    background-color: transparent;
  }
  
  .member-row[data-quality-score^="7"],
  .member-row[data-quality-score="60"] {
    background-color: #fef3c7;
  }
  
  .member-row[data-quality-score^="5"],
  .member-row[data-quality-score^="4"],
  .member-row[data-quality-score^="3"],
  .member-row[data-quality-score^="2"],
  .member-row[data-quality-score^="1"],
  .member-row[data-quality-score="0"] {
    background-color: #fee2e2;
    border-left: 4px solid #dc2626;
  }
  
  .member-row.hidden {
    display: none !important;
  }
  
  /* Link styling for data attributes */
  tr[data-quality-score] {
    position: relative;
  }
</style>

<section class="py-12 bg-gray-50 flex-grow">
  <div class="container mx-auto px-4 max-w-6xl">
    
    <div class="flex justify-between items-center mb-6">
      <div>
        <h1 class="text-2xl font-bold text-gray-800"><a href="/admin" class="text-gray-400 hover:text-saffron-500 mr-2"><i class="fas fa-arrow-left text-lg"></i></a> Manage Members</h1>
        <p class="text-sm text-gray-500 mt-1">Total: <strong><%= members.length %></strong> members</p>
      </div>
      <div class="flex gap-2">
        <button type="button" onclick="openMemberImport()" class="bg-indigo-600 hover:bg-indigo-700 text-white px-4 py-2 rounded text-sm font-medium shadow-sm transition-colors inline-flex items-center">
          <i class="fas fa-upload mr-2"></i> Import Members
        </button>
        <button type="button" onclick="checkDataHealth()" class="bg-teal-600 hover:bg-teal-700 text-white px-4 py-2 rounded text-sm font-medium shadow-sm transition-colors inline-flex items-center">
          <i class="fas fa-notes-medical mr-2"></i> Data Health
        </button>
        <button type="button" onclick="recalculateGenerations()" class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded text-sm font-medium shadow-sm transition-colors inline-flex items-center" title="पीढ़ी (Generation) सभी सदस्यों के लिए Recalculate करें">
          <i class="fas fa-layer-group mr-2"></i> Recalculate पीढ़ी
        </button>
        <button type="button" onclick="checkDuplicates()" class="bg-purple-600 hover:bg-purple-700 text-white px-4 py-2 rounded text-sm font-medium shadow-sm transition-colors inline-flex items-center">
          <i class="fas fa-copy mr-2"></i> Check Duplicates
        </button>
        <a href="/admin/members/export" class="bg-gray-600 hover:bg-gray-700 text-white px-4 py-2 rounded text-sm font-medium shadow-sm transition-colors inline-flex items-center">
          <i class="fas fa-file-csv mr-2"></i> Export CSV
        </a>
        <a href="/admin/members/add" class="bg-saffron-600 hover:bg-saffron-700 text-white px-4 py-2 rounded text-sm font-medium shadow-sm transition-colors inline-flex items-center">
          <i class="fas fa-user-plus mr-2"></i> Add Member
        </a>
      </div>
    </div>

    <!-- Quick Stats Dashboard -->
    <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-8 gap-3 mb-6" id="stats-container">
      <div class="bg-white rounded-lg shadow-sm border border-gray-100 p-4">
        <div class="text-xs text-gray-500 font-medium uppercase">Total</div>
        <div class="text-2xl font-bold text-gray-900" id="stat-total">-</div>
      </div>
      <div class="bg-white rounded-lg shadow-sm border border-gray-100 p-4">
        <div class="text-xs text-gray-500 font-medium uppercase">Approved</div>
        <div class="text-2xl font-bold text-green-600" id="stat-approved">-</div>
      </div>
      <div class="bg-white rounded-lg shadow-sm border border-gray-100 p-4">
        <div class="text-xs text-gray-500 font-medium uppercase">Pending</div>
        <div class="text-2xl font-bold text-orange-600" id="stat-pending">-</div>
      </div>
      <div class="bg-white rounded-lg shadow-sm border border-gray-100 p-4">
        <div class="text-xs text-gray-500 font-medium uppercase">Incomplete</div>
        <div class="text-2xl font-bold text-red-600" id="stat-incomplete">-</div>
      </div>
      <div class="bg-white rounded-lg shadow-sm border border-gray-100 p-4">
        <div class="text-xs text-gray-500 font-medium uppercase">Matrimonial</div>
        <div class="text-2xl font-bold text-pink-600" id="stat-matrimonial">-</div>
      </div>
      <div class="bg-white rounded-lg shadow-sm border border-gray-100 p-4">
        <div class="text-xs text-gray-500 font-medium uppercase">Committee</div>
        <div class="text-2xl font-bold text-saffron-600" id="stat-committee">-</div>
      </div>
      <div class="bg-white rounded-lg shadow-sm border border-gray-100 p-4">
        <div class="text-xs text-gray-500 font-medium uppercase">Deceased</div>
        <div class="text-2xl font-bold text-gray-600" id="stat-deceased">-</div>
      </div>
      <div class="bg-white rounded-lg shadow-sm border border-gray-100 p-4">
        <div class="text-xs text-gray-500 font-medium uppercase">Family Links</div>
        <div class="text-2xl font-bold text-blue-600" id="stat-family">-</div>
      </div>
    </div>

    <div class="bg-white rounded-lg shadow-sm border border-gray-100 overflow-hidden">
      <div class="p-4 border-b border-gray-200 space-y-3">
        <!-- Search Bar & Controls -->
        <div class="flex gap-2 items-end">
          <div class="relative flex-grow">
            <input type="text" id="member-search" placeholder="Search by name, gotra, village..." 
                   class="w-full pl-10 pr-4 py-2 rounded border border-gray-300 text-sm focus:ring-saffron-500 focus:border-saffron-500">
            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
              <i class="fas fa-search text-gray-400"></i>
            </div>
          </div>
          <button type="button" onclick="toggleAdvancedFilters()" class="px-4 py-2 bg-gray-200 hover:bg-gray-300 rounded text-sm font-medium">
            <i class="fas fa-filter mr-1"></i> Filters
          </button>
          <span class="text-sm text-gray-500" id="result-count"></span>
        </div>

        <!-- Advanced Filters (Hidden by default) -->
        <div id="advanced-filters" class="hidden grid grid-cols-2 md:grid-cols-4 gap-3 pt-3 pb-2 border-t border-gray-200">
          <!-- Status Filter -->
          <div>
            <label class="text-xs font-medium text-gray-600">Approval Status</label>
            <select id="filter-status" onchange="applyFilters()" class="w-full mt-1 px-2 py-1 text-xs border border-gray-300 rounded">
              <option value="">All Statuses</option>
              <option value="approved">✓ Approved</option>
              <option value="pending">⏳ Pending</option>
            </select>
          </div>

          <!-- Family Filter -->
          <div>
            <label class="text-xs font-medium text-gray-600">Family Links</label>
            <select id="filter-family" onchange="applyFilters()" class="w-full mt-1 px-2 py-1 text-xs border border-gray-300 rounded">
              <option value="">All Members</option>
              <option value="has-father">Has Father</option>
              <option value="has-mother">Has Mother</option>
              <option value="has-spouse">Has Spouse</option>
              <option value="has-children">Has Children</option>
              <option value="no-links">No Family Links</option>
            </select>
          </div>

          <!-- Committee Filter -->
          <div>
            <label class="text-xs font-medium text-gray-600">Committee</label>
            <select id="filter-committee" onchange="applyFilters()" class="w-full mt-1 px-2 py-1 text-xs border border-gray-300 rounded">
              <option value="">All Members</option>
              <option value="committee">Committee Members</option>
              <option value="non-committee">Non-Committee</option>
            </select>
          </div>

          <!-- Data Quality Filter -->
          <div>
            <label class="text-xs font-medium text-gray-600">Data Quality</label>
            <select id="filter-quality" onchange="applyFilters()" class="w-full mt-1 px-2 py-1 text-xs border border-gray-300 rounded">
              <option value="">All Statuses</option>
              <option value="excellent">⭐ Excellent (80%+)</option>
              <option value="good">✓ Good (60-79%)</option>
              <option value="incomplete">⚠️ Incomplete (&lt;60%)</option>
            </select>
          </div>
        </div>
        
        <!-- Bulk Actions Bar (hidden by default) -->
        <div id="bulk-actions-bar" class="hidden flex gap-2 items-center p-3 bg-saffron-50 border border-saffron-200 rounded">
          <span id="selected-count" class="text-sm font-medium text-gray-700">0 selected</span>
          <div class="flex-grow"></div>
          <button type="button" onclick="bulkUpdateStatus()" class="px-3 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded text-sm font-medium inline-flex items-center transition-colors">
            <i class="fas fa-check-circle mr-1"></i> Approve
          </button>
          <button type="button" onclick="bulkRejectStatus()" class="px-3 py-2 bg-orange-600 hover:bg-orange-700 text-white rounded text-sm font-medium inline-flex items-center transition-colors">
            <i class="fas fa-times-circle mr-1"></i> Reject
          </button>
          <button type="button" onclick="bulkDelete()" class="px-3 py-2 bg-red-600 hover:bg-red-700 text-white rounded text-sm font-medium inline-flex items-center transition-colors">
            <i class="fas fa-trash-alt mr-1"></i> Delete
          </button>
          <button type="button" onclick="clearSelection()" class="px-3 py-2 bg-gray-400 hover:bg-gray-500 text-white rounded text-sm font-medium transition-colors">
            Clear
          </button>
        </div>
      </div>
      
      <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse" id="members-table">
          <thead>
            <tr class="bg-gray-50 text-gray-500 text-xs uppercase tracking-wider border-b border-gray-200">
              <th class="px-4 py-4 font-medium w-10">
                <input type="checkbox" id="select-all" onchange="toggleSelectAll()" class="rounded border-gray-300 cursor-pointer">
              </th>
              <th class="px-6 py-4 font-medium cursor-pointer hover:bg-gray-100" onclick="sortTable('name')">
                Name <span class="text-xs" id="sort-name"></span>
              </th>
              <th class="px-6 py-4 font-medium cursor-pointer hover:bg-gray-100" onclick="sortTable('gotra')">
                Gotra <span class="text-xs" id="sort-gotra"></span>
              </th>
              <th class="px-6 py-4 font-medium cursor-pointer hover:bg-gray-100" onclick="sortTable('village')">
                Village <span class="text-xs" id="sort-village"></span>
              </th>
              <th class="px-6 py-4 font-medium cursor-pointer hover:bg-gray-100" onclick="sortTable('contact')">
                Contact <span class="text-xs" id="sort-contact"></span>
              </th>
              <th class="px-6 py-4 font-medium">Family Links</th>
              <th class="px-4 py-4 font-medium text-center cursor-pointer hover:bg-gray-100" onclick="sortTable('gen')" title="पीढ़ी (Generation Level)">Gen <span class="text-xs" id="sort-gen"></span></th>
              <th class="px-6 py-4 font-medium">Status</th>
              <th class="px-6 py-4 font-medium text-right">Actions</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100 text-sm" id="members-tbody">
            <% if (members && members.length > 0) { %>
              <% members.forEach(member => { %>
                <%
                  // Calculate data quality score (0-100)
                  let qualityScore = 0;
                  let missingFields = [];
                  if (member.name) qualityScore += 20; else missingFields.push('name');
                  if (member.gotra) qualityScore += 20; else missingFields.push('gotra');
                  if (member.village) qualityScore += 20; else missingFields.push('village');
                  if (member.contactNumber) qualityScore += 15; else missingFields.push('contact');
                  if (member.surname) qualityScore += 15; else missingFields.push('surname');
                  if (member.isApproved) qualityScore += 10; else missingFields.push('approval');
                %>
                <tr class="hover:bg-gray-50 text-gray-700 member-row <%= qualityScore < 60 ? 'bg-red-50 border-l-4 border-red-300' : '' %>"
                    data-id="<%= member._id %>"
                    data-name="<%= (member.name + ' ' + (member.surname || '')).toLowerCase() %>"
                    data-gotra="<%= (member.gotra || '').toLowerCase() %>"
                    data-village="<%= (member.village || '').toLowerCase() %>"
                    data-approved="<%= member.isApproved ? 'yes' : 'no' %>"
                    data-has-father="<%= member.father ? 'yes' : 'no' %>"
                    data-has-mother="<%= member.mother ? 'yes' : 'no' %>"
                    data-has-spouse="<%= member.spouse ? 'yes' : 'no' %>"
                    data-has-children="<%= (member.children && member.children.length > 0) ? 'yes' : 'no' %>"
                    data-is-committee="<%= member.isCommitteeMember ? 'yes' : 'no' %>"
                    data-is-complete="<%= (member.name && member.gotra && member.village) ? 'yes' : 'no' %>"
                    data-is-deceased="<%= member.isDeceased ? 'yes' : 'no' %>"
                    data-children='<%= JSON.stringify((member.children || []).length) %>'
                    data-quality-score="<%= qualityScore %>"
                    data-missing-fields="<%= missingFields.join(',') %>"
                    title="Data Quality: <%= qualityScore %>% complete<% if (missingFields.length > 0) { %>. Missing: <%= missingFields.join(', ') %><% } %>">
                  <td class="px-4 py-4">
                    <input type="checkbox" class="member-checkbox rounded border-gray-300 cursor-pointer" data-id="<%= member._id %>" onchange="updateBulkActions()">
                  </td>
                  <td class="px-6 py-4 font-medium text-gray-900">
                    <div class="flex items-center">
                      <div class="w-8 h-8 rounded-full bg-saffron-100 text-saffron-600 flex items-center justify-center mr-3 font-bold flex-shrink-0"><%= member.name.charAt(0) %></div>
                      <div class="flex-grow">
                        <div class="flex items-baseline gap-1">
                          <span><%= member.name %></span>
                          <% if (member.surname) { %><span class="text-saffron-700 font-bold"><%= member.surname %></span><% } %>
                          <% if (qualityScore < 80) { %>
                            <span class="<%= qualityScore < 60 ? 'text-red-600' : 'text-yellow-600' %> text-lg" title="Missing: <%= missingFields.join(', ') %>">
                              <% if (qualityScore < 60) { %>
                                <i class="fas fa-exclamation-triangle"></i>
                              <% } else { %>
                                <i class="fas fa-info-circle"></i>
                              <% } %>
                            </span>
                          <% } %>
                        </div>
                        <% if (member.honorific) { %><div class="text-xs text-gray-400"><%= member.honorific %></div><% } %>
                      </div>
                    </div>
                  </td>
                  <td class="px-6 py-4"><% if (!member.gotra) { %><span class="text-red-600 font-medium flex items-center gap-1"><i class="fas fa-exclamation-circle"></i> Gotra missing</span><% } else { %><%= member.gotra %><% } %></td>
                  <td class="px-6 py-4"><% if (!member.village) { %><span class="text-red-600 font-medium flex items-center gap-1"><i class="fas fa-exclamation-circle"></i> Village missing</span><% } else { %><%= member.village %><% } %></td>
                  <td class="px-6 py-4"><% if (!member.contactNumber) { %><span class="text-yellow-600">—</span><% } else { %><%= member.contactNumber %><% } %></td>
                  <td class="px-6 py-4">
                    <div class="flex flex-wrap gap-1">
                      <% if (member.father) { %><span class="text-xs bg-blue-50 text-blue-600 px-1.5 py-0.5 rounded">Has Father</span><% } %>
                      <% if (member.mother) { %><span class="text-xs bg-purple-50 text-purple-600 px-1.5 py-0.5 rounded">Has Mother</span><% } %>
                      <% if (member.spouse) { %><span class="text-xs bg-pink-50 text-pink-600 px-1.5 py-0.5 rounded">Married</span><% } %>
                      <% if (member.children && member.children.length > 0) { %><span class="text-xs bg-green-50 text-green-600 px-1.5 py-0.5 rounded font-medium"><%= member.children.length %> Child<%= member.children.length > 1 ? 'ren' : '' %></span><% } %>
                      <% if (!member.father && !member.mother && !member.spouse && (!member.children || member.children.length === 0)) { %><span class="text-xs text-gray-400">—</span><% } %>
                    </div>
                  </td>
                  <td class="px-4 py-4 text-center">
                    <% if (member.generationLevel !== null && member.generationLevel !== undefined) { %>
                      <span class="inline-flex items-center justify-center w-8 h-8 rounded-full text-xs font-bold
                        <%= member.generationLevel === 0 ? 'bg-indigo-100 text-indigo-700 ring-2 ring-indigo-300' : 
                           member.generationLevel <= 2 ? 'bg-blue-50 text-blue-700' : 
                           member.generationLevel <= 4 ? 'bg-green-50 text-green-700' : 
                           'bg-gray-100 text-gray-600' %>" 
                        title="पीढ़ी <%= member.generationLevel %> (Generation Level)">
                        <%= member.generationLevel %>
                      </span>
                    <% } else { %>
                      <span class="text-gray-300" title="Not calculated yet">—</span>
                    <% } %>
                  </td>
                  <td class="px-6 py-4">
                    <div class="flex flex-wrap gap-1 items-center">
                      <% if(member.isDeceased) { %><span class="bg-gray-100 text-gray-600 px-2 py-1 rounded text-xs font-medium">स्वर्गीय</span><% } %>
                      <% if(member.isCommitteeMember) { %><span class="bg-saffron-100 text-saffron-700 px-2 py-1 rounded text-xs font-medium">Committee</span><% } %>
                      <% if(member.isFamilyTreeOnly) { %><span class="bg-yellow-100 text-yellow-700 px-2 py-1 rounded text-xs font-medium">Tree Only</span><% } %>
                      <% if(!member.isDeceased && !member.isCommitteeMember && !member.isFamilyTreeOnly) { %><span class="bg-green-100 text-green-700 px-2 py-1 rounded text-xs font-medium">Active</span><% } %>
                      
                      <!-- Data Quality Badge -->
                      <% if (qualityScore >= 80) { %>
                        <span class="bg-green-50 text-green-700 px-2 py-1 rounded text-xs font-medium" title="Complete profile"><i class="fas fa-check-circle mr-1"></i><%= qualityScore %>%</span>
                      <% } else if (qualityScore >= 60) { %>
                        <span class="bg-yellow-50 text-yellow-700 px-2 py-1 rounded text-xs font-medium" title="Partially complete: missing <%= missingFields.join(', ') %>"><i class="fas fa-exclamation-circle mr-1"></i><%= qualityScore %>%</span>
                      <% } else { %>
                        <span class="bg-red-50 text-red-700 px-2 py-1 rounded text-xs font-medium" title="Incomplete profile: missing <%= missingFields.join(', ') %>"><i class="fas fa-times-circle mr-1"></i><%= qualityScore %>%</span>
                      <% } %>
                    </div>
                  </td>
                  <td class="px-6 py-4 text-right whitespace-nowrap">
                    <a href="/members/<%= member._id %>" target="_blank" class="text-gray-400 hover:text-gray-600 mx-1" title="View Profile"><i class="fas fa-eye"></i></a>
                    <a href="/admin/members/<%= member._id %>/edit" class="text-blue-500 hover:text-blue-700 mx-1" title="Edit"><i class="fas fa-edit"></i></a>
                    <button type="button" onclick="openRelationshipManager('<%= member._id %>', '<%= member.name %>')" class="text-green-500 hover:text-green-700 mx-1" title="Manage Relationships"><i class="fas fa-sitemap"></i></button>
                    <!-- Delete button triggers modal -->
                    <button type="button" 
                            class="text-red-400 hover:text-red-600 mx-1 delete-btn" 
                            title="Delete"
                            data-id="<%= member._id %>"
                            data-name="<%= member.name %>"
                            data-children='<%= JSON.stringify((member.children || []).length) %>'
                            data-has-father="<%= !!member.father %>"
                            data-has-mother="<%= !!member.mother %>"
                            data-has-spouse="<%= !!member.spouse %>">
                      <i class="fas fa-trash-alt"></i>
                    </button>
                  </td>
                </tr>
              <% }) %>
            <% } else { %>
              <tr>
                <td colspan="7" class="px-6 py-8 text-center text-gray-500">No members found. <a href="/admin/members/add" class="text-saffron-600 font-medium">Add one now →</a></td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
      
      <!-- Pagination Controls -->
      <div class="p-4 border-t border-gray-200 flex items-center justify-between">
        <div class="text-sm text-gray-600">
          Showing <span id="showing-start">1</span>-<span id="showing-end">10</span> of <span id="total-rows"><%= members.length %></span> members
        </div>
        
        <div class="flex gap-2 items-center">
          <label class="text-sm text-gray-600">Rows per page:</label>
          <select id="rows-per-page" onchange="changeRowsPerPage()" class="px-2 py-1 text-sm border border-gray-300 rounded">
            <option value="10">10</option>
            <option value="25" selected>25</option>
            <option value="50">50</option>
            <option value="100">100</option>
          </select>
        </div>
        
        <div class="flex gap-1">
          <button type="button" id="prev-btn" onclick="prevPage()" class="px-3 py-2 bg-gray-100 hover:bg-gray-200 rounded text-sm font-medium transition-colors">
            <i class="fas fa-chevron-left mr-1"></i> Previous
          </button>
          <span id="page-numbers" class="flex gap-1"></span>
          <button type="button" id="next-btn" onclick="nextPage()" class="px-3 py-2 bg-gray-100 hover:bg-gray-200 rounded text-sm font-medium transition-colors">
            Next <i class="fas fa-chevron-right ml-1"></i>
          </button>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Duplicates Modal -->
<div id="duplicates-modal" class="fixed inset-0 bg-black/50 backdrop-blur-sm z-50 flex items-center justify-center hidden">
  <div class="bg-white rounded-2xl shadow-2xl w-full max-w-2xl mx-4 max-h-screen overflow-y-auto">
    <div class="bg-purple-50 border-b border-purple-100 px-6 py-4 flex items-center justify-between sticky top-0">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 rounded-full bg-purple-100 flex items-center justify-center flex-shrink-0">
          <i class="fas fa-copy text-purple-600"></i>
        </div>
        <div>
          <h3 class="font-bold text-gray-900 text-lg">Potential Duplicates</h3>
          <p class="text-sm text-gray-500">Review and merge similar member records</p>
        </div>
      </div>
      <button type="button" onclick="closeDuplicatesModal()" class="text-gray-400 hover:text-gray-600 text-2xl">×</button>
    </div>
    
    <div class="px-6 py-4">
      <div id="duplicates-loading" class="text-center py-8">
        <i class="fas fa-spinner fa-spin text-purple-600 text-3xl"></i>
        <p class="text-gray-600 mt-2">Scanning for duplicates...</p>
      </div>
      
      <div id="duplicates-content" class="hidden space-y-4">
        <div id="duplicates-list"></div>
      </div>
      
      <div id="duplicates-error" class="hidden text-center py-8">
        <i class="fas fa-exclamation-circle text-red-600 text-3xl"></i>
        <p id="duplicates-error-text" class="text-gray-600 mt-2"></p>
      </div>
    </div>
    
    <div class="border-t border-gray-200 bg-gray-50 px-6 py-4 flex gap-3 justify-end">
      <button type="button" onclick="closeDuplicatesModal()" class="px-5 py-2 rounded-lg border border-gray-300 text-gray-700 hover:bg-gray-100 font-medium transition-colors">
        Close
      </button>
    </div>
  </div>
</div>

<!-- Member Import Modal -->
<div id="member-import-modal" class="fixed inset-0 bg-black/50 backdrop-blur-sm z-50 flex items-center justify-center hidden">
  <div class="bg-white rounded-2xl shadow-2xl w-full max-w-3xl mx-4 max-h-screen overflow-y-auto">
    <div class="bg-indigo-50 border-b border-indigo-100 px-6 py-4 flex items-center justify-between sticky top-0">
