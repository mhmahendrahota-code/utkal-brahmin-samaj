<%- include('partials/admin-header') %>

<div class="flex-grow max-w-4xl mx-auto w-full px-4 py-8">
  <div class="flex items-center mb-6">
    <a href="/admin/documents" class="text-gray-400 hover:text-saffron-500 mr-3 transition-colors">
      <i class="fas fa-arrow-left text-xl"></i>
    </a>
    <h1 class="text-3xl font-bold text-gray-800">Upload Document</h1>
  </div>

  <div class="bg-white rounded-lg shadow-sm border border-gray-100 overflow-hidden">
    <div class="p-8">
      <form action="/admin/documents/add" method="POST" class="space-y-6">
        
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Document Title *</label>
          <input type="text" name="title" required placeholder="e.g. Annual General Meeting Minutes (March 2026)" class="w-full border-gray-300 rounded focus:ring-saffron-500 focus:border-saffron-500 px-3 py-2 border shadow-sm">
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Category *</label>
            <select name="category" required class="w-full border-gray-300 rounded focus:ring-saffron-500 focus:border-saffron-500 px-3 py-2 border shadow-sm bg-white">
              <option value="Rules & Constitution">Rules & Constitution (Vidhan)</option>
              <option value="Meeting Minutes">Meeting Minutes (Karyavahi)</option>
              <option value="Financial Reports">Financial Reports (Aay-Vyay)</option>
              <option value="General Notice">General Notice</option>
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">File URL / Link *</label>
            <input type="url" name="fileUrl" required placeholder="https://drive.google.com/..." class="w-full border-gray-300 rounded focus:ring-saffron-500 focus:border-saffron-500 px-3 py-2 border shadow-sm">
            <p class="text-xs text-gray-500 mt-1">Paste a link to a Google Drive PDF or any public file hosting link.</p>
          </div>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Short Description (Optional)</label>
          <textarea name="description" rows="3" class="w-full border-gray-300 rounded focus:ring-saffron-500 focus:border-saffron-500 px-3 py-2 border shadow-sm" placeholder="Brief summary of the document's contents..."></textarea>
        </div>

        <div class="flex justify-end pt-4 border-t">
          <a href="/admin/documents" class="bg-white border border-gray-300 text-gray-700 hover:bg-gray-50 font-bold py-2 px-6 rounded mr-3 shadow-sm transition-colors">
            Cancel
          </a>
          <button type="submit" class="bg-saffron-600 hover:bg-saffron-700 text-white font-bold py-2 px-6 rounded shadow-sm transition-colors flex items-center">
            <i class="fas fa-upload mr-2"></i> Save & Publish
          </button>
        </div>

      </form>
    </div>
  </div>
</div>

<%- include('partials/admin-footer') %>
