<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | Admin Portal - Utkal Brahmin Samaj</title>

  <!-- Tailwind CSS -->
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            admin: {
              800: '#1e293b',
              900: '#0f172a',
            },
            saffron: {
              100: '#FFF0E6',
              500: '#FF9933',
              600: '#E68A2E',
              900: '#804C19'
            }
          },
          fontFamily: {
            sans: ['Inter', 'sans-serif'],
          }
        }
      }
    }
  </script>

  <!-- Google Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <!-- FontAwesome -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  
  <style>
    body { font-family: 'Inter', sans-serif; }
    
    /* Scrollbar styling for a cleaner CMS feel */
    ::-webkit-scrollbar { width: 6px; height: 6px; }
    ::-webkit-scrollbar-track { background: #f1f5f9; }
    ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 3px; }
    ::-webkit-scrollbar-thumb:hover { background: #94a3b8; }
  </style>
</head>

<body class="bg-slate-50 flex flex-col min-h-screen text-slate-800">

  <!-- Admin Top Navigation Bar -->
  <nav class="bg-admin-900 shadow-xl sticky top-0 z-50">
    <div class="px-4 mx-auto max-w-7xl sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-16">
        
        <!-- Brand / Identity -->
        <div class="flex items-center flex-shrink-0">
          <a href="/admin" class="flex items-center gap-3 group">
            <div class="w-8 h-8 rounded-full bg-saffron-500 flex items-center justify-center text-white shadow-md">
              <i class="fas fa-shield-alt text-sm"></i>
            </div>
            <div>
              <span class="text-white font-bold text-lg tracking-wide group-hover:text-saffron-100 transition-colors">Admin CMS</span>
            </div>
          </a>
        </div>
        
        <!-- Desktop Links (The 7 Modules) -->
        <div class="hidden lg:block">
          <div class="flex items-center space-x-1 ml-10">
            <a href="/admin" class="text-slate-300 hover:bg-admin-800 hover:text-white px-3 py-2 rounded-md text-sm font-medium transition-colors">
              <i class="fas fa-chart-line mr-1.5 opacity-70"></i> Dashboard
            </a>
            
            <a href="/admin/announcements" class="text-slate-300 hover:bg-admin-800 hover:text-white px-3 py-2 rounded-md text-sm font-medium transition-colors" title="Manage Home Page Updates">
              <i class="fas fa-home mr-1.5 opacity-70"></i> Home
            </a>

            <a href="/admin/members" class="text-slate-300 hover:bg-admin-800 hover:text-white px-3 py-2 rounded-md text-sm font-medium transition-colors">
              <i class="fas fa-address-book mr-1.5 opacity-70"></i> Directory
            </a>

            <a href="/admin/surnames" class="text-slate-300 hover:bg-admin-800 hover:text-white px-3 py-2 rounded-md text-sm font-medium transition-colors">
              <i class="fas fa-book mr-1.5 opacity-70"></i> Surnames
            </a>

            <a href="/admin/events" class="text-slate-300 hover:bg-admin-800 hover:text-white px-3 py-2 rounded-md text-sm font-medium transition-colors">
              <i class="fas fa-calendar-alt mr-1.5 opacity-70"></i> Events
            </a>

            <a href="/admin/matrimonial" class="text-slate-300 hover:bg-admin-800 hover:text-white px-3 py-2 rounded-md text-sm font-medium transition-colors">
              <i class="fas fa-rings mr-1.5 opacity-70"></i> Matrimonial
            </a>

            <a href="/admin/gallery" class="text-slate-300 hover:bg-admin-800 hover:text-white px-3 py-2 rounded-md text-sm font-medium transition-colors">
              <i class="fas fa-images mr-1.5 opacity-70"></i> Gallery
            </a>

            <a href="/admin/donations" class="text-slate-300 hover:bg-admin-800 hover:text-white px-3 py-2 rounded-md text-sm font-medium transition-colors">
              <i class="fas fa-hand-holding-heart mr-1.5 opacity-70"></i> Donate
            </a>

            <a href="/admin/inbox" class="text-slate-300 hover:bg-admin-800 hover:text-white px-3 py-2 rounded-md text-sm font-medium transition-colors">
              <i class="fas fa-inbox mr-1.5 opacity-70"></i> Inbox
            </a>

            <a href="/admin/documents" class="text-slate-300 hover:bg-admin-800 hover:text-white px-3 py-2 rounded-md text-sm font-medium transition-colors">
              <i class="fas fa-file-pdf mr-1.5 opacity-70"></i> Docs
            </a>

            <% if (locals.adminRole === 'Super Admin') { %>
            <a href="/admin/manage-admins" class="text-slate-300 hover:bg-admin-800 hover:text-white px-3 py-2 rounded-md text-sm font-medium transition-colors">
              <i class="fas fa-user-shield mr-1.5 opacity-70"></i> Admins
            </a>
            <% } %>
          </div>
        </div>

        <!-- Actions & Logout Button -->
        <div class="hidden lg:flex items-center">
          <a href="/admin/settings" class="text-slate-300 hover:bg-admin-800 hover:text-white px-3 py-2 rounded-md text-sm font-medium transition-colors mr-4 border border-transparent hover:border-slate-700" title="Global Settings">
            <i class="fas fa-cog"></i>
          </a>
          <a href="/admin/logout" class="bg-red-500/10 text-red-400 hover:bg-red-500 hover:text-white border border-red-500/20 px-4 py-1.5 rounded-md text-sm font-medium transition-all">
            <i class="fas fa-sign-out-alt mr-1"></i> Logout
          </a>
          <a href="/" target="_blank" class="ml-3 text-slate-400 hover:text-white transition-colors" title="View Live Website">
            <i class="fas fa-external-link-alt"></i>
          </a>
        </div>

        <!-- Mobile Menu Toggle -->
        <div class="flex lg:hidden">
          <button type="button" onclick="toggleAdminMenu()" class="text-slate-300 hover:text-white focus:outline-none p-2 rounded-md hover:bg-admin-800">
            <i class="fas fa-bars text-xl"></i>
          </button>
        </div>
      </div>
    </div>
    
    <!-- Mobile Menu dropdown -->
    <div id="admin-mobile-menu" class="hidden lg:hidden bg-admin-800 border-t border-slate-700">
      <div class="px-2 pt-2 pb-3 space-y-1 sm:px-3">
        <a href="/admin" class="text-slate-300 hover:bg-slate-700 hover:text-white block px-3 py-2 rounded-md text-base font-medium">Dashboard</a>
        <a href="/admin/announcements" class="text-slate-300 hover:bg-slate-700 hover:text-white block px-3 py-2 rounded-md text-base font-medium">Manage Home</a>
        <a href="/admin/members" class="text-slate-300 hover:bg-slate-700 hover:text-white block px-3 py-2 rounded-md text-base font-medium">Manage Directory</a>
        <a href="/admin/surnames" class="text-slate-300 hover:bg-slate-700 hover:text-white block px-3 py-2 rounded-md text-base font-medium">Manage Surnames</a>
        <a href="/admin/events" class="text-slate-300 hover:bg-slate-700 hover:text-white block px-3 py-2 rounded-md text-base font-medium">Manage Events</a>
        <a href="/admin/matrimonial" class="text-slate-300 hover:bg-slate-700 hover:text-white block px-3 py-2 rounded-md text-base font-medium">Manage Matrimonial</a>
        <a href="/admin/gallery" class="text-slate-300 hover:bg-slate-700 hover:text-white block px-3 py-2 rounded-md text-base font-medium">Manage Gallery</a>
        <a href="/admin/donations" class="text-slate-300 hover:bg-slate-700 hover:text-white block px-3 py-2 rounded-md text-base font-medium">Manage Donate</a>
        <a href="/admin/inbox" class="text-slate-300 hover:bg-slate-700 hover:text-white block px-3 py-2 rounded-md text-base font-medium">Enquiry Inbox</a>
        <a href="/admin/documents" class="text-slate-300 hover:bg-slate-700 hover:text-white block px-3 py-2 rounded-md text-base font-medium">Manage Documents</a>
        <a href="/admin/settings" class="text-slate-300 hover:bg-slate-700 hover:text-white block px-3 py-2 rounded-md text-base font-medium"><i class="fas fa-cog mr-1"></i> Global Settings</a>
        <% if (locals.adminRole === 'Super Admin') { %>
        <a href="/admin/manage-admins" class="text-slate-300 hover:bg-slate-700 hover:text-white block px-3 py-2 rounded-md text-base font-medium"><i class="fas fa-user-shield mr-1"></i> Admin Roles</a>
        <% } %>
        <div class="pt-4 border-t border-slate-700 mt-2">
          <a href="/admin/logout" class="text-red-400 hover:bg-red-500 hover:text-white block px-3 py-2 rounded-md text-base font-medium">Logout</a>
          <a href="/" target="_blank" class="text-slate-400 hover:text-white block px-3 py-2 rounded-md text-base font-medium">View Website</a>
        </div>
      </div>
    </div>
  </nav>

  <script>
    function toggleAdminMenu() {
      const menu = document.getElementById('admin-mobile-menu');
      menu.classList.toggle('hidden');
    }
  </script>

  <!-- Admin CMS Sub-header path / breadcrumb -->
  <div class="bg-white border-b border-slate-200 shadow-sm py-3 px-4 sm:px-6 lg:px-8">
    <div class="max-w-7xl mx-auto flex items-center text-sm">
      <span class="text-slate-500 mr-2"><i class="fas fa-cog"></i> CMS Control Panel</span>
      <span class="text-slate-300 mx-2">/</span>
      <span class="text-saffron-600 font-medium"><%= title %></span>
    </div>
  </div>

  <main class="flex-grow flex flex-col pt-4">
