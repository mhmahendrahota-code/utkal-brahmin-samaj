<%- include('partials/admin-header') %>

<section class="py-8 bg-gray-50 flex-grow">
  <div class="container mx-auto px-4 max-w-5xl">

    <div class="flex items-center mb-6">
      <a href="/admin" class="text-gray-400 hover:text-saffron-500 mr-4"><i class="fas fa-arrow-left text-xl"></i></a>
      <div>
        <h1 class="text-2xl font-bold text-gray-800">Surname Error Reports</h1>
        <p class="text-sm text-gray-500 mt-0.5">Corrections submitted by the public for the Surname Directory</p>
      </div>
      <span class="ml-auto bg-saffron-100 text-saffron-800 text-sm font-bold px-3 py-1 rounded-full">
        <%= reports.filter(r => r.status === 'pending').length %> Pending
      </span>
    </div>

    <% if (reports.length === 0) { %>
      <div class="bg-white rounded-lg border border-gray-100 text-center py-16">
        <i class="fas fa-flag text-4xl text-gray-300 mb-3"></i>
        <p class="text-gray-500">No reports submitted yet.</p>
      </div>
    <% } else { %>
      <div class="space-y-4">
        <% reports.forEach(report => { %>
          <div class="bg-white rounded-lg shadow-sm border <%= report.status === 'resolved' ? 'border-green-100 opacity-70' : 'border-amber-100' %> p-5">
            <div class="flex items-start justify-between gap-4">
              <div class="flex-grow">

                <div class="flex items-center gap-3 mb-2 flex-wrap">
                  <span class="text-lg font-bold text-saffron-700"><%= report.surname %></span>
                  <span class="px-2 py-0.5 rounded text-xs font-semibold
                    <%= report.errorType === 'meaning' ? 'bg-blue-100 text-blue-700' :
                        report.errorType === 'gotra'   ? 'bg-purple-100 text-purple-700' :
                        report.errorType === 'hindi'   ? 'bg-orange-100 text-orange-700' :
                                                         'bg-gray-100 text-gray-600' %>">
                    <%= report.errorType === 'meaning' ? '📖 Meaning Error' :
                        report.errorType === 'gotra'   ? '🔱 Gotra Error' :
                        report.errorType === 'hindi'   ? '🇮🇳 Hindi Name Error' :
                                                         '📝 General' %>
                  </span>
                  <% if (report.status === 'resolved') { %>
                    <span class="px-2 py-0.5 rounded text-xs font-semibold bg-green-100 text-green-700">✅ Resolved</span>
                  <% } else { %>
                    <span class="px-2 py-0.5 rounded text-xs font-semibold bg-yellow-100 text-yellow-700">⏳ Pending</span>
                  <% } %>
                </div>

                <p class="text-gray-700 text-sm leading-relaxed mb-2"><%= report.description %></p>

                <p class="text-xs text-gray-400">
                  Reported by: <strong><%= report.reporterName %></strong> &nbsp;|&nbsp;
                  <%= new Date(report.createdAt).toLocaleDateString('en-IN', { day:'2-digit', month:'short', year:'numeric', hour:'2-digit', minute:'2-digit' }) %>
                </p>
              </div>

              <div class="flex flex-col gap-2 shrink-0">
                <% if (report.status !== 'resolved') { %>
                  <form method="POST" action="/admin/surname-reports/<%= report._id %>/resolve">
                    <button class="w-full text-xs bg-green-500 hover:bg-green-600 text-white font-medium px-3 py-1.5 rounded transition-colors">
                      ✅ Mark Resolved
                    </button>
                  </form>
                <% } %>
                <form method="POST" action="/admin/surname-reports/<%= report._id %>/delete" onsubmit="return confirm('Delete this report?')">
                  <button class="w-full text-xs bg-red-50 hover:bg-red-100 text-red-600 font-medium px-3 py-1.5 rounded border border-red-200 transition-colors">
                    🗑 Delete
                  </button>
                </form>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>
</section>

<%- include('partials/admin-footer') %>
