<%- include('partials/admin-header') %>

<section class="py-12 bg-gray-50 flex-grow">
  <div class="container mx-auto px-4 max-w-4xl">
    
    <div class="flex items-center mb-6">
      <a href="/admin/events" class="text-gray-400 hover:text-saffron-500 mr-4"><i class="fas fa-arrow-left text-xl"></i></a>
      <h1 class="text-2xl font-bold text-gray-800">Create New Event</h1>
    </div>

    <div class="bg-white rounded-lg shadow-sm border border-gray-100 p-6 md:p-8">
      <form action="/admin/events/add" method="POST">
        
        <div class="grid grid-cols-1 gap-6 mb-8">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Event Title *</label>
            <input type="text" name="title" required placeholder="e.g., Jagannath Rath Yatra 2024" class="w-full px-4 py-2 border border-gray-300 rounded focus:ring-saffron-500 focus:border-saffron-500">
          </div>
          
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Date & Time *</label>
              <input type="datetime-local" name="date" required class="w-full px-4 py-2 border border-gray-300 rounded focus:ring-saffron-500 focus:border-saffron-500 text-gray-700">
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Location *</label>
              <input type="text" name="location" required placeholder="e.g., Samaj Bhawan, Pusaur" class="w-full px-4 py-2 border border-gray-300 rounded focus:ring-saffron-500 focus:border-saffron-500">
            </div>
          </div>
          
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Description *</label>
            <textarea name="description" rows="5" required placeholder="Details about the event, timings, arrangements, etc." class="w-full px-4 py-2 border border-gray-300 rounded focus:ring-saffron-500 focus:border-saffron-500"></textarea>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Organizer (Optional)</label>
              <input type="text" name="organizer" placeholder="Youth Wing, etc." class="w-full px-4 py-2 border border-gray-300 rounded focus:ring-saffron-500 focus:border-saffron-500">
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Cover Image URL (Optional)</label>
              <input type="url" name="imageUrl" placeholder="https://example.com/poster.jpg" class="w-full px-4 py-2 border border-gray-300 rounded focus:ring-saffron-500 focus:border-saffron-500">
            </div>
          </div>
        </div>

        <div class="flex justify-end gap-4 border-t pt-6">
          <a href="/admin/events" class="px-6 py-2 border border-gray-300 rounded text-gray-700 font-medium hover:bg-gray-50 transition-colors">Cancel</a>
          <button type="submit" class="px-6 py-2 bg-saffron-600 hover:bg-saffron-700 text-white rounded font-medium shadow-sm transition-colors">
            <i class="fas fa-calendar-check mr-2"></i> Publish Event
          </button>
        </div>

      </form>
    </div>
  </div>
</section>

<%- include('partials/admin-footer') %>
