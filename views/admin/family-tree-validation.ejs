<%- include('partials/admin-header') %>

<section class="py-8 bg-gray-50 flex-grow">
  <div class="container mx-auto px-4 max-w-6xl">
    
    <!-- Header -->
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-6 gap-4">
      <div>
        <h1 class="text-2xl font-bold text-gray-800"><i class="fas fa-heartbeat text-indigo-500 mr-2"></i> Family Tree Validation</h1>
        <p class="text-gray-500 text-sm mt-1">Scan and fix broken relationships, inconsistent links, and family tree errors.</p>
      </div>
      <div class="flex gap-3">
        <a href="/admin" class="bg-white border border-gray-300 text-gray-700 px-4 py-2 rounded shadow-sm hover:bg-gray-50 transition text-sm font-medium">
          <i class="fas fa-arrow-left mr-1"></i> Back
        </a>
        <button id="btn-scan" class="bg-indigo-600 text-white px-4 py-2 rounded shadow-sm hover:bg-indigo-700 transition text-sm font-medium flex items-center">
          <i class="fas fa-sync-alt mr-2"></i> Run Full Scan
        </button>
      </div>
    </div>

    <!-- Loading State -->
    <div id="loading-state" class="hidden bg-white rounded-lg shadow-sm border border-gray-200 p-12 text-center">
      <div class="inline-block w-12 h-12 border-4 border-indigo-200 border-t-indigo-600 rounded-full animate-spin mb-4"></div>
      <h3 class="text-lg font-bold text-gray-800">Scanning Database...</h3>
      <p class="text-gray-500 text-sm mt-2">Checking all member relationships for inconsistencies. This may take a few seconds.</p>
    </div>

    <!-- Results Container -->
    <div id="results-container" class="space-y-6 hidden">
      
      <!-- Stats Overview -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
        <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-5">
          <div class="text-gray-500 text-xs font-bold uppercase tracking-wider mb-1">Total Members</div>
          <div class="text-2xl font-bold text-gray-800" id="stat-total">-</div>
        </div>
        <div class="bg-white rounded-lg shadow-sm border border-red-200 p-5 border-l-4 border-l-red-500">
          <div class="text-red-500 text-xs font-bold uppercase tracking-wider mb-1">Broken Links</div>
          <div class="text-2xl font-bold text-red-600" id="stat-broken">-</div>
        </div>
        <div class="bg-white rounded-lg shadow-sm border border-yellow-200 p-5 border-l-4 border-l-yellow-500">
          <div class="text-yellow-600 text-xs font-bold uppercase tracking-wider mb-1">Inconsistent Links</div>
          <div class="text-2xl font-bold text-yellow-700" id="stat-inconsistent">-</div>
        </div>
        <div class="bg-white rounded-lg shadow-sm border border-purple-200 p-5 border-l-4 border-l-purple-500">
          <div class="text-purple-600 text-xs font-bold uppercase tracking-wider mb-1">Orphaned Members</div>
          <div class="text-2xl font-bold text-purple-700" id="stat-orphans">-</div>
        </div>
      </div>

      <!-- Health Progress Bars -->
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
        <h3 class="text-md font-bold text-gray-800 mb-4 border-b pb-2">Tree Health Metrics</h3>
        
        <div class="mb-4">
          <div class="flex justify-between text-sm mb-1">
            <span class="font-medium text-gray-700">Profile Completeness (Name + Gotra + Village)</span>
            <span class="font-bold text-gray-900" id="bar-complete-text">0%</span>
          </div>
          <div class="w-full bg-gray-200 rounded-full h-2.5">
            <div id="bar-complete" class="bg-green-500 h-2.5 rounded-full" style="width: 0%"></div>
          </div>
        </div>
        
        <div>
          <div class="flex justify-between text-sm mb-1">
            <span class="font-medium text-gray-700">Linked to Family Tree</span>
            <span class="font-bold text-gray-900" id="bar-linked-text">0%</span>
          </div>
          <div class="w-full bg-gray-200 rounded-full h-2.5">
            <div id="bar-linked" class="bg-blue-500 h-2.5 rounded-full" style="width: 0%"></div>
          </div>
        </div>
      </div>

      <!-- Issues Table -->
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden">
        <div class="bg-gray-50 px-6 py-4 border-b border-gray-200 flex justify-between items-center">
          <h3 class="text-md font-bold text-gray-800">Identified Issues</h3>
          <span id="issue-count-badge" class="bg-red-100 text-red-800 text-xs font-bold px-2.5 py-1 rounded-full">0 Issues</span>
        </div>
        
        <div class="overflow-x-auto">
          <table class="w-full text-sm text-left">
            <thead class="text-xs text-gray-500 uppercase bg-gray-50 border-b">
              <tr>
                <th class="px-6 py-3">Severity</th>
                <th class="px-6 py-3">Member</th>
                <th class="px-6 py-3">Issue Type</th>
                <th class="px-6 py-3">Description</th>
                <th class="px-6 py-3 text-right">Action</th>
              </tr>
            </thead>
            <tbody id="issues-tbody">
              <!-- Populated by JS -->
            </tbody>
          </table>
        </div>
        
        <div id="no-issues" class="hidden p-8 text-center text-gray-500">
          <i class="fas fa-check-circle text-green-500 text-4xl mb-3"></i>
          <p class="text-lg font-medium">All relationships look healthy!</p>
          <p class="text-sm mt-1">No broken links or inconsistencies found.</p>
        </div>
      </div>

    </div>

  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const btnScan = document.getElementById('btn-scan');
    const loadingState = document.getElementById('loading-state');
    const resultsContainer = document.getElementById('results-container');
    
    // Load data on page open
    runScan();

    btnScan.addEventListener('click', runScan);

    async function runScan() {
      btnScan.disabled = true;
      btnScan.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i> Scanning...';
      
      resultsContainer.classList.add('hidden');
      loadingState.classList.remove('hidden');

      try {
        const response = await fetch('/admin/api/family-tree/validation-report');
        const data = await response.json();
        
        if (data.ok) {
          updateDashboard(data);
        } else {
          alert('Error running scan: ' + data.error);
        }
      } catch (err) {
        console.error(err);
        alert('Network error while scanning.');
      } finally {
        loadingState.classList.add('hidden');
        resultsContainer.classList.remove('hidden');
        btnScan.disabled = false;
        btnScan.innerHTML = '<i class="fas fa-sync-alt mr-2"></i> Run Full Scan';
      }
    }

    function updateDashboard(data) {
      const { stats, issues } = data;

      // Update Stat Cards
      document.getElementById('stat-total').textContent = stats.totalMembers;
      document.getElementById('stat-broken').textContent = stats.brokenRelationships;
      document.getElementById('stat-inconsistent').textContent = stats.inconsistentRelationships;
      document.getElementById('stat-orphans').textContent = stats.orphanedMembers;

      // Update Progress Bars
      document.getElementById('bar-complete').style.width = stats.completeProfilesPercent + '%';
      document.getElementById('bar-complete-text').textContent = stats.completeProfilesPercent + '%';
      
      document.getElementById('bar-linked').style.width = stats.linkedToTreePercent + '%';
      document.getElementById('bar-linked-text').textContent = stats.linkedToTreePercent + '%';

      // Update Issues Table
      const tbody = document.getElementById('issues-tbody');
      const noIssues = document.getElementById('no-issues');
      const countBadge = document.getElementById('issue-count-badge');
      
      tbody.innerHTML = '';
      countBadge.textContent = `${issues.length} Issues`;

      if (issues.length === 0) {
        tbody.parentNode.classList.add('hidden');
        noIssues.classList.remove('hidden');
        countBadge.classList.replace('bg-red-100', 'bg-green-100');
        countBadge.classList.replace('text-red-800', 'text-green-800');
      } else {
        tbody.parentNode.classList.remove('hidden');
        noIssues.classList.add('hidden');
        countBadge.classList.replace('bg-green-100', 'bg-red-100');
        countBadge.classList.replace('text-green-800', 'text-red-800');

        issues.forEach(issue => {
          const tr = document.createElement('tr');
          tr.className = 'border-b hover:bg-gray-50';
          
          let severityHtml = '';
          if (issue.severity === 'critical') {
            severityHtml = `<span class="bg-red-100 text-red-800 text-xs font-bold px-2 py-0.5 rounded border border-red-200"><i class="fas fa-times-circle mr-1"></i> Critical</span>`;
          } else if (issue.severity === 'high') {
            severityHtml = `<span class="bg-orange-100 text-orange-800 text-xs font-bold px-2 py-0.5 rounded border border-orange-200"><i class="fas fa-exclamation-triangle mr-1"></i> High</span>`;
          } else {
            severityHtml = `<span class="bg-yellow-100 text-yellow-800 text-xs font-bold px-2 py-0.5 rounded border border-yellow-200">Medium</span>`;
          }

          const isAutoFixable = issue.action.toLowerCase().includes('auto-fix') || issue.action.toLowerCase().includes('remove');

          tr.innerHTML = `
            <td class="px-6 py-3">${severityHtml}</td>
            <td class="px-6 py-3 font-medium text-gray-900">
              <a href="/members/${issue.memberId}" target="_blank" class="hover:text-indigo-600 hover:underline">${issue.memberName}</a>
            </td>
            <td class="px-6 py-3 text-gray-600"><code class="bg-gray-100 px-1 py-0.5 rounded text-xs">${issue.type}</code></td>
            <td class="px-6 py-3 text-gray-600">${issue.message}</td>
            <td class="px-6 py-3 text-right">
              ${isAutoFixable 
                ? `<button onclick="fixIssue('${issue.type}', '${issue.memberId}')" class="text-white bg-indigo-500 hover:bg-indigo-600 px-3 py-1.5 rounded text-xs font-medium transition shadow-sm"><i class="fas fa-wrench mr-1"></i> Fix</button>` 
                : `<a href="/admin/members/${issue.memberId}/edit" target="_blank" class="text-gray-700 bg-gray-200 hover:bg-gray-300 px-3 py-1.5 rounded text-xs font-medium transition"><i class="fas fa-edit mr-1"></i> Manual Edit</a>`
              }
            </td>
          `;
          tbody.appendChild(tr);
        });
      }
    }
  });

  async function fixIssue(type, memberId) {
    if (!confirm('Are you sure you want to apply this auto-fix?')) return;
    
    try {
      const res = await fetch('/admin/api/family-tree/fix-issue', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ issueType: type, memberId: memberId })
      });
      
      const data = await res.json();
      if (data.ok) {
        // Re-run scan to update UI
        document.getElementById('btn-scan').click();
      } else {
        alert('Failed to fix issue: ' + data.error);
      }
    } catch (err) {
      alert('Network error while trying to fix the issue.');
    }
  }
</script>

<%- include('partials/admin-footer') %>