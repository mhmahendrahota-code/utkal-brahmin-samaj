<%- include('../partials/header') %>

<section class="py-12 bg-gray-50 flex-grow">
  <div class="container mx-auto px-4 max-w-4xl">
    
    <div class="mb-6">
      <a href="/members" class="text-gray-500 hover:text-saffron-600 font-medium transition-colors"><i class="fas fa-arrow-left mr-2"></i> Back to Directory</a>
    </div>

    <div class="bg-white rounded-2xl shadow-lg border border-gray-100 overflow-hidden">
      
      <!-- Top Banner / Header -->
      <div class="bg-saffron-600 h-32 relative">
        <div class="absolute -bottom-12 left-8">
          <div class="h-24 w-24 bg-white rounded-full flex items-center justify-center shadow-md border-4 border-white text-3xl font-bold text-saffron-600">
            <%= member.name.charAt(0).toUpperCase() %>
          </div>
        </div>
        <div class="absolute top-4 right-4">
          <% if(member.isCommitteeMember) { %>
            <span class="bg-white text-saffron-700 px-3 py-1 rounded-full text-xs font-bold shadow-sm inline-flex items-center">
              <i class="fas fa-star text-yellow-500 mr-2"></i> Committee Member
            </span>
          <% } %>
        </div>
      </div>

      <!-- Profile Content -->
      <div class="p-8 pt-16">
        <div class="mb-8">
          <h1 class="text-3xl font-bold text-gray-900 mb-1"><%= member.name %></h1>
          <p class="text-gray-500 font-medium text-lg flex items-center">
            <i class="fas fa-map-marker-alt text-saffron-500 mr-2"></i> Original Village (Mool): <%= member.village %>
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          
          <!-- Column 1 -->
          <div>
            <h3 class="text-xl font-bold text-gray-800 border-b pb-2 mb-4">Personal Details</h3>
            <ul class="space-y-4">
              <li class="flex items-start">
                <span class="text-gray-400 w-8"><i class="fas fa-dharmachakra"></i></span>
                <div>
                  <p class="text-xs text-gray-500 font-semibold uppercase">Gotra</p>
                  <p class="text-gray-800 font-medium"><%= member.gotra %></p>
                </div>
              </li>
              <li class="flex items-start">
                <span class="text-gray-400 w-8"><i class="fas fa-briefcase"></i></span>
                <div>
                  <p class="text-xs text-gray-500 font-semibold uppercase">Occupation</p>
                  <p class="text-gray-800 font-medium"><%= member.occupation || 'Not specified' %></p>
                </div>
              </li>
            </ul>
          </div>

          <!-- Column 2 -->
          <div>
            <h3 class="text-xl font-bold text-gray-800 border-b pb-2 mb-4">Contact Information</h3>
            <div class="bg-gray-50 p-4 rounded-lg border border-gray-100">
              <ul class="space-y-4">
                <li class="flex items-start">
                  <span class="text-saffron-500 w-8 mt-1"><i class="fas fa-phone-alt"></i></span>
                  <div>
                    <p class="text-xs text-gray-500 font-semibold uppercase">Phone Number</p>
                    <a href="tel:<%= member.contactNumber %>" class="text-saffron-600 font-bold hover:underline"><%= member.contactNumber %></a>
                  </div>
                </li>
                <% if(member.email) { %>
                  <li class="flex items-start">
                    <span class="text-saffron-500 w-8 mt-1"><i class="fas fa-envelope"></i></span>
                    <div>
                      <p class="text-xs text-gray-500 font-semibold uppercase">Email Address</p>
                      <a href="mailto:<%= member.email %>" class="text-gray-800 hover:text-saffron-600 transition-colors"><%= member.email %></a>
                    </div>
                  </li>
                <% } %>
                <% if(member.address) { %>
                  <li class="flex items-start">
                    <span class="text-saffron-500 w-8 mt-1"><i class="fas fa-home"></i></span>
                    <div>
                      <p class="text-xs text-gray-500 font-semibold uppercase">Current Address</p>
                      <p class="text-gray-800 whitespace-pre-line"><%= member.address %></p>
                    </div>
                  </li>
                <% } %>
              </ul>
            </div>
          </div>

        </div>

        <% if (member.matrimonialProfile && member.matrimonialProfile.isEligible && member.matrimonialProfile.isApproved) { %>
          <div class="mt-10 bg-blue-50 border border-blue-100 rounded-lg p-6">
            <h3 class="text-lg font-bold text-blue-800 mb-4 flex items-center"><i class="fas fa-rings mr-2"></i> Matrimonial Details</h3>
            <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
              <div>
                <p class="text-xs text-gray-500 uppercase">Age</p>
                <p class="font-medium text-gray-800"><%= Math.floor((new Date() - new Date(member.matrimonialProfile.dateOfBirth)) / 31557600000) %> Years</p>
              </div>
              <div>
                <p class="text-xs text-gray-500 uppercase">Height</p>
                <p class="font-medium text-gray-800"><%= member.matrimonialProfile.height || 'N/A' %></p>
              </div>
              <div class="col-span-2">
                <p class="text-xs text-gray-500 uppercase">Education</p>
                <p class="font-medium text-gray-800"><%= member.matrimonialProfile.education || 'N/A' %></p>
              </div>
            </div>
          </div>
        <% } %>

      </div>
    </div>

  </div>
</section>

<%- include('../partials/footer') %>
