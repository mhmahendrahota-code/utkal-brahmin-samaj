<%- include('../partials/header') %>

  <!-- Page Header -->
  <section class="bg-saffron-900 py-12 text-white">
    <div class="container mx-auto px-4 text-center">
      <h1 class="text-3xl md:text-5xl font-bold mb-4 font-display">Member Directory</h1>
      <p class="text-saffron-100 max-w-2xl mx-auto">Connect with members of the Pusaur Utkal Brahmin Samaj community.
      </p>
    </div>
  </section>

  <!-- Main Content -->
  <section class="py-12 bg-gray-50 flex-grow">
    <div class="container mx-auto px-4">

      <!-- Search Form -->
      <div class="bg-white p-6 rounded-lg shadow-sm border border-gray-100 mb-8 max-w-4xl mx-auto">
        <form action="/members" method="GET" class="flex flex-col md:flex-row gap-4">
          <div class="flex-grow">
            <label for="search" class="block text-sm font-medium text-gray-700 mb-1">Search Name / Gotra</label>
            <div class="relative">
              <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                <i class="fas fa-search text-gray-400"></i>
              </div>
              <input type="text" name="search" id="search" value="<%= searchQuery %>"
                placeholder="E.g., Sharma, Kashyap..."
                class="block w-full pl-10 pr-3 py-2 border border-gray-300 rounded-md focus:ring-saffron-500 focus:border-saffron-500 bg-gray-50 text-gray-900">
            </div>
          </div>

          <div class="md:w-1/3">
            <label for="village" class="block text-sm font-medium text-gray-700 mb-1">Filter by Village</label>
            <div class="relative">
              <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                <i class="fas fa-map-marker-alt text-gray-400"></i>
              </div>
              <input type="text" name="village" id="village" value="<%= villageQuery %>" placeholder="Village Name"
                class="block w-full pl-10 pr-3 py-2 border border-gray-300 rounded-md focus:ring-saffron-500 focus:border-saffron-500 bg-gray-50 text-gray-900">
            </div>
          </div>

          <div class="flex items-end">
            <button type="submit"
              class="w-full md:w-auto bg-saffron-600 hover:bg-saffron-700 text-white font-medium py-2 px-6 rounded-md transition-colors shadow-sm">
              Search
            </button>
          </div>
        </form>
      </div>

      <!-- Results count & actions -->
      <div class="flex justify-between items-center mb-6 max-w-5xl mx-auto">
        <h2 class="text-xl font-bold text-gray-800">
          Found <%= members ? members.length : 0 %> Members
            <% if(searchQuery || villageQuery) { %>
              <a href="/members" class="text-sm font-normal text-saffron-600 ml-3 hover:underline">(Clear filters)</a>
              <% } %>
        </h2>
      </div>

      <!-- Members Grid -->
      <div class="max-w-5xl mx-auto">
        <% if (members && members.length > 0) { %>
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            <% members.forEach((member) => { %>
              <div
                class="bg-white rounded-lg shadow-sm border border-gray-100 p-6 flex flex-col hover:shadow-md transition-shadow">
                <div class="flex items-start justify-between mb-4">
                  <div class="flex items-center">
                    <img src="<%= member.profileImage %>" alt="<%= member.name %>"
                      class="w-14 h-14 rounded-full object-cover border-2 border-saffron-200">
                    <div class="ml-4">
                      <h3 class="text-lg font-bold text-gray-900 flex items-center gap-1">
                        <span><%= (member.honorific ? member.honorific + ' ' : '') + member.name %></span>
                        <% if (member.surname) { %><span class="text-saffron-600"><%= member.surname %></span><% } %>
                      </h3>
                      <% if (member.isCommitteeMember) { %>
                        <span
                          class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-saffron-100 text-saffron-800 border border-saffron-200">
                          Committee
                        </span>
                        <% } %>
                    </div>
                  </div>
                </div>

                <div class="space-y-2 text-sm flex-grow mb-4">
                  <p class="flex items-center text-gray-600">
                    <i class="fas fa-om w-5 text-saffron-500"></i>
                    <span class="font-medium mr-2">Gotra:</span>
                    <%= member.gotra %>
                  </p>
                  <p class="flex items-center text-gray-600">
                    <i class="fas fa-map-marker-alt w-5 text-saffron-500"></i>
                    <span class="font-medium mr-2">Village:</span>
                    <%= member.village %>
                  </p>
                  <% if (member.occupation) { %>
                    <p class="flex items-center text-gray-600">
                      <i class="fas fa-briefcase w-5 text-saffron-500"></i>
                      <span class="font-medium mr-2">Work:</span>
                      <%= member.occupation %>
                    </p>
                    <% } %>
                </div>

                <div class="pt-4 border-t border-gray-100 mt-auto">
                  <a href="/members/<%= member._id %>"
                    class="w-full bg-gray-50 hover:bg-saffron-50 text-saffron-700 font-medium py-2 rounded border border-gray-200 hover:border-saffron-300 transition-colors text-sm text-center block">
                    <i class="fas fa-address-card mr-2"></i> View Full Profile
                  </a>
                </div>
              </div>
              <% }) %>
          </div>
          <% } else { %>
            <div class="text-center py-16 bg-white rounded-lg border border-gray-100">
              <i class="fas fa-users-slash text-5xl text-gray-300 mb-4"></i>
              <h3 class="text-xl font-medium text-gray-700">No members found</h3>
              <p class="text-gray-500 mt-2">Try adjusting your search criteria.</p>
            </div>
            <% } %>
      </div>

    </div>
  </section>

  <%- include('../partials/footer') %>