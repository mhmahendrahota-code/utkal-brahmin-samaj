<%- include('./partials/header') %>

<style>
  .card-hover {
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .card-hover:hover {
    transform: scale(1.03);
    box-shadow: 0 10px 30px rgba(180, 83, 9, 0.15);
  }
</style>

<!-- Load React and Babel for this specific page -->
<script src="https://unpkg.com/react@18/umd/react.development.js" crossorigin></script>
<script src="https://unpkg.com/react-dom@18/umd/react-dom.development.js" crossorigin></script>
<script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>

<div id="surname-root"></div>

<script id="surnames-data" type="application/json">
  <%- JSON.stringify(surnames) %>
</script>

<script type="text/babel">

// ── Dynamic Surname Dataset from Database (Bilingual) ──────────────────────
const SURNAMES = JSON.parse(document.getElementById('surnames-data').textContent);

const ALPHABET = "ABCDEFGHIJKLMNOPQRSTUVWXYZ".split("");

// ── Gotra badge color map ────────────────────────────────────
const GOTRA_COLORS = {
  "Kashyapa":    "bg-amber-100 text-amber-800",
  "Shandilya":   "bg-orange-100 text-orange-800",
  "Bharadwaj":   "bg-red-100 text-red-800",
  "Vashistha":   "bg-rose-100 text-rose-800",
  "Atri":        "bg-yellow-100 text-yellow-800",
  "Gautama":     "bg-lime-100 text-lime-800",
  "Gargya":      "bg-teal-100 text-teal-800",
  "Parashara":   "bg-sky-100 text-sky-800",
  "Vishwamitra": "bg-violet-100 text-violet-800",
  "Kaundinya":   "bg-pink-100 text-pink-800",
  "Kaushik":     "bg-green-100 text-green-800",
};

// ── SurnameCard ──────────────────────────────────────────────
function SurnameCard({ item, onReport }) {
  const badgeClass = GOTRA_COLORS[item.gotra] || "bg-gray-100 text-gray-700";
  return (
    <div className="card-hover bg-white rounded-2xl border border-amber-100 shadow-sm overflow-hidden flex flex-col">
      {/* Card Header */}
      <div className="bg-gradient-to-r from-saffron-700 to-saffron-500 px-6 py-4">
        <div className="flex items-start justify-between gap-2">
          <div>
            <h2 className="text-white text-xl font-bold font-display tracking-wide leading-tight">{item.surname}</h2>
            <p className="text-saffron-200 text-sm mt-0.5 font-medium">{item.hindiName}</p>
          </div>
          <div className="flex flex-col items-center gap-1">
            <span className="w-9 h-9 shrink-0 rounded-full bg-white/20 flex items-center justify-center text-white font-black text-base">
              {item.letter}
            </span>
          </div>
        </div>
      </div>
      {/* Card Body */}
      <div className="p-5 flex flex-col gap-3 flex-grow">
        <div>
          <p className="text-xs font-semibold text-gray-400 uppercase tracking-widest mb-1">Meaning</p>
          <p className="text-gray-700 text-sm leading-relaxed">{item.meaning}</p>
        </div>
        <div className="bg-amber-50 rounded-lg p-3 border border-amber-100">
          <p className="text-xs font-semibold text-saffron-600 uppercase tracking-widest mb-1">अर्थ</p>
          <p className="text-gray-600 text-xs leading-relaxed">{item.meaningHindi}</p>
        </div>
        <div className="flex items-end justify-between mt-auto pt-1">
          <div>
            <p className="text-xs font-semibold text-gray-400 uppercase tracking-widest mb-1">Gotra / गोत्र</p>
            <span className={`inline-block px-3 py-1 rounded-full text-xs font-semibold ${badgeClass}`}>
              🔱 {item.gotra}
            </span>
          </div>
          <button
            onClick={() => onReport(item.surname)}
            title="Report an error in this entry"
            className="flex items-center gap-1 text-xs text-gray-400 hover:text-red-500 transition-colors border border-gray-100 hover:border-red-200 hover:bg-red-50 px-2 py-1 rounded-lg"
          >
            🚩 <span>Report</span>
          </button>
        </div>
      </div>
    </div>
  );
}

// ── Report Modal ──────────────────────────────────────────────
function ReportModal({ surname, onClose }) {
  const [form, setForm] = React.useState({ reporterName: '', errorType: 'meaning', description: '' });
  const [status, setStatus] = React.useState(null); // null | 'sending' | 'success' | 'error'

  const handleSubmit = async (e) => {
    e.preventDefault();
    setStatus('sending');
    try {
      const res = await fetch('/admin/api/surname-report', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ surname, ...form })
      });
      const data = await res.json();
      setStatus(data.success ? 'success' : 'error');
    } catch {
      setStatus('error');
    }
  };

  return (
    <div className="fixed inset-0 z-50 flex items-center justify-center px-4"
      style={{ background: 'rgba(0,0,0,0.55)', backdropFilter: 'blur(4px)' }}
      onClick={e => e.target === e.currentTarget && onClose()}
    >
      <div className="bg-white rounded-2xl shadow-2xl w-full max-w-md overflow-hidden">
        {/* Modal Header */}
        <div className="bg-gradient-to-r from-red-700 to-red-500 px-6 py-4 flex items-center justify-between">
          <div>
            <h3 className="text-white font-bold text-lg">🚩 Report an Error</h3>
            <p className="text-red-100 text-xs mt-0.5">Surname: <strong>{surname}</strong></p>
          </div>
          <button onClick={onClose} className="text-white/70 hover:text-white text-2xl leading-none">&times;</button>
        </div>

        <div className="p-6">
          {status === 'success' ? (
            <div className="text-center py-6">
              <div className="text-5xl mb-3">✅</div>
              <h4 className="font-bold text-gray-800 text-lg mb-1">धन्यवाद! Report Submitted.</h4>
              <p className="text-gray-500 text-sm">Our team will review your correction. Thank you for helping improve the directory!</p>
              <button onClick={onClose} className="mt-4 bg-saffron-600 hover:bg-saffron-700 text-white font-medium px-6 py-2 rounded-lg transition-colors text-sm">Close</button>
            </div>
          ) : (
            <form onSubmit={handleSubmit} className="space-y-4">
              <div>
                <label className="block text-sm font-medium text-gray-700 mb-1">आपका नाम / Your Name (Optional)</label>
                <input
                  type="text"
                  placeholder="Anonymous"
                  value={form.reporterName}
                  onChange={e => setForm({...form, reporterName: e.target.value})}
                  className="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-red-300"
                />
              </div>
              <div>
                <label className="block text-sm font-medium text-gray-700 mb-1">गलती का प्रकार / Error Type *</label>
                <select
                  value={form.errorType}
                  onChange={e => setForm({...form, errorType: e.target.value})}
                  className="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm bg-white focus:outline-none focus:ring-2 focus:ring-red-300"
                >
                  <option value="meaning">📖 Meaning Error (अर्थ में गलती)</option>
                  <option value="hindi">🇮🇳 Hindi Name Error (हिंदी नाम गलत)</option>
                  <option value="gotra">🔱 Gotra Error (गोत्र गलत)</option>
                  <option value="general">📝 General / Other (अन्य)</option>
                </select>
              </div>
              <div>
                <label className="block text-sm font-medium text-gray-700 mb-1">सही जानकारी लिखें / Describe the Correction *</label>
                <textarea
                  required
                  rows={4}
                  placeholder="उदाहरण: 'गोत्र Kashyapa नहीं बल्कि Bharadwaj होना चाहिए' — Example: The correct meaning should be..."
                  value={form.description}
                  onChange={e => setForm({...form, description: e.target.value})}
                  className="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-red-300 resize-none"
                />
              </div>
              {status === 'error' && (
                <p className="text-red-500 text-xs">⚠️ Failed to submit. Please try again.</p>
              )}
              <div className="flex gap-3 pt-1">
                <button type="button" onClick={onClose}
                  className="flex-1 border border-gray-200 text-gray-600 hover:bg-gray-50 font-medium py-2 rounded-lg text-sm transition-colors">
                  Cancel
                </button>
                <button type="submit" disabled={status === 'sending'}
                  className="flex-1 bg-red-600 hover:bg-red-700 disabled:opacity-60 text-white font-medium py-2 rounded-lg text-sm transition-colors">
                  {status === 'sending' ? 'Sending...' : '🚩 Submit Report'}
                </button>
              </div>
            </form>
          )}
        </div>
      </div>
    </div>
  );
}

// ── Main Component ───────────────────────────────────────────
function SurnameDirectory() {
  const [search, setSearch] = React.useState("");
  const [activeLetter, setActiveLetter] = React.useState("ALL");
  const [reportSurname, setReportSurname] = React.useState(null);

  const filtered = SURNAMES.filter(item => {
    const q = search.toLowerCase();
    const matchesSearch =
      item.surname.toLowerCase().includes(q) ||
      item.hindiName.toLowerCase().includes(q) ||
      item.meaning.toLowerCase().includes(q) ||
      item.meaningHindi.toLowerCase().includes(q) ||
      item.gotra.toLowerCase().includes(q);
    const matchesLetter = activeLetter === "ALL" || item.letter === activeLetter;
    return matchesSearch && matchesLetter;
  });

  // Which letters actually have entries
  const availableLetters = new Set(SURNAMES.map(s => s.letter));

  return (
    <div className="bg-amber-50 flex-grow" style={{ fontFamily: 'Inter, sans-serif' }}>
      {/* Report Modal */}
      {reportSurname && (
        <ReportModal surname={reportSurname} onClose={() => setReportSurname(null)} />
      )}

      {/* ── Page Header ── */}
      <div className="bg-gradient-to-b from-maroon-900 to-saffron-900 text-white py-14 px-4 text-center">
        <p className="text-saffron-300 text-sm font-semibold tracking-[0.2em] uppercase mb-2 mt-4 md:mt-0">उत्कल ब्राह्मण समाज</p>
        <h1 className="text-4xl md:text-5xl font-bold font-display mb-2" style={{ fontFamily: 'Georgia, serif' }}>Surname Directory</h1>
        <p className="text-saffron-200 text-lg font-display mb-3" style={{ fontFamily: 'Georgia, serif' }}>उपनाम और उनके अर्थ</p>
        <p className="text-saffron-100 max-w-xl mx-auto text-sm md:text-base">
          Explore the rich heritage of 27 surnames — their origins, meanings in English &amp; Hindi, and associated Gotras.
        </p>
      </div>

      <div className="max-w-6xl mx-auto px-4 py-10">

        {/* ── Search Bar ── */}
        <div className="relative mb-6">
          <span className="absolute left-4 top-1/2 -translate-y-1/2 text-saffron-500 text-lg">🔍</span>
          <input
            type="text"
            value={search}
            onChange={e => { setSearch(e.target.value); setActiveLetter("ALL"); }}
            placeholder="Search by surname, उपनाम, meaning, or gotra..."
            className="w-full pl-12 pr-5 py-4 rounded-xl border border-amber-200 bg-white shadow-sm text-gray-800 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-saffron-400 text-base"
          />
          {search && (
            <button
              onClick={() => setSearch("")}
              className="absolute right-4 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600 text-xl font-bold"
            >×</button>
          )}
        </div>

        {/* ── Alphabet Filter ── */}
        <div className="flex flex-wrap gap-1.5 mb-8 justify-center">
          {["ALL", ...ALPHABET].map(letter => {
            const isActive = activeLetter === letter;
            const hasEntries = letter === "ALL" || availableLetters.has(letter);
            return (
              <button
                key={letter}
                onClick={() => { setActiveLetter(letter); setSearch(""); }}
                disabled={!hasEntries}
                className={`w-9 h-9 rounded-lg text-sm font-semibold transition-all
                  ${isActive
                    ? "bg-saffron-600 text-white shadow-md scale-110"
                    : hasEntries
                      ? "bg-white text-saffron-700 border border-saffron-200 hover:bg-saffron-50 hover:border-saffron-400"
                      : "bg-gray-100 text-gray-300 cursor-not-allowed"
                  }`}
              >
                {letter}
              </button>
            );
          })}
        </div>

        {/* ── Results Meta ── */}
        <p className="text-sm text-gray-500 mb-5">
          Showing <span className="font-semibold text-saffron-700">{filtered.length}</span> of {SURNAMES.length} surnames
          {activeLetter !== "ALL" && <span> — starting with <strong>'{activeLetter}'</strong></span>}
          {search && <span> — matching <strong>"{search}"</strong></span>}
        </p>

        {/* ── Card Grid ── */}
        {filtered.length > 0 ? (
          <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {filtered.map(item => (
              <SurnameCard key={item.surname} item={item} onReport={setReportSurname} />
            ))}
          </div>
        ) : (
          <div className="text-center py-20 text-gray-400">
            <div className="text-6xl mb-4">🙏</div>
            <p className="text-lg font-medium">No surnames found</p>
            <p className="text-sm mt-1">Try a different letter or search term</p>
          </div>
        )}
      </div>

      {/* ── Footer ── */}
      <div className="text-center pb-10 text-xs text-gray-400 mt-2">
        <p>कोई गलती दिखी? — Each card has a <strong>🚩 Report</strong> button to notify the admin.</p>
      </div>
    </div>
  );
}

// ── Mount ────────────────────────────────────────────────────
const root = ReactDOM.createRoot(document.getElementById('surname-root'));
root.render(<SurnameDirectory />);

</script>

<%- include('./partials/footer') %>
