<%- include('partials/header') %>

<section class="bg-saffron-900 py-12 text-white border-b-4 border-saffron-500">
  <div class="container mx-auto px-4 text-center">
    <h1 class="text-3xl md:text-5xl font-bold mb-4 font-display drop-shadow-md">दस्तावेज़ एवं ई-लाइब्रेरी</h1>
    <p class="text-saffron-100 max-w-2xl mx-auto font-medium text-lg drop-shadow-sm">
      समाज के विधान (Constitution), नियमों, बैठकों की कार्यवाहियों और महत्वपूर्ण रिपोर्ट का संग्रह
    </p>
  </div>
</section>

<section class="py-16 bg-white min-h-[50vh] flex-grow">
  <div class="container mx-auto px-4 max-w-6xl">
    
    <% if (documents && documents.length > 0) { %>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <% documents.forEach(doc => { %>
          <div class="bg-gray-50 rounded-xl p-6 border border-gray-200 shadow-sm hover:shadow-md transition-shadow relative overflow-hidden group">
            <div class="absolute top-0 right-0 p-4 opacity-10 group-hover:opacity-20 transition-opacity">
              <i class="fas fa-file-pdf text-6xl text-saffron-500"></i>
            </div>
            
            <span class="inline-block px-3 py-1 bg-saffron-100 text-saffron-800 text-xs font-bold rounded-full mb-3 shadow-sm border border-saffron-200"><%= doc.category %></span>
            
            <h3 class="text-xl font-bold text-gray-900 mb-2 leading-snug pr-8 line-clamp-2" title="<%= doc.title %>"><%= doc.title %></h3>
            
            <p class="text-gray-600 text-sm mb-4 line-clamp-3 h-12"><%= doc.description %></p>
            
            <div class="flex items-center justify-between mt-auto pt-4 border-t border-gray-200">
              <span class="text-xs text-gray-500 font-medium">Uploaded: <%= new Date(doc.dateUploaded).toLocaleDateString() %></span>
              <a href="<%= doc.fileUrl %>" target="_blank" class="bg-saffron-600 hover:bg-saffron-700 text-white px-4 py-2 rounded text-sm font-bold shadow-sm transition-colors flex items-center">
                <i class="fas fa-download mr-2"></i> View/Download
              </a>
            </div>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <div class="text-center py-20 bg-gray-50 rounded-2xl border border-gray-200 shadow-inner">
        <i class="fas fa-folder-open text-6xl text-gray-300 mb-4 drop-shadow-sm"></i>
        <h2 class="text-2xl font-bold text-gray-800 mb-2 font-display">कोई दस्तावेज़ मौजूद नहीं है</h2>
        <p class="text-gray-500 max-w-md mx-auto">वर्तमान में ई-लाइब्रेरी में कोई दस्तावेज़ या पीडीएफ फाइल उपलब्ध नहीं है। समिति सदस्यों द्वारा दस्तावेज़ अपलोड किए जाने पर वे यहाँ दिखाई देंगे।</p>
      </div>
    <% } %>

  </div>
</section>

<%- include('partials/footer') %>
