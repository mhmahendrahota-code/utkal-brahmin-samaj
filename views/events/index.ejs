<%- include('../partials/header') %>

<!-- Page Header -->
<section class="bg-saffron-900 py-12 text-white">
  <div class="container mx-auto px-4 text-center">
    <h1 class="text-3xl md:text-5xl font-bold mb-4 font-display">Events & Festivals</h1>
    <p class="text-saffron-100 max-w-2xl mx-auto">Stay updated with the latest happenings and upcoming festivals in our community.</p>
  </div>
</section>

<section class="py-12 bg-gray-50 flex-grow">
  <div class="container mx-auto px-4 max-w-5xl">
    
    <!-- Upcoming Events -->
    <h2 class="text-2xl font-bold text-gray-800 mb-6 flex items-center">
      <i class="fas fa-calendar-day text-saffron-500 mr-3"></i> Upcoming Events
    </h2>
    
    <% if (upcomingEvents && upcomingEvents.length > 0) { %>
      <div class="space-y-6 mb-16">
        <% upcomingEvents.forEach(event => { %>
          <div class="bg-white rounded-lg shadow-sm border border-gray-100 flex flex-col md:flex-row overflow-hidden hover:shadow-md transition-shadow">
            <div class="md:w-1/3 h-48 md:h-auto bg-gray-200 relative">
              <img src="<%= event.imageUrl %>" alt="<%= event.title %>" class="w-full h-full object-cover">
            </div>
            <div class="p-6 md:w-2/3 flex flex-col justify-center">
              <div class="flex items-center justify-between mb-2">
                <span class="text-saffron-600 font-bold bg-saffron-50 px-3 py-1 rounded text-sm">
                  <%= event.date.toLocaleDateString('en-US', { weekday: 'short', year: 'numeric', month: 'long', day: 'numeric' }) %>
                </span>
                <% if(event.organizer) { %>
                  <span class="text-gray-500 text-sm">By: <%= event.organizer %></span>
                <% } %>
              </div>
              <h3 class="text-2xl font-bold text-gray-900 mb-3"><%= event.title %></h3>
              <p class="text-gray-600 mb-4 line-clamp-2"><%= event.description %></p>
              <div class="flex items-center text-sm text-gray-500 font-medium space-x-6">
                <span class="flex items-center"><i class="fas fa-clock w-5 text-saffron-500"></i> <%= event.date.toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}) %></span>
                <span class="flex items-center"><i class="fas fa-map-marker-alt w-5 text-saffron-500"></i> <%= event.location %></span>
              </div>
              <!-- Description & Actions -->
              <div class="p-6">
                <h3 class="text-xl font-bold text-gray-800 mb-2"><%= event.title %></h3>
                <p class="text-gray-600 mb-6 line-clamp-3 text-sm"><%= event.description %></p>
                
                <div class="flex justify-between items-center pt-4 border-t border-gray-100 mt-auto">
                  <span class="text-xs font-bold text-gray-400 uppercase tracking-wider">
                    <i class="fas fa-users mr-1"></i> <%= event.rsvpCount || 0 %> Going
                  </span>
                  <% if(isUpcoming) { %>
                  <form action="/events/<%= event._id %>/rsvp" method="POST" class="inline">
                    <button type="submit" class="bg-saffron-50 hover:bg-saffron-100 text-saffron-700 font-bold py-2 px-4 rounded transition-colors text-sm shadow-sm border border-saffron-200">
                      <i class="far fa-check-circle mr-1 text-saffron-500"></i> I'm Going
                    </button>
                  </form>
                  <% } else { %>
                  <a href="/events/<%= event._id %>" class="text-saffron-600 hover:text-saffron-700 font-medium text-sm transition-colors">View Details <i class="fas fa-chevron-right text-xs ml-1"></i></a>
                  <% } %>
                </div>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <div class="bg-white rounded-lg shadow-sm p-10 text-center border border-gray-100 mb-16">
        <i class="far fa-calendar text-4xl text-gray-300 mb-3"></i>
        <h3 class="text-lg font-medium text-gray-600">No upcoming events are scheduled currently.</h3>
      </div>
    <% } %>

    <!-- Past Events (Brief) -->
    <h2 class="text-2xl font-bold text-gray-800 mb-6 flex items-center">
      <i class="fas fa-history text-saffron-500 mr-3"></i> Past Events
    </h2>
    
    <% if (pastEvents && pastEvents.length > 0) { %>
      <div class="bg-white rounded-lg shadow-sm border border-gray-100 overflow-hidden">
        <div class="divide-y divide-gray-100">
          <% pastEvents.forEach(event => { %>
            <div class="p-4 sm:p-6 flex flex-col sm:flex-row sm:items-center justify-between hover:bg-gray-50 transition-colors">
              <div class="mb-3 sm:mb-0">
                <h4 class="text-lg font-bold text-gray-800"><%= event.title %></h4>
                <p class="text-sm text-gray-500 mt-1"><%= event.location %></p>
              </div>
              <div class="text-left sm:text-right text-sm">
                <span class="block text-gray-900 font-medium">
                  <%= event.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %>
                </span>
                <span class="block text-gray-500 mt-1 text-xs">Completed</span>
              </div>
            </div>
          <% }) %>
        </div>
      </div>
    <% } else { %>
      <div class="bg-white rounded-lg shadow-sm p-8 text-center border border-gray-100">
        <p class="text-gray-500">No past events recorded yet.</p>
      </div>
    <% } %>

  </div>
</section>

<%- include('../partials/footer') %>
