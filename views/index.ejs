<%- include('partials/header') %>

  <!-- Hero Section -->
  <section class="bg-jagannath py-24 sm:py-32 relative">
    <div class="absolute inset-0 bg-white/40"></div>
    <div class="container mx-auto px-4 relative z-10 text-center">
      <h1 class="text-4xl sm:text-6xl font-extrabold text-saffron-900 mb-6 drop-shadow-md pb-2">
        पुसौर उत्कल ब्राह्मण समाज<br>में आपका हार्दिक स्वागत है – जय जगन्नाथ!
      </h1>
      <p class="text-lg sm:text-2xl text-gray-800 font-bold mb-10 max-w-4xl mx-auto drop-shadow-sm">
        धर्म, संस्कृति, और पारिवारिक एकता को समर्पित हमारा साझा डिजिटल मंच।
      </p>
      <div class="flex flex-wrap justify-center gap-4 mt-8">
        <a href="/members"
          class="bg-saffron-600 hover:bg-saffron-700 text-white px-8 py-3 rounded-full font-bold shadow-lg transition-transform transform hover:-translate-y-1">
          <i class="fas fa-address-book mr-2"></i> सदस्य निर्देशिका (Directory)
        </a>
        <a href="/members/community-tree"
          class="bg-blue-600 hover:bg-blue-700 text-white px-8 py-3 rounded-full font-bold shadow-lg transition-transform transform hover:-translate-y-1">
          <i class="fas fa-sitemap mr-2"></i> संपूर्ण वंशावली (Family Tree)
        </a>
        <a href="/donate"
          class="bg-white hover:bg-gray-100 text-saffron-600 px-8 py-3 rounded-full font-bold shadow-lg border border-saffron-200 transition-transform transform hover:-translate-y-1">
          <i class="fas fa-hand-holding-heart mr-2"></i> सहयोग करें
        </a>
      </div>
    </div>
  </section>

  <!-- Vision Section -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4">
      <div class="text-center max-w-4xl mx-auto mb-16">
        <i class="fas fa-dharmachakra text-4xl text-saffron-500 mb-4"></i>
        <h2 class="text-3xl font-bold text-gray-800 mb-4 font-display">हमारा विजन (Our Vision)</h2>
        <div class="w-24 h-1 bg-saffron-500 mx-auto rounded mb-6"></div>
        <p class="text-gray-700 leading-relaxed text-lg font-medium">
          पुसौर तहसील (जिला- रायगढ़) और इसके आसपास के क्षेत्रों में निवासरत सभी उत्कल (ओड़िआ) ब्राह्मण परिवारों को एक
          सूत्र में पिरोना। इस मंच का उद्देश्य हमारी समृद्ध जगन्नाथ संस्कृति का संरक्षण करना, युवा पीढ़ी को मार्गदर्शन
          देना और समाज के हर परिवार तक सहयोग पहुंचाना है।
        </p>
      </div>

      <!-- Services / Activities -->
      <h2 class="text-3xl font-bold text-center text-gray-800 mb-10 mt-16 font-display border-b pb-4">मुख्य सेवाएँ एवं
        गतिविधियाँ (Our Services)</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">

        <div
          class="bg-saffron-50 rounded-xl p-8 text-center shadow-sm border border-saffron-100 hover:shadow-md transition-shadow">
          <div
            class="w-16 h-16 bg-saffron-500 text-white rounded-full flex items-center justify-center text-2xl mx-auto mb-5">
            <i class="fas fa-rings-wedding"></i></div>
          <h3 class="text-xl font-bold text-gray-800 mb-3">वैवाहिक परिचय</h3>
          <p class="text-gray-600 text-sm font-medium">पुसौर और रायगढ़ जिले के योग्य युवक-युवतियों के लिए सुरक्षित और
            गोत्र-आधारित वैवाहिक डेटाबेस।</p>
        </div>

        <div
          class="bg-saffron-50 rounded-xl p-8 text-center shadow-sm border border-saffron-100 hover:shadow-md transition-shadow">
          <div
            class="w-16 h-16 bg-saffron-500 text-white rounded-full flex items-center justify-center text-2xl mx-auto mb-5">
            <i class="fas fa-users"></i></div>
          <h3 class="text-xl font-bold text-gray-800 mb-3">पारिवारिक निर्देशिका</h3>
          <p class="text-gray-600 text-sm font-medium">पुसौर तहसील के सभी उत्कल ब्राह्मण परिवारों का डिजिटल डेटाबेस।
            आपात स्थिति में एक-दूसरे से जुड़ने का सबसे आसान तरीका।</p>
        </div>

        <div
          class="bg-saffron-50 rounded-xl p-8 text-center shadow-sm border border-saffron-100 hover:shadow-md transition-shadow">
          <div
            class="w-16 h-16 bg-saffron-500 text-white rounded-full flex items-center justify-center text-2xl mx-auto mb-5">
            <i class="fas fa-user-graduate"></i></div>
          <h3 class="text-xl font-bold text-gray-800 mb-3">शिक्षा एवं मार्गदर्शन</h3>
          <p class="text-gray-600 text-sm font-medium">समाज के सफल अधिकारियों और प्रोफेशनल्स द्वारा युवा पीढ़ी के लिए
            एजुकेशन और करियर काउंसलिंग।</p>
        </div>

        <div
          class="bg-saffron-50 rounded-xl p-8 text-center shadow-sm border border-saffron-100 hover:shadow-md transition-shadow">
          <div
            class="w-16 h-16 bg-saffron-500 text-white rounded-full flex items-center justify-center text-2xl mx-auto mb-5">
            <i class="fas fa-gopuram"></i></div>
          <h3 class="text-xl font-bold text-gray-800 mb-3">सांस्कृतिक आयोजन</h3>
          <p class="text-gray-600 text-sm font-medium">शीतल षष्ठी, रथ यात्रा, और मकर संक्रांति जैसे पारंपरिक त्योहारों
            का सामूहिक आयोजन एवं संवर्धन।</p>
        </div>

      </div>
    </div>
  </section>

  <!-- Upcoming Events preview -->
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4">
      <div class="flex justify-between items-end mb-10 border-b pb-4">
        <div>
          <h2 class="text-3xl font-bold text-gray-800 font-display">आगामी कार्यक्रम (Upcoming Events)</h2>
          <p class="text-saffron-600 font-medium mt-1">हमारे आयोजनों और उत्सवों में शामिल हों</p>
        </div>
        <a href="/events"
          class="text-saffron-600 font-bold hover:text-saffron-800 transition-colors hidden sm:block">सभी देखें <i
            class="fas fa-arrow-right ml-1"></i></a>
      </div>

      <% if (typeof events !=='undefined' && events && events.length> 0) { %>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          <% events.forEach(event=> { %>
            <div
              class="bg-white rounded-lg shadow-md overflow-hidden hover:shadow-lg transition-shadow border border-gray-100">
              <div class="h-48 bg-gray-200 relative">
                <img
                  src="<%= event.imageUrl || 'https://images.unsplash.com/photo-1598225176697-e7fc98e2c9ef?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80' %>"
                  alt="<%= event.title %>" class="w-full h-full object-cover">
                <div class="absolute top-4 left-4 bg-white px-3 py-1 rounded shadow text-center">
                  <span class="block text-saffron-600 font-bold text-xl">
                    <%= event.date.getDate() %>
                  </span>
                  <span class="block text-gray-600 text-xs font-bold uppercase">
                    <%= event.date.toLocaleString('default', { month: 'short' }) %>
                  </span>
                </div>
              </div>
              <div class="p-6">
                <h3 class="text-xl font-bold text-gray-800 mb-2">
                  <%= event.title %>
                </h3>
                <p class="text-gray-600 text-sm mb-4 line-clamp-2">
                  <%= event.description %>
                </p>
                <div class="flex items-center text-sm text-gray-500 mb-2">
                  <i class="fas fa-map-marker-alt w-5 text-saffron-500"></i>
                  <%= event.location %>
                </div>
                <div class="flex items-center text-sm text-gray-500">
                  <i class="fas fa-clock w-5 text-saffron-500"></i>
                  <%= event.date.toLocaleTimeString([], {hour: '2-digit' , minute:'2-digit'}) %>
                </div>
              </div>
            </div>
            <% }) %>
        </div>
        <% } else { %>
          <div class="bg-white rounded-lg shadow-sm p-8 text-center border border-gray-100">
            <i class="far fa-calendar-times text-4xl text-gray-300 mb-4"></i>
            <h3 class="text-lg font-medium text-gray-600">वर्तमान में कोई आगामी कार्यक्रम नहीं है</h3>
            <p class="text-gray-400 mt-2">भविष्य के कार्यक्रमों की जानकारी के लिए जुड़े रहें।</p>
          </div>
          <% } %>

            <div class="text-center mt-8 sm:hidden">
              <a href="/events"
                class="inline-block bg-white text-saffron-600 font-bold py-2 px-6 rounded-full border border-saffron-500">सभी
                कार्यक्रम देखें</a>
            </div>
    </div>
  </section>

  <!-- Call To Action -->
  <section class="py-16 bg-saffron-900 text-white text-center border-t-4 border-saffron-500">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl md:text-4xl font-bold mb-4 font-display">समाज के डिजिटल सदस्य बनें!</h2>
      <p class="text-saffron-100 text-lg max-w-2xl mx-auto mb-10 leading-relaxed font-medium">
        क्या आप पुसौर तहसील या इसके आसपास के निवासी हैं? आज ही अपनी और अपने परिवार की जानकारी हमारी डिजिटल डायरेक्टरी
        में दर्ज करें। यह पूरी तरह निःशुल्क और सुरक्षित है।
      </p>
      <div class="flex flex-col sm:flex-row justify-center items-center gap-6">
        <a href="/members/add"
          class="bg-white text-saffron-900 hover:bg-saffron-50 font-bold py-4 px-10 rounded-full shadow-lg transition-transform transform hover:-translate-y-1 text-lg">
          <i class="fas fa-file-signature mr-2 text-saffron-500"></i> सदस्यता फॉर्म भरें
        </a>
        <a href="/members/matrimonial/submit"
          class="bg-transparent border-2 border-saffron-400 text-white hover:bg-saffron-800 font-bold py-4 px-10 rounded-full shadow-lg transition-transform transform hover:-translate-y-1 text-lg">
          <i class="fas fa-heart mr-2 text-saffron-400"></i> वैवाहिक प्रोफाइल बनाएं
        </a>
      </div>
    </div>
  </section>

  <%- include('partials/footer') %>