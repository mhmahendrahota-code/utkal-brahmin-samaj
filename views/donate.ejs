<%- include('partials/header') %>

  <!-- Page Header -->
  <section class="bg-saffron-900 py-12 text-white">
    <div class="container mx-auto px-4 text-center">
      <h1 class="text-3xl md:text-5xl font-bold mb-4 font-display">समाज को सहयोग दें (Contribute to the Samaj)</h1>
      <p class="text-saffron-100 max-w-2xl mx-auto">आपका उदार दान हमें समाज भवन निर्माण और सामुदायिक कल्याण में मदद करता है। (Your generous donations help us build the Samaj Bhawan and support community welfare.)</p>
    </div>
  </section>

  <section class="py-16 bg-gray-50 flex-grow">
    <div class="container mx-auto px-4 max-w-4xl">

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">

        <!-- Donation Info -->
        <div class="bg-white p-8 rounded-lg shadow-sm border border-gray-100 h-full">
          <h2 class="text-2xl font-bold text-gray-800 mb-6 border-b pb-2">समाज भवन पहल (Samaj Bhawan Initiative)</h2>
          <p class="text-gray-600 mb-8 leading-relaxed">
            उत्कल ब्राह्मण समाज पुसौर में एक सामुदायिक भवन (समाज भवन) का निर्माण कर रहा है। यह भवन शादियों, उपनयन संस्कारों, उत्सवों और सामुदायिक बैठकों के लिए एक केंद्रीय केंद्र के रूप में कार्य करेगा। हम सभी सक्षम सदस्यों से इस नेक काम के लिए उदारतापूर्वक योगदान देने की अपील करते हैं।
          </p>

          <!-- Live Progress Bar -->
          <div class="bg-gray-50 border border-gray-200 rounded-lg p-6 mb-8">
            <div class="flex justify-between items-end mb-2">
              <div>
                <span class="text-xs font-bold text-gray-500 uppercase tracking-wider">प्राप्त राशि (Raised So Far)</span>
                <div class="text-2xl font-bold text-saffron-600">₹<%= totalRaised.toLocaleString('en-IN') %>
                </div>
              </div>
              <div class="text-right">
                <span class="text-xs font-bold text-gray-500 uppercase tracking-wider">लक्ष्य (Goal)</span>
                <div class="text-lg font-bold text-gray-800">₹<%= targetGoal.toLocaleString('en-IN') %>
                </div>
              </div>
            </div>
            <div class="w-full bg-gray-200 rounded-full h-4 mb-2 overflow-hidden shadow-inner">
              <div class="bg-saffron-500 h-4 rounded-full transition-all duration-1000"
                <%- `style="width: ${Math.min(Math.round((totalRaised / targetGoal) * 100), 100)}%;"` %>></div>
            </div>
            <p class="text-right text-xs font-bold text-gray-500">
              <%= Math.round((totalRaised / targetGoal) * 100) %>% पूर्ण (Completed)
            </p>
          </div>
          <h2 class="text-2xl font-bold text-gray-800 mb-6 border-b pb-4">बैंक खाता विवरण (Bank Details)</h2>

          <div class="space-y-6">
            <div class="flex items-start">
              <div class="bg-saffron-100 p-3 rounded-full mr-4 text-saffron-600">
                <i class="fas fa-university text-xl"></i>
              </div>
              <div>
                <p class="text-xs text-gray-500 uppercase font-bold tracking-wider mb-1">खाता धारक (Account Name)</p>
                <p class="text-md font-bold text-gray-900"><%= siteSettings.accountName %></p>
              </div>
            </div>

            <div class="flex items-start">
              <div class="bg-saffron-100 p-3 rounded-full mr-4 text-saffron-600">
                <i class="fas fa-money-check text-xl"></i>
              </div>
              <div>
                <p class="text-xs text-gray-500 uppercase font-bold tracking-wider mb-1">खाता संख्या (Account Number)</p>
                <p class="text-lg font-bold text-gray-900 tracking-wider"><%= siteSettings.accountNumber %></p>
                <p class="text-sm text-gray-600 font-medium"><%= siteSettings.bankName %></p>
              </div>
            </div>

            <div class="flex items-start">
              <div class="bg-saffron-100 p-3 rounded-full mr-4 text-saffron-600">
                <i class="fas fa-code-branch text-xl"></i>
              </div>
              <div>
                <p class="text-xs text-gray-500 uppercase font-bold tracking-wider mb-1">IFSC कोड & शाखा (Branch)</p>
                <p class="text-lg font-bold text-gray-900 tracking-wider"><%= siteSettings.ifscCode %></p>
                <p class="text-sm text-gray-600 font-medium"><%= siteSettings.branchName %></p>
              </div>
            </div>
          </div>

          <div class="mt-8 p-4 bg-saffron-50 rounded-lg border border-saffron-200">
            <h3 class="font-bold text-saffron-900 mb-2">सूचना (Notice):</h3>
            <p class="text-sm text-saffron-800 leading-relaxed">प्रत्यक्ष बैंक हस्तांतरण करने के बाद, कृपया लेनदेन संदर्भ संख्या के साथ कोषाध्यक्ष को <%= siteSettings.contactPhone %> पर सूचित करें ताकि आपकी डिजिटल रसीद प्राप्त हो सके। (After transfer, inform treasurer at <%= siteSettings.contactPhone %> for receipt.)</p>
          </div>
        </div>

        <!-- QR Code / UPI -->
        <div
          class="bg-white p-8 rounded-lg shadow-sm border border-gray-100 h-full flex flex-col items-center justify-center text-center">
          <h2 class="text-2xl font-bold text-gray-800 mb-2">Scan & Pay via UPI</h2>
          <p class="text-gray-500 mb-8 text-sm">Any UPI App (GPay, PhonePe, Paytm, BHIM)</p>

          <div class="bg-white p-4 border border-gray-200 rounded-xl shadow-inner mb-6 flex justify-center items-center h-56 w-56 mx-auto">
            <% if (locals.siteSettings && siteSettings.qrCodeUrl) { %>
              <img src="<%= siteSettings.qrCodeUrl %>" alt="Scan to Donate" class="max-w-full max-h-full object-contain">
            <% } else { %>
              <!-- Placeholder for actual QR Code -->
              <div class="w-full h-full bg-gray-100 border-2 border-dashed border-gray-300 flex flex-col items-center justify-center text-gray-400">
                <i class="fas fa-qrcode text-6xl mb-2 opacity-50"></i>
                <span class="text-sm font-medium text-center px-2 text-xs">Setup QR in Admin Panel</span>
              </div>
            <% } %>
          </div>

          <div
            class="w-full flex items-center justify-center space-x-2 bg-gray-50 py-3 px-4 rounded-lg border border-gray-200">
            <span class="text-gray-600 font-medium">UPI ID:</span>
            <span class="text-gray-900 font-bold tracking-wide"><%= locals.siteSettings && siteSettings.upiId ? siteSettings.upiId : 'Not Configured' %></span>
            <button data-upi="<%= locals.siteSettings && siteSettings.upiId ? siteSettings.upiId : '' %>"
              onclick="navigator.clipboard.writeText(this.getAttribute('data-upi')); alert('UPI ID copied!')"
              class="text-saffron-600 hover:text-saffron-800 ml-2" title="Copy to clipboard">
              <i class="far fa-copy"></i>
            </button>
          </div>
        </div>

      </div>
    </div>
  </section>

  <%- include('partials/footer') %>