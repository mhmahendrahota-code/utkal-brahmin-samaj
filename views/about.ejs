<%- include('partials/header') %>

<section class="bg-saffron-900 py-12 text-white border-b-4 border-saffron-500">
  <div class="container mx-auto px-4 text-center">
    <h1 class="text-3xl md:text-5xl font-bold mb-4 font-display drop-shadow-md">हमारे बारे में (About Us)</h1>
    <p class="text-saffron-100 max-w-2xl mx-auto font-medium text-lg drop-shadow-sm">
      समाज के इतिहास, गौरवशाली विरासत और पुसौर क्षेत्र से हमारे जुड़ाव की जानकारी
    </p>
  </div>
</section>

<section class="py-16 bg-white flex-grow">
  <div class="container mx-auto px-4 max-w-5xl">
    <div class="prose prose-lg prose-saffron mx-auto max-w-none text-gray-800">
      
      <div class="flex justify-center mb-10">
        <i class="fas fa-om text-6xl text-saffron-500 drop-shadow-sm"></i>
      </div>

      <h2 class="text-3xl font-bold text-gray-900 mb-6 border-b-2 border-saffron-200 pb-3 font-display">हमारी गौरवशाली विरासत</h2>
      <p class="mb-10 font-medium leading-relaxed text-xl text-gray-700 bg-saffron-50 p-6 rounded-lg border-l-4 border-saffron-500 shadow-sm">
        उत्कल ब्राह्मण, भारतवर्ष के पारंपरिक **'पंच-गौड़'** ब्राह्मणों की एक अत्यंत प्रतिष्ठित शाखा हैं। सदियों से हमारा सीधा संबंध पुरी के श्री जगन्नाथ मंदिर की सेवा, वेदों के अध्ययन और सनातन धर्म के प्रचार-प्रसार से रहा है।
      </p>

      <h2 class="text-3xl font-bold text-gray-900 mb-6 border-b-2 border-saffron-200 pb-3 font-display">पुसौर तहसील में हमारा आगमन और विस्तार</h2>
      <p class="mb-12 font-medium leading-relaxed text-lg text-gray-700">
        ओडिशा राज्य की सीमाओं से लगे होने के कारण, पुसौर तहसील ऐतिहासिक रूप से उत्कल ब्राह्मणों का एक प्रमुख केंद्र रहा है। पुसौर, कोड़ातराई, बुनगा, जोंधरा और आसपास के दर्जनों गांवों में हमारे पूर्वजों ने शिक्षा, कृषि और पौरोहित्य कर्म के माध्यम से समाज को एक नई दिशा दी है। आज पुसौर का उत्कल ब्राह्मण समाज शिक्षा, व्यापार, तकनीकी और सरकारी सेवाओं में अपना परचम लहरा रहा है।
      </p>

      <h2 class="text-3xl font-bold text-gray-900 mb-6 border-b-2 border-saffron-200 pb-3 font-display">हमारे गोत्र एवं उपनाम (Gotra & Surnames)</h2>
      <p class="mb-6 font-medium text-gray-600 text-lg">
        समाज के परिवारों की मुख्य पहचान उनके गोत्र और उपनामों से होती है। पुसौर क्षेत्र में निवासरत परिवारों के प्रमुख विवरण इस प्रकार हैं:
      </p>

      <div class="overflow-x-auto rounded-xl shadow-md border border-gray-200 mb-10 bg-white">
        <table class="w-full text-left border-collapse">
          <thead>
            <tr class="bg-saffron-900 text-white text-lg">
              <th class="p-5 font-bold tracking-wide w-1/4">प्रमुख उपनाम</th>
              <th class="p-5 font-bold tracking-wide w-1/4">मुख्य गोत्र (संभावित)</th>
              <th class="p-5 font-bold tracking-wide">ऐतिहासिक कार्य / पहचान</th>
            </tr>
          </thead>
          <tbody class="text-gray-700 align-top text-base font-medium">
            <tr class="border-b border-gray-200 hover:bg-saffron-50 transition-colors">
              <td class="p-5 font-bold text-saffron-900">होता (Hota)</td>
              <td class="p-5">कौशिक, अत्रि</td>
              <td class="p-5 text-gray-600">ऋग्वेद के मंत्रों का पाठ व यज्ञ संपन्न कराने वाले।</td>
            </tr>
            <tr class="border-b border-gray-200 hover:bg-saffron-50 transition-colors bg-gray-50">
              <td class="p-5 font-bold text-saffron-900">मिश्र (Mishra)</td>
              <td class="p-5">भरद्वाज, गौतम</td>
              <td class="p-5 text-gray-600">सभी वेदों और शास्त्रों के संयुक्त ज्ञाता।</td>
            </tr>
            <tr class="border-b border-gray-200 hover:bg-saffron-50 transition-colors">
              <td class="p-5 font-bold text-saffron-900">दाश / दास (Dash)</td>
              <td class="p-5">वत्स, कश्यप</td>
              <td class="p-5 text-gray-600">धर्मशास्त्रों के विद्वान और त्यागी जीवन जीने वाले।</td>
            </tr>
            <tr class="border-b border-gray-200 hover:bg-saffron-50 transition-colors bg-gray-50">
              <td class="p-5 font-bold text-saffron-900">रथ (Rath)</td>
              <td class="p-5">वत्स, आत्रेय</td>
              <td class="p-5 text-gray-600">रथोत्सव के मुख्य सलाहकार एवं शास्त्र-ज्ञाता।</td>
            </tr>
            <tr class="border-b border-gray-200 hover:bg-saffron-50 transition-colors">
              <td class="p-5 font-bold text-saffron-900">पंडा (Panda)</td>
              <td class="p-5">भरद्वाज, वसिष्ठ</td>
              <td class="p-5 text-gray-600">मंदिरों के मुख्य पुजारी एवं तीर्थ पुरोहित।</td>
            </tr>
            <tr class="hover:bg-saffron-50 transition-colors bg-gray-50">
              <td class="p-5 font-bold text-saffron-900">सतपथी (Satapathy)</td>
              <td class="p-5">कौंडिन्य, पराशर</td>
              <td class="p-5 text-gray-600">सौ (100) ऋचाओं या वैदिक पथों के विशेषज्ञ।</td>
            </tr>
          </tbody>
        </table>
      </div>

      <!-- Committee Section -->
      <% if (locals.committee && committee.length > 0) { %>
        <h2 class="text-3xl font-bold text-gray-900 mt-16 mb-6 border-b-2 border-saffron-200 pb-3 font-display">हमारी समिति (Our Committee)</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 sm:grid-cols-2 lg:grid-cols-3 gap-8 mb-12">
          <% committee.forEach(member => { %>
            <div class="bg-white rounded-xl shadow-md border border-gray-100 overflow-hidden flex flex-col items-center p-6 hover:shadow-lg transition-shadow transform hover:-translate-y-1">
              <img src="<%= member.photoUrl || '/images/default-avatar.png' %>" alt="<%= member.name %>" onerror="this.src='https://ui-avatars.com/api/?name=<%= encodeURIComponent(member.name) %>&background=FF9933&color=fff'" class="w-32 h-32 rounded-full object-cover border-4 border-saffron-100 shadow-sm mb-4">
              <h3 class="text-xl font-bold text-gray-900 text-center"><%= member.name %></h3>
              <p class="text-saffron-700 font-bold mb-2 text-center text-sm bg-saffron-50 px-3 py-1 rounded-full mt-1 border border-saffron-200"><%= member.role %></p>
              <% if (member.phone) { %>
                <a href="tel:<%= member.phone %>" class="text-gray-500 hover:text-saffron-600 text-sm mt-2"><i class="fas fa-phone mr-1 text-xs"></i> <%= member.phone %></a>
              <% } %>
            </div>
          <% }) %>
        </div>
      <% } %>

      <!-- Contact Form Section -->
      <h2 class="text-3xl font-bold text-gray-900 mt-16 mb-6 border-b-2 border-saffron-200 pb-3 font-display" id="contact">हमसे संपर्क करें (Contact Us)</h2>
      
      <div class="bg-saffron-50 p-8 rounded-xl border border-saffron-100 shadow-sm mb-8">
        <p class="text-gray-700 mb-6 font-medium text-lg">
          यदि आपके कोई प्रश्न, सुझाव या संदेश हैं, तो कृपया नीचे दिए गए फॉर्म को भरें। हमारी समिति जल्द ही आपसे संपर्क करेगी।
        </p>

        <!-- Use EJS tags to display success/error from URL params directly (via JS) -->
        <script>
          document.addEventListener("DOMContentLoaded", function() {
            const urlParams = new URLSearchParams(window.location.search);
            if (urlParams.get('contact') === 'success') {
              const msg = document.createElement('div');
              msg.className = "bg-green-100 border-l-4 border-green-500 text-green-700 p-4 mb-6 font-bold";
              msg.innerHTML = "<i class='fas fa-check-circle mr-2'></i> आपका संदेश सफलतापूर्वक भेज दिया गया है।";
              document.getElementById('contact-form-container').prepend(msg);
            }
          });
        </script>

        <div id="contact-form-container">
          <form action="/contact-submit" method="POST" class="space-y-6">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <label class="block text-sm font-bold text-gray-700 mb-2">पूरा नाम (Full Name) *</label>
                <input type="text" name="name" required class="w-full px-4 py-3 rounded border border-gray-300 focus:ring-2 focus:ring-saffron-500 focus:border-saffron-500 transition-colors shadow-sm bg-white">
              </div>
              <div>
                <label class="block text-sm font-bold text-gray-700 mb-2">संपर्क नंबर (Phone) *</label>
                <input type="tel" name="phone" required class="w-full px-4 py-3 rounded border border-gray-300 focus:ring-2 focus:ring-saffron-500 focus:border-saffron-500 transition-colors shadow-sm bg-white">
              </div>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <label class="block text-sm font-bold text-gray-700 mb-2">ईमेल (Email) - Optional</label>
                <input type="email" name="email" class="w-full px-4 py-3 rounded border border-gray-300 focus:ring-2 focus:ring-saffron-500 focus:border-saffron-500 transition-colors shadow-sm bg-white">
              </div>
              <div>
                <label class="block text-sm font-bold text-gray-700 mb-2">विषय (Subject) *</label>
                <input type="text" name="subject" required class="w-full px-4 py-3 rounded border border-gray-300 focus:ring-2 focus:ring-saffron-500 focus:border-saffron-500 transition-colors shadow-sm bg-white">
              </div>
            </div>
            <div>
              <label class="block text-sm font-bold text-gray-700 mb-2">संदेश (Message) *</label>
              <textarea name="message" rows="5" required class="w-full px-4 py-3 rounded border border-gray-300 focus:ring-2 focus:ring-saffron-500 focus:border-saffron-500 transition-colors shadow-sm bg-white"></textarea>
            </div>
            <div>
              <button type="submit" class="bg-saffron-600 hover:bg-saffron-700 text-white font-bold py-3 px-8 rounded-lg shadow-md transition-transform transform hover:-translate-y-0.5 flex items-center justify-center w-full md:w-auto text-lg">
                <i class="fas fa-paper-plane mr-2"></i> संदेश भेजें
              </button>
            </div>
          </form>
        </div>
      </div>

    </div>
  </div>
</section>

<%- include('partials/footer') %>
