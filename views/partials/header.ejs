      <div class="flex space-x-4">
        <span class="hidden md:inline"><i class="fas fa-phone mr-1"></i> +91 98765 43210</span>
        <span><i class="fas fa-envelope mr-1"></i> contact@pusaursamaj.org</span>
      </div>
      <div class="flex space-x-4 items-center">
        <!-- PWA Install Link (Desktop/Top) -->
        <button onclick="installPWA()" id="pwa-top-install" class="hidden text-white hover:text-saffron-300 font-bold transition-colors items-center gap-1 border-r border-white/20 pr-4 mr-2">
          <i class="fas fa-download text-xs"></i> ऐप इंस्टॉल (App)
        </button>
        <a href="#" class="hover:text-saffron-500 transition-colors hidden sm:inline"><i
            class="fab fa-facebook"></i></a>
        <a href="#" class="hover:text-saffron-500 transition-colors hidden sm:inline"><i class="fab fa-youtube"></i></a>
      </div>
    </div>
  </div>

  <!-- Main Navigation -->
  <nav class="bg-white shadow-md sticky top-0 z-50">
    <div class="container mx-auto px-4 py-3 flex justify-between items-center">

      <!-- Logo & Title -->
      <a href="/" class="flex items-center space-x-3 group">
        <!-- Jagannath Logo -->
        <div
          class="w-14 h-14 rounded-full flex items-center justify-center shadow-lg border-[3px] border-saffron-500 overflow-hidden bg-saffron-50 group-hover:scale-105 transition-transform transform">
          <span class="text-4xl leading-none font-bold text-saffron-600" title="Jai Jagannath">ଓ</span>
        </div>
        <div>
          <h1 class="text-xl sm:text-2xl font-bold text-saffron-600 leading-tight">Utkal</h1>
          <h2 class="text-sm font-semibold text-gray-600 tracking-wider">Brahmin Samaj -Pusaur</h2>
        </div>
      </a>

      <!-- Desktop Menu -->
      <div class="hidden md:flex space-x-6 font-medium text-gray-700">
        <a href="/"
          class="hover:text-saffron-500 transition-colors border-b-2 border-transparent hover:border-saffron-500">होम (Home)</a>
        <a href="/members"
          class="hover:text-saffron-500 transition-colors border-b-2 border-transparent hover:border-saffron-500">निर्देशिका (Directory)</a>
        <a href="/surnames"
          class="hover:text-saffron-500 transition-colors border-b-2 border-transparent hover:border-saffron-500">उपनाम (Surnames)</a>
        <a href="/events"
          class="hover:text-saffron-500 transition-colors border-b-2 border-transparent hover:border-saffron-500">कार्यक्रम (Events)</a>
        <a href="/members/matrimonial"
          class="hover:text-saffron-500 transition-colors border-b-2 border-transparent hover:border-saffron-500">वैवाहिक (Matrimonial)</a>
        <a href="/gallery"
          class="hover:text-saffron-500 transition-colors border-b-2 border-transparent hover:border-saffron-500">गैलरी (Gallery)</a>
        <a href="/documents"
          class="hover:text-saffron-500 transition-colors border-b-2 border-transparent hover:border-saffron-500">ई-लाइब्रेरी (Library)</a>
        <a href="/donate"
          class="hover:text-saffron-500 transition-colors border-b-2 border-transparent hover:border-saffron-500">सहयोग (Donate)</a>
      </div>

      <div class="flex items-center space-x-3">
        <!-- Hidden Original Translate Widget -->
        <div id="google_translate_element"></div>

        <!-- NEW Custom Language Dropdown -->
        <div
          class="relative flex items-center bg-white border border-saffron-300 rounded-full shadow-sm hover:border-saffron-500 transition-colors px-1 py-1 sm:mr-2 cursor-pointer">
          <div
