        </button>
      </div>
    </div>

    <!-- Mobile Menu (Hidden by default) -->
    <div id="mobile-menu" class="hidden md:hidden bg-white border-t border-gray-100 px-4 py-2 shadow-inner">
      <button onclick="installPWA()" id="pwa-mobile-menu-item" class="hidden w-full text-left py-3 px-4 bg-saffron-50 text-saffron-700 font-black rounded-xl border border-saffron-200 mb-2 animate-pulse">
        <i class="fas fa-mobile-alt mr-2"></i> मोबाइल ऐप (Install App) 📲
      </button>
      <a href="/" class="block py-2 text-gray-700 hover:text-saffron-500 border-b border-gray-50">होम (Home)</a>
      <a href="/members" class="block py-2 text-gray-700 hover:text-saffron-500 border-b border-gray-50">निर्देशिका (Directory)</a>
      <a href="/surnames" class="block py-2 text-gray-700 hover:text-saffron-500 border-b border-gray-50">उपनाम (Surnames)</a>
      <a href="/events" class="block py-2 text-gray-700 hover:text-saffron-500 border-b border-gray-50">कार्यक्रम (Events)</a>
      <a href="/members/matrimonial"
        class="block py-2 text-gray-700 hover:text-saffron-500 border-b border-gray-50">वैवाहिक (Matrimonial)</a>
      <a href="/gallery" class="block py-2 text-gray-700 hover:text-saffron-500 border-b border-gray-50">गैलरी (Gallery)</a>
      <a href="/documents" class="block py-2 text-gray-700 hover:text-saffron-500 border-b border-gray-50">ई-लाइब्रेरी (Library)</a>
      <a href="/donate" class="block py-2 text-gray-700 hover:text-saffron-500 border-b border-gray-50">सहयोग (Donate)</a>
      <% if (locals.isAdmin) { %>
        <a href="/admin" class="block py-2 text-saffron-600 font-medium mt-2"><i
            class="fas fa-cogs mr-2"></i>Dashboard</a>
        <a href="/admin/logout" class="block py-2 text-red-600 font-medium mt-2"><i
            class="fas fa-sign-out-alt mr-2"></i>Logout</a>
        <% } else { %>
          <a href="/admin/login" class="block py-2 text-saffron-600 font-medium mt-2"><i
              class="fas fa-user-lock mr-2"></i>Admin Login</a>
          <% } %>
    </div>
  </nav>

  <script>
    function toggleMobileMenu() {
      const menu = document.getElementById('mobile-menu');
      menu.classList.toggle('hidden');
    }

    // Cookie-based Google Translate (most reliable method)
    function changeGoogleLanguage(langValue) {
      var hostname = window.location.hostname;
      document.cookie = 'googtrans=; expires=Thu, 01 Jan 1970 00:00:00 UTC; path=/;';
      document.cookie = 'googtrans=; expires=Thu, 01 Jan 1970 00:00:00 UTC; path=/; domain=' + hostname;
      document.cookie = 'googtrans=; expires=Thu, 01 Jan 1970 00:00:00 UTC; path=/; domain=.' + hostname;
      if (langValue !== 'en') {
        var cookieVal = '/auto/' + langValue;
        document.cookie = 'googtrans=' + cookieVal + '; path=/;';
        document.cookie = 'googtrans=' + cookieVal + '; path=/; domain=' + hostname;
        document.cookie = 'googtrans=' + cookieVal + '; path=/; domain=.' + hostname;
      }
      window.location.reload();
    }
    window.addEventListener('load', function () {
      var cookieMatch = document.cookie.match(/googtrans=\/(?:auto|en)\/([^;]+)/);
      if (cookieMatch) {
        var sel = document.getElementById('lang-select');
        if (sel) sel.value = cookieMatch[1];
      }
    });

    // ── PWA Service Worker Registration ──
    if ('serviceWorker' in navigator) {
      window.addEventListener('load', () => {
        navigator.serviceWorker.register('/sw.js')
          .then(reg => console.log('[PWA] Service Worker registered:', reg.scope))
          .catch(err => console.warn('[PWA] SW registration failed:', err));
      });
    }

    // ── PWA Install Banner ──
    let _deferredPrompt = null;
    window.addEventListener('beforeinstallprompt', (e) => {
      e.preventDefault();
      _deferredPrompt = e;
      
      // Show all install triggers
      const banner = document.getElementById('pwa-install-banner');
      const topBtn = document.getElementById('pwa-top-install');
      const mobileItem = document.getElementById('pwa-mobile-menu-item');
      const heroBtn = document.getElementById('pwa-hero-install');

      if (banner && !localStorage.getItem('pwa-dismissed')) {
        banner.classList.remove('hidden');
      }
      if (topBtn) topBtn.classList.remove('hidden', 'md:hidden');
      if (mobileItem) mobileItem.classList.remove('hidden');
      if (heroBtn) heroBtn.classList.remove('hidden');
    });

    // Also check if app is already installed
    window.addEventListener('appinstalled', () => {
      console.log('[PWA] App installed successfully');
      hideAllInstallTriggers();
    });

    function hideAllInstallTriggers() {
      ['pwa-install-banner', 'pwa-top-install', 'pwa-mobile-menu-item', 'pwa-hero-install'].forEach(id => {
        const el = document.getElementById(id);
        if (el) el.classList.add('hidden');
      });
    }

    function installPWA() {
      if (_deferredPrompt) {
        _deferredPrompt.prompt();
        _deferredPrompt.userChoice.then(choice => {
          if (choice.outcome === 'accepted') {
            hideAllInstallTriggers();
          }
          _deferredPrompt = null;
        });
      } else {
        // Fallback or Guide for iOS
        const isIOS = /iPad|iPhone|iPod/.test(navigator.userAgent) && !window.MSStream;
        if (isIOS) {
          alert('iPhone/iOS के लिए: Safari खोलें, "Share" बटन दबाएं, फिर "Add to Home Screen" चुनें।');
        } else {
          alert('कृपया ब्राउज़र मेनू से "Install App" चुनें।');
        }
      }
    }
    function dismissPWA() {
      document.getElementById('pwa-install-banner').classList.add('hidden');
      localStorage.setItem('pwa-dismissed', '1');
      // Reset dismissal after 7 days
      setTimeout(() => localStorage.removeItem('pwa-dismissed'), 7 * 24 * 60 * 60 * 1000);
    }
  </script>

  <!-- PWA Install Banner (Enhanced) -->
  <div id="pwa-install-banner" class="hidden fixed bottom-24 left-4 right-4 sm:left-auto sm:right-6 sm:w-96 bg-white border border-saffron-200 rounded-3xl shadow-[0_20px_50px_rgba(217,119,6,0.15)] p-5 z-[9999] flex flex-col gap-4 animate-in fade-in slide-in-from-bottom-5 duration-500">
    <div class="flex items-center gap-4">
      <div class="w-14 h-14 bg-gradient-to-br from-saffron-400 to-saffron-600 rounded-2xl flex items-center justify-center flex-shrink-0 shadow-lg shadow-saffron-200 ring-4 ring-saffron-50">
        <span class="text-3xl text-white font-black">ଓ</span>
      </div>
      <div class="flex-1 min-w-0">
        <p class="text-base font-black text-gray-900 leading-tight mb-0.5">Mobile App 📲</p>
        <p class="text-xs text-gray-400 font-medium">Behtar anubhav ke liye UBS App install karein.</p>
      </div>
      <button onclick="dismissPWA()" class="text-gray-300 hover:text-gray-500 p-1">
        <i class="fas fa-times text-lg"></i>
      </button>
    </div>
    <div class="flex gap-2">
      <button onclick="installPWA()" class="flex-1 bg-saffron-600 hover:bg-saffron-700 text-white font-black py-3 rounded-2xl transition-all shadow-md active:scale-95 text-sm uppercase tracking-widest">
        Install Now
      </button>
    </div>
  </div>

  <!-- News Ticker -->
  <div class="bg-saffron-100 border-b border-saffron-500 text-saffron-900 py-2 overflow-hidden flex whitespace-nowrap">
    <div class="px-4 font-bold bg-saffron-500 text-white z-10 hidden sm:block">Latest News</div>
    <marquee behavior="scroll" direction="left" class="flex-1 px-4 font-medium text-sm pt-1" onmouseover="this.stop();"
      onmouseout="this.start();">
      <% if (typeof announcements !=='undefined' && announcements.length> 0) { %>
        <% announcements.forEach((notice, idx)=> { %>
          <i class="<%= notice.icon %> text-saffron-500 mr-2"></i>
          <% if (notice.link) { %>
            <a href="<%= notice.link %>" class="hover:underline text-saffron-800"><%= notice.message %></a>
          <% } else { %>
            <%= notice.message %>
          <% } %>
            <% if (idx < announcements.length - 1) { %>
              <span class="mx-4 text-gray-400">|</span>
              <% } %>
                <% }) %>
                  <% } else { %>
                    <i class="fas fa-dharmachakra text-saffron-500 mr-2"></i>
                    Welcome to the official website of Utkal Brahmin Samaj -Pusaur!
                    <% } %>
    </marquee>
  </div>

  <!-- Main Content Wrapper -->
  <main class="flex-grow">