        <!-- Mobile Menu Button -->
        <button class="md:hidden text-saffron-600 text-2xl focus:outline-none pl-2" onclick="toggleMobileMenu()">
          <i class="fas fa-bars"></i>
        </button>
      </div>
    </div>

    <!-- Mobile Menu (Hidden by default) -->
    <div id="mobile-menu" class="hidden md:hidden bg-white border-t border-gray-100 px-4 py-2 shadow-inner">
      <a href="/" class="block py-2 text-gray-700 hover:text-saffron-500 border-b border-gray-50">Home</a>
      <a href="/members" class="block py-2 text-gray-700 hover:text-saffron-500 border-b border-gray-50">Directory</a>
      <a href="/surnames" class="block py-2 text-gray-700 hover:text-saffron-500 border-b border-gray-50">Surnames</a>
      <a href="/events" class="block py-2 text-gray-700 hover:text-saffron-500 border-b border-gray-50">Events</a>
      <a href="/members/matrimonial"
        class="block py-2 text-gray-700 hover:text-saffron-500 border-b border-gray-50">Matrimonial</a>
      <a href="/gallery" class="block py-2 text-gray-700 hover:text-saffron-500 border-b border-gray-50">Gallery</a>
      <a href="/documents" class="block py-2 text-gray-700 hover:text-saffron-500 border-b border-gray-50">ई-लाइब्रेरी (Docs)</a>
      <a href="/donate" class="block py-2 text-gray-700 hover:text-saffron-500 border-b border-gray-50">Donate</a>
      <% if (locals.isAdmin) { %>
        <a href="/admin" class="block py-2 text-saffron-600 font-medium mt-2"><i
            class="fas fa-cogs mr-2"></i>Dashboard</a>
        <a href="/admin/logout" class="block py-2 text-red-600 font-medium mt-2"><i
            class="fas fa-sign-out-alt mr-2"></i>Logout</a>
        <% } else { %>
          <a href="/admin/login" class="block py-2 text-saffron-600 font-medium mt-2"><i
              class="fas fa-user-lock mr-2"></i>Admin Login</a>
          <% } %>
    </div>
  </nav>

  <script>
    function toggleMobileMenu() {
      const menu = document.getElementById('mobile-menu');
      menu.classList.toggle('hidden');
    }

    // Cookie-based Google Translate (most reliable method)
    function changeGoogleLanguage(langValue) {
      var hostname = window.location.hostname;
      // Remove old googtrans cookies on both domain variants
      document.cookie = 'googtrans=; expires=Thu, 01 Jan 1970 00:00:00 UTC; path=/;';
      document.cookie = 'googtrans=; expires=Thu, 01 Jan 1970 00:00:00 UTC; path=/; domain=' + hostname;
      document.cookie = 'googtrans=; expires=Thu, 01 Jan 1970 00:00:00 UTC; path=/; domain=.' + hostname;

      if (langValue !== 'en') {
        // Use /auto/ as source so Google detects Hindi/English/Odia automatically
        var cookieVal = '/auto/' + langValue;
        document.cookie = 'googtrans=' + cookieVal + '; path=/;';
        document.cookie = 'googtrans=' + cookieVal + '; path=/; domain=' + hostname;
        document.cookie = 'googtrans=' + cookieVal + '; path=/; domain=.' + hostname;
      }
      window.location.reload();
    }

    // On page load, sync the dropdown to match current cookie language
    window.addEventListener('load', function () {
      var cookieMatch = document.cookie.match(/googtrans=\/(?:auto|en)\/([^;]+)/);
      if (cookieMatch) {
        var sel = document.getElementById('lang-select');
        if (sel) sel.value = cookieMatch[1];
      }
    });
  </script>

  <!-- News Ticker -->
  <div class="bg-saffron-100 border-b border-saffron-500 text-saffron-900 py-2 overflow-hidden flex whitespace-nowrap">
    <div class="px-4 font-bold bg-saffron-500 text-white z-10 hidden sm:block">Latest News</div>
    <marquee behavior="scroll" direction="left" class="flex-1 px-4 font-medium text-sm pt-1" onmouseover="this.stop();"
      onmouseout="this.start();">
      <% if (typeof announcements !=='undefined' && announcements.length> 0) { %>
        <% announcements.forEach((notice, idx)=> { %>
          <i class="<%= notice.icon %> text-saffron-500 mr-2"></i>
          <% if (notice.link) { %>
            <a href="<%= notice.link %>" class="hover:underline text-saffron-800"><%= notice.message %></a>
          <% } else { %>
            <%= notice.message %>
          <% } %>
            <% if (idx < announcements.length - 1) { %>
              <span class="mx-4 text-gray-400">|</span>
              <% } %>
                <% }) %>
                  <% } else { %>
                    <i class="fas fa-dharmachakra text-saffron-500 mr-2"></i>
                    Welcome to the official website of Utkal Brahmin Samaj -Pusaur!
                    <% } %>
    </marquee>
  </div>

  <!-- Main Content Wrapper -->
  <main class="flex-grow">